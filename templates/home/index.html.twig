    <div class="grid" style="grid-template-columns: repeat(3, 1fr); gap: 3rem;">
        <div class="card" data-aos="fade-up" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);">
            <i data-lucide="trophy" style="width: 48px; height: 48px; color: var(--warning); margin-bottom: 1.5rem;"></i>
            <h3>Gamified Learning</h3>
            <p style="color: var(--text-secondary);">Earn points, unlock badges, and climb the leaderboard while you learn.</p>
        </div>
        <div class="card" data-aos="fade-up" data-aos-delay="100" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);">
            <i data-lucide="zap" style="width: 48px; height: 48px; color: var(--brand-accent); margin-bottom: 1.5rem;"></i>
            <h3>Smart Integration</h3>
            <p style="color: var(--text-secondary);">Upload docs and let our system generate quizzes, summaries, and videos instantly.</p>
        </div>
        <div class="card" data-aos="fade-up" data-aos-delay="200" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);">
            <i data-lucide="users" style="width: 48px; height: 48px; color: var(--success); margin-bottom: 1.5rem;"></i>
            <h3>Community First</h3>
            <p style="color: var(--text-secondary);">Host events, share journals, and collaborate with students worldwide.</p>
        </div>
    </div>
</div>

