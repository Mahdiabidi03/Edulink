<!DOCTYPE html>
<html>
<head>
    <title>{% block title %}Admin - EduLink{% endblock %}</title>

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600;700&family=Fira+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- Canvas Confetti -->
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>

    <link rel="stylesheet" href="{{ asset('assets/css/variables.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/layout.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/components.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/admin.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/dashboard.css') }}">

    <script>
        (function() {
            const theme = localStorage.getItem("theme") || "dark";
            document.documentElement.className = theme + "-mode";
            document.documentElement.setAttribute("data-theme", theme);
        })();
    </script>
</head>
<body>

{% include 'components/topbaradmin.html.twig' %}

<div class="app">
    {% include 'components/sidebaradmin.html.twig' %}
    <main>
        {% block content %}{% endblock %}
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="{{ asset('assets/js/admin.js') }}"></script>
<script src="{{ asset('assets/js/theme.js') }}"></script>
<script>
  lucide.createIcons();

  // Flash Messages with SweetAlert2
  {% for label, messages in app.flashes %}
    {% for message in messages %}
      Swal.fire({
        icon: '{{ label == "error" ? "error" : (label == "warning" ? "warning" : "success") }}',
        title: '{{ message|e("js") }}',
        toast: true,
        position: 'top-end',
        showConfirmButton: false,
        timer: 4000,
        timerProgressBar: true,
        background: 'var(--bg-card)',
        color: 'var(--text-main)',
        iconColor: '{{ label == "error" ? "#ef4444" : (label == "warning" ? "#f59e0b" : "#8b5cf6") }}',
        didOpen: (toast) => {
          toast.addEventListener('mouseenter', Swal.stopTimer)
          toast.addEventListener('mouseleave', Swal.resumeTimer)
        }
      });

      {% if label == "success" %}
        confetti({
          particleCount: 150,
          spread: 80,
          origin: { y: 0.6 },
          colors: ['#3b82f6', '#8b5cf6', '#10b981']
        });
      {% endif %}
    {% endfor %}
  {% endfor %}
</script>

    {% block javascripts %}{% endblock %}
</body>
</html>
