<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; }
        .header { background: linear-gradient(135deg, #4361ee, #3a0ca3); color: white; padding: 20px; border-radius: 8px 8px 0 0; }
        .content { padding: 20px; background: #f8f9fa; border: 1px solid #e9ecef; }
        .btn { display: inline-block; padding: 12px 24px; background: #4361ee; color: white; text-decoration: none; border-radius: 6px; margin-top: 15px; }
        .footer { padding: 15px; text-align: center; font-size: 0.85em; color: #888; }
    </style>
</head>
<body>
    <div class="header">
        <h2>🎓 Someone wants to help!</h2>
    </div>
    <div class="content">
        <p>Hello <strong>{{ student.fullName ?? student.email }}</strong>,</p>
        <p>Great news! <strong>{{ tutor.fullName ?? tutor.email }}</strong> has offered to help with your request:</p>
        <blockquote style="border-left: 3px solid #4361ee; padding-left: 12px; margin: 15px 0; color: #555;">
            <strong>{{ helpRequest.title }}</strong><br>
            {{ helpRequest.description|length > 150 ? helpRequest.description|slice(0, 150) ~ '...' : helpRequest.description }}
        </blockquote>
        {% if helpRequest.bounty > 0 %}
            <p>💰 Bounty: <strong>{{ helpRequest.bounty }} coins</strong></p>
        {% endif %}
        <p>Head to EduLink to start your tutoring session!</p>
    </div>
    <div class="footer">
        <p>EduLink — Peer-to-peer learning platform</p>
    </div>
</body>
</html>
