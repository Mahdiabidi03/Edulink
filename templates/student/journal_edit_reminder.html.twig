{% extends 'base.html.twig' %}

{% block title %}Edit Reminder - EduLink{% endblock %}

{% block content %}
<div style="max-width: 800px; margin: 2rem auto;">
    <a href="{{ path('student_journal') }}" style="color: var(--brand-main); text-decoration: none; margin-bottom: 1rem; display: inline-flex; align-items: center; gap: 6px;">
        <i class="ri-arrow-left-line"></i> Back to Journal
    </a>

    <div class="card" style="padding: 2rem;">
        <h1 style="margin-top: 0; margin-bottom: 1.5rem;">Edit Reminder</h1>

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            <div style="margin-bottom: 1.5rem;">
                {{ form_label(form.title, 'Reminder Title') }}
                {{ form_widget(form.title, {'attr': {'class': 'form-control'}}) }}
                {% if form.title.vars.errors %}
                    <div style="color: #ff6b6b; font-size: 0.9rem; margin-top: 5px;">
                        {% for error in form.title.vars.errors %}
                            {{ error.message }}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            <div style="margin-bottom: 1.5rem;">
                {{ form_label(form.description, 'Description') }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4}}) }}
                {% if form.description.vars.errors %}
                    <div style="color: #ff6b6b; font-size: 0.9rem; margin-top: 5px;">
                        {% for error in form.description.vars.errors %}
                            {{ error.message }}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            <div style="margin-bottom: 1.5rem;">
                {{ form_label(form.reminderTime, 'Reminder Date & Time') }}
                {{ form_widget(form.reminderTime, {'attr': {'class': 'form-control'}}) }}
                {% if form.reminderTime.vars.errors %}
                    <div style="color: #ff6b6b; font-size: 0.9rem; margin-top: 5px;">
                        {% for error in form.reminderTime.vars.errors %}
                            {{ error.message }} (Make sure the date is in the future)
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            <div style="display: flex; gap: 1rem;">
                <button type="submit" class="btn"><i class="ri-save-3-line"></i> Save Changes</button>
                <a href="{{ path('student_journal') }}" class="btn secondary" style="text-decoration: none; display: inline-flex; align-items: center; gap: 6px;">
                    <i class="ri-close-line"></i> Cancel
                </a>
                <form method="POST" action="{{ path('student_reminder_delete', {id: reminder.id}) }}" style="display: inline; margin-left: auto;">
                    <input type="hidden" name="_token" value="{{ csrf_token('student_reminder_delete' ~ reminder.id) }}" />
                    <button type="submit" class="btn secondary" style="background-color: rgb(255, 107, 107);" onclick="return confirm('Delete this reminder?');"><i class="ri-delete-line"></i> Delete Reminder</button>
                </form>
            </div>
        {{ form_end(form) }}
    </div>
</div>

<style>
    .form-control {
        width: 100%;
        padding: 10px;
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: white;
        font-family: 'Inter', sans-serif;
    }
    .form-control::placeholder {
        color: var(--text-muted);
    }
    textarea.form-control {
        resize: vertical;
        min-height: 100px;
    }

    form > div > label {
        display: block;
        margin-bottom: 8px;
        font-weight: 600;
        color: var(--text-main);
    }
</style>
{% endblock %}
