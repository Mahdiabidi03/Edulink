{% extends 'base.html.twig' %}

{% block title %}Events & Hackathons - EduLink{% endblock %}

{% block content %}
<div class="events-container">

    <!-- Header & Hero -->
    <div style="position: relative; border-radius: 20px; overflow: hidden; margin-bottom: 2.5rem; border: 1px solid var(--border);">
        <div style="background: linear-gradient(90deg, #2B1C4A 0%, #0F172A 100%); height: 250px; display: flex; align-items: center; padding: 3rem; position: relative;">
            <!-- Decorative shapes -->
            <div style="position: absolute; top: -50px; right: -50px; width: 200px; height: 200px; background: var(--brand-accent); filter: blur(100px); opacity: 0.4;"></div>
            <div style="position: absolute; bottom: -50px; left: 50px; width: 150px; height: 150px; background: var(--info); filter: blur(80px); opacity: 0.3;"></div>

            <div style="position: relative; z-index: 10;">
                <span style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); padding: 5px 12px; border-radius: 20px; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; color: var(--brand-light); margin-bottom: 1rem; display: inline-block;">Community Hub</span>
                <h1 style="font-size: 3rem; margin: 0.5rem 0; line-height: 1.1;">EduLink <span style="background: var(--brand-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Events</span></h1>
                <p style="color: var(--text-secondary); max-width: 500px; font-size: 1.1rem;">Join hackathons, workshops, and meetups. Earn points to host your own events!</p>
            </div>
            
            <div style="position: absolute; right: 3rem; bottom: 3rem; text-align: right;">
                 <div style="font-size: 2.5rem; font-weight: 700; color: white;">450 <span style="font-size: 1rem; color: var(--text-muted); font-weight: 400;">PTS</span></div>
                 <div style="font-size: 0.85rem; color: var(--text-secondary);">Your Balance</div>
            </div>
        </div>
        <!-- Stats Bar -->
        <div style="background: rgba(15, 23, 42, 0.95); backdrop-filter: blur(10px); padding: 1rem 3rem; display: flex; gap: 3rem; border-top: 1px solid var(--border);">
             <div style="display: flex; align-items: center; gap: 10px;">
                 <i class="ri-calendar-check-line" style="font-size: 1.5rem; color: var(--success);"></i>
                 <div>
                     <div style="font-weight: 700;">12</div>
                     <div style="font-size: 0.8rem; color: var(--text-muted);">Upcoming Events</div>
                 </div>
             </div>
             <div style="display: flex; align-items: center; gap: 10px;">
                 <i class="ri-fire-line" style="font-size: 1.5rem; color: var(--warning);"></i>
                 <div>
                     <div style="font-weight: 700;">3</div>
                     <div style="font-size: 0.8rem; color: var(--text-muted);">Hot Hackathons</div>
                 </div>
             </div>
        </div>
    </div>

    <!-- Filter & Actions -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div style="display: flex; gap: 1rem;">
             <button class="btn secondary active" style="border-color: var(--brand-main); color: var(--brand-main);">All Events</button>
             <button class="btn secondary">Workshops</button>
             <button class="btn secondary">Hackathons</button>
             <button class="btn secondary">Social</button>
        </div>
        <button class="btn" style="background: linear-gradient(135deg, #F59E0B, #D97706); box-shadow: 0 0 15px rgba(245, 158, 11, 0.4);" onclick="createEventCheck(450)">
            <i class="ri-add-line"></i> Host Event (500 Pts)
        </button>
    </div>

    <!-- Events Grid -->
    <div class="grid" style="grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 2rem;">
        
        <!-- Featured Event Card (Large) -->
        <div class="card event-card featured" style="grid-column: span 2; padding: 0; overflow: hidden; position: relative; border: 1px solid var(--brand-main);">
             <div style="position: absolute; top: 1rem; left: 1rem; z-index: 10; background: var(--brand-main); color: white; padding: 5px 10px; border-radius: 6px; font-weight: 600; font-size: 0.8rem;">FEATURED</div>
             <div style="height: 220px; background: url('https://images.unsplash.com/photo-1504384308090-c54be3855833?q=80&w=1000&auto=format&fit=crop') center/cover;"></div>
             <div style="padding: 2rem;">
                 <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 1rem;">
                     <div>
                        <h2 style="margin: 0 0 0.5rem;">Global AI Hackathon 2026</h2>
                        <div style="display: flex; gap: 1rem; color: var(--text-secondary); font-size: 0.9rem;">
                            <span><i class="ri-calendar-line"></i> Feb 15 - 17</span>
                            <span><i class="ri-map-pin-line"></i> Online / Discord</span>
                        </div>
                     </div>
                     <div style="text-align: center; background: rgba(255,255,255,0.05); padding: 8px 12px; border-radius: 8px;">
                         <div style="font-weight: 700; font-size: 1.2rem; color: var(--brand-light);">1500</div>
                         <div style="font-size: 0.7rem; color: var(--text-muted);">XP PRIZE</div>
                     </div>
                 </div>
                 <p style="color: var(--text-secondary); line-height: 1.6; margin-bottom: 1.5rem;">
                     Join 500+ students in building the next generation of AI tools. Sponsors include Google, Microsoft and EduLink. Teams of 4 max.
                 </p>
                 <div style="display: flex; justify-content: space-between; align-items: center;">
                     <div style="display: flex; align-items: center; gap: 8px;">
                         <img src="https://ui-avatars.com/api/?name=Admin+Team&background=000&color=fff" style="width: 30px; height: 30px; border-radius: 50%;">
                         <span style="font-size: 0.9rem; color: var(--text-main);">Hosted by <strong>EduLink Team</strong></span>
                     </div>
                     <button class="btn">Register Now</button>
                 </div>
             </div>
        </div>

        <!-- Normal Event Card 1 -->
        <div class="card event-card" style="padding: 0; overflow: hidden; display: flex; flex-direction: column;">
            <div style="height: 150px; background: url('https://images.unsplash.com/photo-1542744173-8e7e53415bb0?q=80&w=1000&auto=format&fit=crop') center/cover; position: relative;">
                <div style="position: absolute; bottom: 10px; left: 10px; background: rgba(0,0,0,0.7); backdrop-filter: blur(5px); color: white; padding: 4px 10px; border-radius: 20px; font-size: 0.75rem;">
                    <i class="ri-user-voice-line"></i> Workshop
                </div>
            </div>
            <div style="padding: 1.5rem; flex: 1; display: flex; flex-direction: column;">
                <h3 style="margin: 0 0 0.5rem; font-size: 1.2rem;">React.js Masterclass</h3>
                <div style="margin-bottom: 1rem; color: var(--text-secondary); font-size: 0.85rem; display: flex; flex-direction: column; gap: 4px;">
                     <span><i class="ri-time-line"></i> Tomorrow, 5:00 PM</span>
                     <span><i class="ri-user-line"></i> 24/50 Spots filled</span>
                </div>
                <div style="margin-top: auto; display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--border); padding-top: 1rem;">
                    <div style="display: flex; align-items: center; gap: 8px;">
                         <img src="https://ui-avatars.com/api/?name=Sarah+J&background=random" style="width: 24px; height: 24px; border-radius: 50%;">
                         <span style="font-size: 0.8rem; color: var(--text-muted);">Sarah J.</span>
                    </div>
                    <button class="btn secondary" style="font-size: 0.8rem; padding: 6px 12px;">Join</button>
                </div>
            </div>
        </div>

        <!-- Normal Event Card 2 -->
        <div class="card event-card" style="padding: 0; overflow: hidden; display: flex; flex-direction: column;">
            <div style="height: 150px; background: url('https://images.unsplash.com/photo-1522071820081-009f0129c71c?q=80&w=1000&auto=format&fit=crop') center/cover; position: relative;">
                 <div style="position: absolute; bottom: 10px; left: 10px; background: rgba(0,0,0,0.7); backdrop-filter: blur(5px); color: white; padding: 4px 10px; border-radius: 20px; font-size: 0.75rem;">
                    <i class="ri-cup-line"></i> Social
                </div>
            </div>
            <div style="padding: 1.5rem; flex: 1; display: flex; flex-direction: column;">
                <h3 style="margin: 0 0 0.5rem; font-size: 1.2rem;">Virtual Coffee Chat</h3>
                <div style="margin-bottom: 1rem; color: var(--text-secondary); font-size: 0.85rem; display: flex; flex-direction: column; gap: 4px;">
                     <span><i class="ri-time-line"></i> Friday, 10:00 AM</span>
                     <span><i class="ri-user-line"></i> Open to all</span>
                </div>
                <div style="margin-top: auto; display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--border); padding-top: 1rem;">
                    <div style="display: flex; align-items: center; gap: 8px;">
                         <img src="https://ui-avatars.com/api/?name=Mike+Ross&background=random" style="width: 24px; height: 24px; border-radius: 50%;">
                         <span style="font-size: 0.8rem; color: var(--text-muted);">Mike R.</span>
                    </div>
                    <button class="btn secondary" style="font-size: 0.8rem; padding: 6px 12px;">Join</button>
                </div>
            </div>
        </div>

    </div>

</div>

<!-- Host Event Modal (Simulated) -->
<div id="hostModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); backdrop-filter: blur(5px); z-index: 100; align-items: center; justify-content: center;">
    <div class="card" style="width: 500px; max-width: 90%; position: relative; animation: slideUp 0.3s ease;">
        <button onclick="document.getElementById('hostModal').style.display = 'none'" style="position: absolute; top: 1rem; right: 1rem; background: none; border: none; color: white; font-size: 1.5rem; cursor: pointer;">&times;</button>
        
        <h2 style="margin-top: 0;">Host an Event</h2>
        <div style="background: rgba(245, 158, 11, 0.1); color: var(--warning); padding: 10px; border-radius: 8px; margin-bottom: 1.5rem; font-size: 0.9rem; display: flex; gap: 10px; align-items: center;">
            <i class="ri-lock-line"></i> Cost: 500 Points. You have 450 Points.
        </div>

        <p style="color: var(--text-secondary); margin-bottom: 1.5rem;">
            You need <strong>50 more points</strong> to unlock this feature. Earn points by completing courses or helping others!
        </p>
        
        <div style="display: flex; justify-content: flex-end; gap: 1rem;">
            <button class="btn secondary" onclick="document.getElementById('hostModal').style.display = 'none'">Close</button>
            <button class="btn" disabled style="opacity: 0.5; cursor: not-allowed;">Pay & Create</button>
        </div>
    </div>
</div>

<style>
    .event-card {
        transition: transform 0.3s, box-shadow 0.3s;
    }
    .event-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }
    @keyframes slideUp {
        from { transform: translateY(20px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
    @media (min-width: 1024px) {
        .featured {
            grid-column: span 2;
        }
    }
</style>

<script>
    function createEventCheck(currentPoints) {
        const required = 500;
        const modal = document.getElementById('hostModal');
        modal.style.display = 'flex';
        
        // In a real app we'd dynamically update the modal text based on points
    }
</script>
{% endblock %}
