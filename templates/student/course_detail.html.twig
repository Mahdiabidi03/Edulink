{% extends 'base.html.twig' %}

{% block content %}
<div style="max-width: 1200px; margin: 0 auto; padding: 2rem;">
    
    <!-- Breadcrumbs -->
    <div style="margin-bottom: 2rem;">
        <a href="{{ path('app_student_courses', {'category': cours.matiere.id}) }}" style="color: var(--text-secondary); text-decoration: none; display: flex; align-items: center; gap: 5px;">
            <i data-lucide="arrow-left" style="width: 16px; height: 16px;"></i> Back to {{ cours.matiere.name }}
        </a>
    </div>

    <!-- Course Header -->
    <div class="card" style="padding: 2.5rem; margin-bottom: 2rem; background: linear-gradient(135deg, rgba(59, 130, 246, 0.05), rgba(139, 92, 246, 0.05)); border: 1px solid var(--border);">
        <div style="flex: 1;">
            <div style="display: flex; justify-content: space-between; align-items: start;">
                <div>
                    <span class="badge" style="background: var(--info); color: white; padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; margin-bottom: 1rem; display: inline-block;">{{ cours.level }}</span>
                    <h1 style="margin: 0; font-size: 2.5rem; color: var(--text-main);">{{ cours.title }}</h1>
                </div>
                
                {% if not isEnrolled %}
                    <div style="text-align: right;">
                        <div style="font-size: 1.1rem; font-weight: 600; color: var(--success); margin-bottom: 0.5rem;">+{{ cours.xp }} XP</div>
                        <form action="{{ path('app_student_enroll', {'id': cours.id}) }}" method="post">
                            <button type="submit" class="btn" style="background: var(--brand-main); color: white; padding: 12px 24px; font-size: 1.1rem;">Start Learning</button>
                        </form>
                    </div>
                {% else %}
                    <div style="text-align: right;">
                        <span class="badge" style="background: var(--success); color: white; padding: 8px 16px; border-radius: 20px; font-weight: 600;">Enrolled</span>
                        <div style="margin-top: 10px; color: var(--text-secondary); font-size: 0.9rem;">Progress: {{ enrollment.progress }}%</div>
                    </div>
                {% endif %}
            </div>
            
            <p style="color: var(--text-secondary); line-height: 1.6; margin-top: 1.5rem; font-size: 1.1rem;">{{ cours.description }}</p>
        </div>
    </div>

    <!-- Gemini AI Insight Button/Card -->
    <div id="aiSummaryCard" class="card" style="padding: 1.5rem; margin-bottom: 2rem; background: var(--bg-card); border: 2px solid var(--brand-accent); box-shadow: var(--shadow-neon); display: none;">
        <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 10px;">
            <div style="width: 40px; height: 40px; background: rgba(139, 92, 246, 0.2); border-radius: 50%; display: grid; place-items: center;">
                <i data-lucide="bot" style="color: var(--brand-accent); width: 24px; height: 24px;"></i>
            </div>
            <h3 style="margin: 0; font-size: 1.2rem; color: var(--brand-accent);">Gemini AI Insight</h3>
        </div>
        <p id="aiSummaryText" style="margin: 0; line-height: 1.6; font-style: italic; color: var(--text-main);">Thinking...</p>
    </div>

    <script>
    document.addEventListener('DOMContentLoaded', async () => {
        const title = "{{ cours.title|e('js') }}";
        const description = "{{ cours.description|e('js') }}";
        const aiCard = document.getElementById('aiSummaryCard');
        const aiText = document.getElementById('aiSummaryText');

        if (description || title) {
            aiCard.style.display = 'block';
            try {
                const response = await fetch('{{ path('api_ai_summarize_course') }}', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title, description })
                });
                const data = await response.json();
                if (data.success) {
                    aiText.innerText = data.result;
                } else {
                    aiCard.style.display = 'none';
                }
            } catch (e) {
                console.error('AI Summary failed', e);
                aiCard.style.display = 'none';
            }
        }
    });
    </script>

    <!-- Dynamic Video Player (Shows current active video) -->
    {% if isEnrolled %}
        {% set activeVideo = null %}
        {% set foundActive = false %}
        {% for resource in cours.resources|filter(r => r.type|upper == 'VIDEO' and r.status == 'APPROVED')|sort((a,b) => a.id <=> b.id) %}
            {% if not foundActive and resource.id not in enrollment.completedResources %}
                {% set activeVideo = resource %}
                {% set foundActive = true %}
            {% endif %}
        {% endfor %}

        {# Fallback to first video if all are completed #}
        {% if not activeVideo %}
            {% for resource in cours.resources|filter(r => r.type|upper == 'VIDEO' and r.status == 'APPROVED')|sort((a,b) => a.id <=> b.id) %}
                {% if not activeVideo %}
                    {% set activeVideo = resource %}
                {% endif %}
            {% endfor %}
        {% endif %}

        {% if activeVideo %}
            <div class="card" style="padding: 2rem; margin-bottom: 2rem; border: 2px solid var(--brand-main); box-shadow: var(--shadow-neon);">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                    <h3 style="margin: 0;">Currently Watching: {{ activeVideo.title }}</h3>
                    {% if activeVideo.id in enrollment.completedResources %}
                        <span class="badge" style="background: var(--success); color: white;"><i data-lucide="check" style="width: 14px; height: 14px;"></i> Completed</span>
                    {% else %}
                        <span class="badge" style="background: var(--info); color: white;">Next Lesson</span>
                    {% endif %}
                </div>
                
                <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 12px; background: #000; border: 1px solid var(--border);">
                    {% if 'youtube.com' in activeVideo.url or 'youtu.be' in activeVideo.url %}
                        {% set videoId = activeVideo.url|split('v=')|last|split('&')|first %}
                        {% if 'youtu.be' in activeVideo.url %}
                            {% set videoId = activeVideo.url|split('/')|last %}
                        {% endif %}
                        <iframe 
                            style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
                            src="https://www.youtube.com/embed/{{ videoId }}" 
                            frameborder="0" 
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                            allowfullscreen>
                        </iframe>
                    {% else %}
                        <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: white; flex-direction: column;">
                            <i data-lucide="video" style="font-size: 3rem; margin-bottom: 1rem;"></i>
                            <a href="{{ activeVideo.url }}" target="_blank" class="btn" style="background: var(--info); color: white;">Watch Video Externally</a>
                        </div>
                    {% endif %}
                </div>
                
                {% if activeVideo.id not in enrollment.completedResources %}
                    <div style="margin-top: 1.5rem; display: flex; justify-content: flex-end;">
                        <form action="{{ path('app_student_complete_resource', {'id': activeVideo.id}) }}" method="post">
                            <button type="submit" class="btn success" style="padding: 12px 24px;">
                                <i data-lucide="check-circle" style="width: 20px; height: 20px; margin-right: 8px;"></i> Mark Lesson as Finished
                            </button>
                        </form>
                    </div>
                {% endif %}
            </div>
        {% endif %}
    {% endif %}

    <!-- Resources Section -->
    <div class="card" style="padding: 2rem; border: 2px solid var(--border);">
        <h2 style="margin-top: 0; border-bottom: 2px solid var(--border); padding-bottom: 1rem; margin-bottom: 1.5rem;">Resources</h2>
        
        {% if cours.resources is not empty %}
            <div style="display: flex; flex-direction: column; gap: 1rem;">
                {% set previousCompleted = true %}
                {% set allResourcesFinished = true %}
                
                {% for resource in cours.resources|filter(r => r.status == 'APPROVED')|sort((a, b) => a.id <=> b.id) %}
                    {% set isCompleted = isEnrolled and resource.id in enrollment.completedResources %}
                    {% set isLocked = isEnrolled and not previousCompleted %}
                    
                    {% if not isCompleted %}
                        {% set allResourcesFinished = false %}
                    {% endif %}

                    <div class="card" style="padding: 1.25rem; display: flex; align-items: center; justify-content: space-between; background: {{ isLocked ? 'rgba(0,0,0,0.05)' : 'rgba(255, 255, 255, 0.05)' }}; border: 1px solid {{ isLocked ? 'var(--border)' : (isCompleted ? 'var(--success)' : 'var(--border-light)') }}; opacity: {{ isLocked ? '0.6' : '1' }};">
                        <div style="display: flex; align-items: center; gap: 1.5rem;">
                            <div style="width: 48px; height: 48px; background: {{ isCompleted ? 'rgba(16, 185, 129, 0.1)' : 'rgba(59, 130, 246, 0.1)' }}; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                {% if isLocked %}
                                    <i data-lucide="lock" style="width: 24px; height: 24px; color: var(--text-muted);"></i>
                                {% elseif resource.type|upper == 'VIDEO' %}
                                    <i data-lucide="video" style="width: 24px; height: 24px; color: var(--info);"></i>
                                {% elseif resource.type|upper == 'FILE' or resource.type|upper == 'PDF' or resource.type|upper == 'WORD' %}
                                    <i data-lucide="file-text" style="width: 24px; height: 24px; color: var(--brand-accent);"></i>
                                {% else %}
                                    <i data-lucide="link" style="width: 24px; height: 24px; color: var(--brand-main);"></i>
                                {% endif %}
                            </div>
                            <div>
                                <h4 style="margin: 0; font-size: 1.1rem; color: {{ isLocked ? 'var(--text-muted)' : 'var(--text-main)' }};">
                                    {{ resource.title ?? 'Untitled Resource' }}
                                    {% if isCompleted %}
                                        <i data-lucide="check-circle" style="width: 16px; height: 16px; color: var(--success); margin-left: 5px;"></i>
                                    {% endif %}
                                </h4>
                                <span style="font-size: 0.85rem; color: var(--text-secondary);">Type: {{ resource.type }}</span>
                            </div>
                        </div>
                        
                        <div style="display: flex; gap: 1rem; align-items: center;">
                            {% if isLocked %}
                                <span style="color: var(--text-muted); font-size: 0.85rem;"><i data-lucide="lock" style="width: 14px; height: 14px;"></i> Finish previous resource</span>
                            {% else %}
                                {% if isEnrolled and not isCompleted %}
                                    <form action="{{ path('app_student_complete_resource', {'id': resource.id}) }}" method="post" style="margin: 0;">
                                        <button type="submit" class="btn success" style="padding: 8px 16px; font-size: 0.85rem;">Mark as Read</button>
                                    </form>
                                {% endif %}
                                <a href="{{ resource.url }}" target="_blank" class="btn secondary" style="text-decoration: none;">Open</a>
                            {% endif %}
                        </div>
                    </div>
                    
                    {% set previousCompleted = isCompleted %}
                {% endfor %}
            </div>

            {% if isEnrolled %}
                <div style="margin-top: 2rem; padding-top: 2rem; border-top: 2px solid var(--border); text-align: right;">
                    {% if enrollment.completedAt %}
                        <div style="display: flex; align-items: center; justify-content: flex-end; gap: 1rem;">
                            <div style="color: var(--success); font-weight: 700; font-size: 1.1rem; display: flex; align-items: center; gap: 8px;">
                                <i data-lucide="check-circle" style="width: 28px; height: 28px;"></i> Course Finished
                            </div>
                            <a href="{{ path('app_student_courses') }}" class="btn secondary" style="display: flex; align-items: center; gap: 8px; text-decoration: none;">
                                <i data-lucide="library" style="width: 18px; height: 18px;"></i> Back to Library
                            </a>
                        </div>
                    {% elseif allResourcesFinished %}
                        <div style="margin-bottom: 1.5rem; color: var(--success); font-weight: 600; font-size: 1.05rem;">
                            🎉 Fantastic work! All resources are finished. Claim your XP now!
                        </div>
                        <form action="{{ path('app_student_complete_course', {'id': cours.id}) }}" method="post">
                            <button type="submit" class="btn" style="background: var(--brand-main); color: white; padding: 15px 40px; font-size: 1.1rem; border-radius: 12px; box-shadow: var(--shadow-neon);">
                                <i data-lucide="award" style="width: 22px; height: 22px; margin-right: 10px;"></i> Claim XP & Finish Course
                            </button>
                        </form>
                    {% else %}
                        <div style="color: var(--text-secondary); font-size: 1.05rem;">
                            Finish all resources above to unlock completion and earn <strong>{{ cours.xp }} XP</strong>
                        </div>
                    {% endif %}
                </div>
            {% endif %}

        {% else %}
            <p style="text-align: center; color: var(--text-muted); padding: 2rem;">No resources yet.</p>
        {% endif %}
    </div>

</div>
{% endblock %}
