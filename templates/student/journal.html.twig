{% extends 'base.html.twig' %}

{% block title %}My Journal - EduLink{% endblock %}

{% block content %}
<div class="journal-container" style="max-height: 90vh; display: flex; flex-direction: column;">

    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1 class="page-title" style="margin: 0; font-size: 2rem; background: var(--brand-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">My Journal</h1>
            <p style="color: var(--text-secondary); margin-top: 0.5rem;">Capture your thoughts, track tasks, and stay organized.</p>
        </div>
        <button class="btn" onclick="createNewNote()"><i class="ri-add-line"></i> New Note</button>
    </div>

    <div class="grid" style="grid-template-columns: 2fr 1fr; gap: 2rem; align-items: start;">
        
        <!-- LEFT COLUMN: NOTES AREA -->
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            
            <!-- Quick Input -->
            <div class="card" style="padding: 1.5rem;">
                <input type="text" id="noteTitle" placeholder="Note Title..." style="width: 100%; padding: 10px; margin-bottom: 10px; background: rgba(0,0,0,0.2); border: 1px solid var(--border); border-radius: 8px; color: white; font-size: 1.1rem; font-weight: 600;">
                <textarea id="noteContent" placeholder="Write something..." style="width: 100%; height: 120px; padding: 10px; background: rgba(0,0,0,0.2); border: 1px solid var(--border); border-radius: 8px; color: var(--text-main); font-family: 'Inter', sans-serif; resize: none; margin-bottom: 1rem;"></textarea>
                <div style="display: flex; justify-content: flex-end;">
                    <button class="btn secondary" style="padding: 8px 16px;"><i class="ri-save-3-line"></i> Save Note</button>
                </div>
            </div>

            <!-- Saved Notes List -->
            <h3 style="margin: 0; color: var(--text-muted); font-size: 1rem;">Recent Notes</h3>
            
            <div class="notes-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem;">
                <!-- Note 1 -->
                <div class="card" style="cursor: pointer; transition: transform 0.2s; border-left: 4px solid var(--brand-accent);">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                        <h4 style="margin: 0;">Project Ideas</h4>
                        <span style="font-size: 0.75rem; color: var(--text-muted);">2h ago</span>
                    </div>
                    <p style="font-size: 0.9rem; color: var(--text-secondary); line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                        1. AI Checkers game using Python.
                        2. Portfolio website with glassmorphism.
                        3. EduLink feature: Student Journal...
                    </p>
                </div>

                <!-- Note 2 -->
                <div class="card" style="cursor: pointer; transition: transform 0.2s; border-left: 4px solid var(--success);">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                        <h4 style="margin: 0;">Meeting Notes</h4>
                        <span style="font-size: 0.75rem; color: var(--text-muted);">Yesterday</span>
                    </div>
                    <p style="font-size: 0.9rem; color: var(--text-secondary); line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                        Discussed the database schema for the new module. Need to add a 'status' field to the 'tasks' table.
                        Next meeting scheduled for Friday.
                    </p>
                </div>
                 <!-- Note 3 -->
                <div class="card" style="cursor: pointer; transition: transform 0.2s; border-left: 4px solid var(--info);">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                        <h4 style="margin: 0;">SQL Commands</h4>
                        <span style="font-size: 0.75rem; color: var(--text-muted);">3 days ago</span>
                    </div>
                    <p style="font-size: 0.9rem; color: var(--text-secondary); line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                        SELECT * FROM users WHERE role = 'student';
                        UPDATE users SET points = points + 10 WHERE id = 1;
                    </p>
                </div>
            </div>

        </div>

        <!-- RIGHT COLUMN: TASKS & REMINDERS -->
        <div style="display: flex; flex-direction: column; gap: 2rem;">
            
            <!-- Tasks Widget -->
            <div class="card" style="padding: 0; overflow: hidden;">
                <div style="padding: 1.5rem; border-bottom: 1px solid var(--border); background: rgba(0,0,0,0.2);">
                    <h3 style="margin: 0; display: flex; align-items: center; gap: 8px;">
                        <i class="ri-checkbox-circle-line" style="color: var(--success);"></i> My Tasks
                    </h3>
                </div>
                
                <div style="padding: 1.5rem;">
                    <div style="display: flex; gap: 8px; margin-bottom: 1.5rem;">
                        <input type="text" placeholder="Add new task..." style="flex: 1; padding: 8px; background: var(--bg-main); border: 1px solid var(--border); border-radius: 6px; color: white;">
                        <button class="btn secondary" style="padding: 8px;"><i class="ri-add-line"></i></button>
                    </div>

                    <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
                        <li class="task-item">
                            <input type="checkbox" id="task1">
                            <label for="task1">Finish Database Assignment</label>
                        </li>
                        <li class="task-item checked">
                            <input type="checkbox" id="task2" checked>
                            <label for="task2">Read Chapter 4 of AI Book</label>
                        </li>
                         <li class="task-item">
                            <input type="checkbox" id="task3">
                            <label for="task3">Update Profile Picture</label>
                        </li>
                         <li class="task-item">
                            <input type="checkbox" id="task4">
                            <label for="task4">Email Professor Smith</label>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Reminders Widget -->
            <div class="card" style="padding: 0; overflow: hidden;">
                <div style="padding: 1.5rem; border-bottom: 1px solid var(--border); background: rgba(0,0,0,0.2);">
                    <h3 style="margin: 0; display: flex; align-items: center; gap: 8px;">
                        <i class="ri-alarm-warning-line" style="color: var(--warning);"></i> Upcoming Reminders
                    </h3>
                </div>
                <div style="padding: 1rem;">
                    
                    <div class="reminder-item">
                        <div class="reminder-date">
                            <span style="font-size: 1.2rem; font-weight: 700;">02</span>
                            <span style="font-size: 0.7rem; text-transform: uppercase;">Feb</span>
                        </div>
                        <div class="reminder-content">
                            <div style="font-weight: 600;">Project Submission</div>
                            <div style="font-size: 0.8rem; color: var(--text-muted);">11:59 PM • Web Development</div>
                        </div>
                    </div>

                    <div class="reminder-item">
                        <div class="reminder-date">
                            <span style="font-size: 1.2rem; font-weight: 700;">05</span>
                            <span style="font-size: 0.7rem; text-transform: uppercase;">Feb</span>
                        </div>
                        <div class="reminder-content">
                            <div style="font-weight: 600;">Quiz: SQL Basics</div>
                            <div style="font-size: 0.8rem; color: var(--text-muted);">10:00 AM • Databases</div>
                        </div>
                    </div>

                </div>
                 <button class="btn secondary" style="width: 100%; border-top: 1px solid var(--border); border-radius: 0; border-left: none; border-right: none; border-bottom: none;">+ Set Reminder</button>
            </div>

        </div>

    </div>

</div>

<style>
    /* Task Item Styling */
    .task-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px;
        border-radius: 6px;
        transition: background 0.2s;
    }
    .task-item:hover {
        background: rgba(255, 255, 255, 0.05);
    }
    .task-item input[type="checkbox"] {
        accent-color: var(--brand-main);
        width: 18px;
        height: 18px;
        cursor: pointer;
    }
    .task-item label {
        flex: 1;
        cursor: pointer;
        font-size: 0.95rem;
    }
    .task-item.checked label {
        text-decoration: line-through;
        color: var(--text-muted);
    }

    /* Reminder Item Styling */
    .reminder-item {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 12px;
        border-bottom: 1px solid var(--border-light);
    }
    .reminder-item:last-of-type {
        border-bottom: none;
    }
    .reminder-date {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        width: 50px;
        height: 50px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: var(--brand-light);
    }
</style>

<script>
    // Simple interactions for demo
    document.querySelectorAll('.task-item input').forEach(checkbox => {
        checkbox.addEventListener('change', function() {
            if(this.checked) {
                this.parentElement.classList.add('checked');
            } else {
                this.parentElement.classList.remove('checked');
            }
        });
    });

    function createNewNote() {
        document.getElementById('noteTitle').focus();
    }
</script>
{% endblock %}
