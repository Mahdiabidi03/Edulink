<!-- SENTIMENT ANALYSIS: Motivational Popup Modal           -->
<!-- ====================================================== -->
<div id="sentimentModal" style="
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(6px);
    z-index: 99999;
    align-items: center;
    justify-content: center;
">
    <div style="
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 2.5rem;
        max-width: 480px;
        width: 90%;
        box-shadow: 0 20px 60px rgba(0,0,0,0.4);
        animation: sentimentSlideIn 0.35s cubic-bezier(0.34,1.56,0.64,1);
        text-align: center;
        position: relative;
    ">
        <!-- Emoji top accent -->
        <div style="font-size: 3.5rem; margin-bottom: 1rem;">💪</div>

        <!-- Title -->
        <h3 style="margin: 0 0 0.75rem; color: var(--text-main); font-size: 1.35rem; font-weight: 700;">
            We noticed something...
        </h3>

        <!-- Subtitle -->
        <p style="color: var(--text-secondary); margin: 0 0 1.25rem; font-size: 0.95rem; line-height: 1.6;">
            Your note seems a bit heavy. Before you save it, here's a reminder from us:
        </p>

        <!-- Motivational Phrase Box -->
        <div id="sentimentPhrase" style="
            background: linear-gradient(135deg, rgba(99,102,241,0.12) 0%, rgba(168,85,247,0.08) 100%);
            border: 1px solid rgba(99,102,241,0.25);
            border-radius: 12px;
            padding: 1.25rem 1.5rem;
            margin-bottom: 2rem;
            color: var(--text-main);
            font-size: 1rem;
            font-style: italic;
            line-height: 1.65;
            font-weight: 500;
        ">
            <!-- filled by JS -->
        </div>

        <!-- Action buttons -->
        <div style="display: flex; gap: 1rem; justify-content: center;">
            <button id="sentimentReviseBtn" style="
                flex: 1;
                padding: 12px 20px;
                border-radius: 10px;
                border: 1px solid var(--border);
                background: var(--bg-main);
                color: var(--text-main);
                font-weight: 600;
                cursor: pointer;
                font-size: 0.9rem;
                transition: all 0.2s;
            " onmouseover="this.style.borderColor='var(--brand-main)'" onmouseout="this.style.borderColor='var(--border)'">
                ✏️ Let me revise
            </button>
            <button id="sentimentSaveBtn" style="
                flex: 1;
                padding: 12px 20px;
                border-radius: 10px;
                border: none;
                background: var(--brand-gradient);
                color: white;
                font-weight: 600;
                cursor: pointer;
                font-size: 0.9rem;
                box-shadow: 0 4px 14px rgba(99,102,241,0.3);
                transition: transform 0.15s;
            " onmouseover="this.style.transform='scale(1.03)'" onmouseout="this.style.transform='scale(1)'">
                💾 Save anyway
            </button>
        </div>
    </div>
</div>

<style>
@keyframes sentimentSlideIn {
    from { transform: translateY(-24px) scale(0.94); opacity: 0; }
    to   { transform: translateY(0)     scale(1);    opacity: 1; }
}
@keyframes sparkle {
    0%   { box-shadow: 0 4px 12px rgba(99,102,241,0.3); }
    50%  { box-shadow: 0 4px 24px rgba(99,102,241,0.7), 0 0 0 4px rgba(99,102,241,0.15); }
    100% { box-shadow: 0 4px 12px rgba(99,102,241,0.3); }
}
</style>

<script>
(function () {
    'use strict';

    let _pendingFormSubmit = false;
    let _noteForm = null;

    /** Strip HTML tags from editor output */
    function stripHtml(html) {
        const tmp = document.createElement('div');
        tmp.innerHTML = html;
        return (tmp.textContent || tmp.innerText || '').trim();
    }

    /** Get the note content from the Quill editor or textarea */
    function getNoteContent() {
        // Try reading from Quill editor directly
        const quillEditor = document.querySelector('#inline-quill-editor .ql-editor');
        if (quillEditor) {
            return quillEditor.innerHTML;
        }
        // Fallback: read the textarea directly
        const ta = document.querySelector('textarea[name$="[content]"], #inline-note-content-hidden, #note_content');
        return ta ? ta.value : '';
    }

    /** Show the motivational modal with a phrase */
    function showSentimentModal(phrase) {
        const modal = document.getElementById('sentimentModal');
        const phraseEl = document.getElementById('sentimentPhrase');
        if (!modal || !phraseEl) return;
        phraseEl.textContent = phrase || "You are stronger than you think. Keep going!";
        modal.style.display = 'flex';
    }

    /** Hide the modal */
    function hideSentimentModal() {
        const modal = document.getElementById('sentimentModal');
        if (modal) modal.style.display = 'none';
    }

    /** Sparkle animation on the Save button */
    function sparkleButton(btn) {
        btn.style.animation = 'sparkle 0.6s ease';
        setTimeout(() => { btn.style.animation = ''; }, 700);
    }

    document.addEventListener('DOMContentLoaded', function () {
        // Find the note form within noteFormContainer
        _noteForm = document.querySelector('#noteFormContainer form');
        if (!_noteForm) return;

        const submitBtn = _noteForm.querySelector('button[type="submit"]');

        _noteForm.addEventListener('submit', async function (e) {
            // If the user already confirmed via the modal, let the form through
            if (_pendingFormSubmit) {
                _pendingFormSubmit = false;
                return;
            }

            e.preventDefault();

            const rawContent = getNoteContent();
            const plainText = stripHtml(rawContent);

            if (!plainText) {
                // Empty note — just submit
                _pendingFormSubmit = true;
                _noteForm.submit();
                return;
            }

            // Show a subtle loading state
            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.style.opacity = '0.7';
            }

            try {
                const res = await fetch('/student/note/analyze-sentiment', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text: plainText })
                });

                if (!res.ok) throw new Error('Sentiment API unavailable');

                const data = await res.json();

                if (data.sentiment === 'negative' && data.motivational_phrase) {
                    // Show the motivational modal — do NOT submit yet
                    showSentimentModal(data.motivational_phrase);
                } else {
                    // Positive or neutral — submit with a sparkle ✨
                    if (submitBtn) sparkleButton(submitBtn);
                    _pendingFormSubmit = true;
                    _noteForm.submit();
                }
            } catch (err) {
                // Sentiment API is down — submit anyway, do not block user
                console.warn('[Sentiment] Could not reach sentiment API:', err.message);
                _pendingFormSubmit = true;
                _noteForm.submit();
            } finally {
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.style.opacity = '1';
                }
            }
        });

        // "Let me revise" — close modal without saving
        document.getElementById('sentimentReviseBtn')?.addEventListener('click', function () {
            hideSentimentModal();
        });

        // "Save anyway" — proceed with note submission
        document.getElementById('sentimentSaveBtn')?.addEventListener('click', function () {
            hideSentimentModal();
            _pendingFormSubmit = true;
            _noteForm.submit();
        });

        // Close modal on backdrop click
        document.getElementById('sentimentModal')?.addEventListener('click', function (e) {
            if (e.target === this) hideSentimentModal();
        });
    });
})();
</script>

{# Quill.js for inline note editor #}
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
<script>
(function() {
    const editorEl = document.getElementById('inline-quill-editor');
    if (!editorEl) { console.warn('Quill: #inline-quill-editor not found'); return; }

    // Find the hidden textarea — try multiple strategies
    let hiddenField = document.getElementById('inline-note-content-hidden');
    if (!hiddenField) {
        // Fallback: find by name attribute (Symfony generates name="note[content]")
        hiddenField = document.querySelector('textarea[name="note[content]"]');
    }
    if (!hiddenField) {
        // Fallback: find any textarea inside the form container
        hiddenField = document.querySelector('#noteFormContainer textarea');
    }
    if (!hiddenField) {
        console.error('Quill: could not find hidden textarea for content');
    }

    const quill = new Quill('#inline-quill-editor', {
        theme: 'snow',
        placeholder: 'Write your note here...',
        modules: {
            toolbar: [
                [{ header: [1, 2, 3, false] }],
                ['bold', 'italic', 'underline', 'strike'],
                [{ color: [] }, { background: [] }],
                [{ list: 'ordered' }, { list: 'bullet' }],
                ['blockquote', 'code-block'],
                ['link'],
                ['clean']
            ]
        }
    });

    // Load existing content if editing
    if (hiddenField && hiddenField.value && hiddenField.value.trim()) {
        quill.root.innerHTML = hiddenField.value;
    }

    // Sync on every text change
    quill.on('text-change', function() {
        if (!hiddenField) return;
        const text = quill.getText().trim();
        hiddenField.value = text.length > 0 ? quill.root.innerHTML : '';
    });

    // Also sync on form submit as safety net
    const form = editorEl.closest('form') || document.querySelector('#noteFormContainer form');
    if (form) {
        form.addEventListener('submit', function(e) {
            if (!hiddenField) return;
            const text = quill.getText().trim();
            hiddenField.value = text.length > 0 ? quill.root.innerHTML : '';

            if (!hiddenField.value) {
                e.preventDefault();
                alert('Note content cannot be empty.');
            }
        });
    }
})();
</script>

