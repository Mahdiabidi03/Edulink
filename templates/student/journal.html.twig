<script>
    // AI Prediction feature
    document.addEventListener('DOMContentLoaded', function() {
        const aiPredictBtn = document.getElementById('aiPredictBtn');
        if (aiPredictBtn) {
            aiPredictBtn.addEventListener('click', async function() {
                let textContent = '';
                const quillEditor = document.querySelector('#inline-quill-editor .ql-editor');
                if (quillEditor) {
                    textContent = quillEditor.innerText.trim();
                } else {
                    const hiddenContent = document.getElementById('inline-note-content-hidden');
                    if (hiddenContent) {
                        const div = document.createElement("div");
                        div.innerHTML = hiddenContent.value;
                        textContent = div.textContent || div.innerText || "";
                    }
                }
                
                if (!textContent || textContent.trim() === '') {
                    alert('Please write some content in the note before testing AI prediction.');
                    return;
                }

                const container = document.getElementById('aiPredictionResultsContainer');
                const loading = document.getElementById('aiPredictionLoading');
                const content = document.getElementById('aiPredictionContent');
                const errorHtml = document.getElementById('aiPredictionError');
                
                container.style.display = 'block';
                loading.style.display = 'block';
                content.style.display = 'none';
                errorHtml.style.display = 'none';

                try {
                    const response = await fetch('/student/note/ai-predict', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json'
                        },
                        body: JSON.stringify({text: textContent})
                    });

                    const data = await response.json();
                    console.log('[AI Predict] Full response:', data);

                    if (!response.ok || !data.success) {
                        throw new Error(data.error || 'Failed to fetch AI predictions.');
                    }

                    document.getElementById('aiPredictedCategory').textContent = data.data.category;
                    
                    // Auto-select the predicted category in the dropdown if it exists
                    const categorySelect = document.getElementById('note_category');
                    if (categorySelect) {
                        for (let i = 0; i < categorySelect.options.length; i++) {
                            const option = categorySelect.options[i];
                            // Match text case-insensitively since categories are user-defined
                            if (option.text.toLowerCase().trim() === data.data.category.toLowerCase().trim()) {
                                categorySelect.selectedIndex = i;
                                // Highlight the input briefly to show the user it was changed
                                categorySelect.style.transition = 'box-shadow 0.3s';
                                categorySelect.style.boxShadow = '0 0 0 2px #4285F4';
                                setTimeout(() => categorySelect.style.boxShadow = '', 1500);
                                break;
                            }
                        }
                    }
                    
                    const tagsContainer = document.getElementById('aiGeneratedTags');
                    tagsContainer.innerHTML = '';
                    let tagsStringList = [];
                    
                    if (data.data.tags && data.data.tags.length > 0) {
                        data.data.tags.forEach(tag => {
                            const tagSpan = document.createElement('span');
                            tagSpan.style.cssText = 'padding: 4px 10px; border-radius: 20px; background: var(--bg-main); border: 1px solid var(--border); color: var(--text-secondary); font-size: 0.8rem; margin-right: 4px; display: inline-block; white-space: nowrap;';
                            tagSpan.innerHTML = `<i class="ri-price-tag-3-line"></i> ${tag}`;
                            tagsContainer.appendChild(tagSpan);
                            tagsStringList.push(tag);
                        });
                    } else {
                        // Fallback if the sentence is too short and model predicts NO tags
                        const fallbackTag = data.data.category.toLowerCase() + '-related';
                        const tagSpan = document.createElement('span');
                        tagSpan.style.cssText = 'padding: 4px 10px; border-radius: 20px; background: var(--bg-main); border: 1px solid var(--border); color: var(--text-secondary); font-size: 0.8rem; margin-right: 4px; display: inline-block; white-space: nowrap;';
                        tagSpan.innerHTML = `<i class="ri-price-tag-3-line"></i> ${fallbackTag}`;
                        tagsContainer.appendChild(tagSpan);
                        tagsStringList.push(fallbackTag);
                    }
                    
                    // Populate hidden input so it gets POSTed on form submission
                    const aiTagsInput = document.getElementById('note_ai_tags_input');
                    if(aiTagsInput) {
                        aiTagsInput.value = tagsStringList.join(', ');
                    }
                    
                    // Populate hidden category input so backend can create it if the user doesn't have it
                    const aiCategoryInput = document.getElementById('note_ai_category_input');
                    if(aiCategoryInput) {
                        aiCategoryInput.value = data.data.category;
                    }

                    const matchContainer = document.getElementById('aiSemanticMatches');
                    matchContainer.innerHTML = '';
                    const entries = data.data.similar_entries || [];
                    if (entries.length === 0) {
                        matchContainer.innerHTML = '<li style="color: var(--text-muted); font-size:0.85rem; font-style: italic;">No close matches found in the training corpus.</li>';
                    } else {
                        entries.forEach(match => {
                            const li = document.createElement('li');
                            li.style.cssText = 'padding: 8px 12px; background: var(--bg-main); border-radius: 6px; font-size: 0.9rem; color: var(--text-main); border-left: 3px solid #34A853; margin-bottom: 6px; line-height: 1.4;';
                            li.innerHTML = `<div style="color: var(--text-muted); font-size: 0.75rem; margin-bottom: 4px;">Similarity Score: ${(parseFloat(match.score)*100).toFixed(1)}%</div> ${match.text}`;
                            matchContainer.appendChild(li);
                        });
                    }

                    loading.style.display = 'none';
                    content.style.display = 'block';
                    
                } catch (error) {
                    console.error('AI Predict Error:', error);
                    loading.style.display = 'none';
                    errorHtml.innerHTML = `<i class="ri-error-warning-line"></i> ${error.message}`;
                    errorHtml.style.display = 'block';
                }
            });
        }
    });
    // Task checkbox toggle (optimistic UI + label click handling)
    function handleTaskToggleCheckbox(checkbox) {
        return async function(e) {
            const taskId = checkbox.dataset.taskId;
            const parentLi = checkbox.parentElement;
            const badge = parentLi.querySelector('.task-badge');

            // optimistic UI
            const willBeChecked = checkbox.checked;
            if (willBeChecked) {
                parentLi.classList.add('checked');
                if (badge) { badge.style.display = 'inline'; badge.textContent = 'Fait'; }
            } else {
                parentLi.classList.remove('checked');
                if (badge) { badge.style.display = 'none'; badge.textContent = ''; }
            }

            try {
                const response = await fetch(`/student/personal-task/${taskId}/toggle`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                if (!response.ok) {
                    throw new Error('Network response was not ok');
                }

                const data = await response.json();
                if (!data.success) {
                    throw new Error('Server reported failure');
                }

                // keep optimistic UI (server confirms)
            } catch (error) {
                console.error('Error toggling task:', error);
                // revert UI
                checkbox.checked = !willBeChecked;
                if (!willBeChecked) {
                    parentLi.classList.add('checked');
                    if (badge) { badge.style.display = 'inline'; badge.textContent = 'Fait'; }
                } else {
                    parentLi.classList.remove('checked');
                    if (badge) { badge.style.display = 'none'; badge.textContent = ''; }
                }
            }
        };
    }

    document.querySelectorAll('.task-checkbox').forEach(checkbox => {
        checkbox.addEventListener('change', handleTaskToggleCheckbox(checkbox));
    });

    // Sort tasks by completion status (incomplete first)
    function sortTasks() {
        const list = document.getElementById('tasksList');
        if (!list) return;
        const items = Array.from(list.children);
        // toggle sort direction stored on button
        const btn = document.getElementById('sortTasksBtn');
        const asc = btn.dataset.asc !== 'false'; // default true

        items.sort((a, b) => {
            const aDone = a.classList.contains('checked');
            const bDone = b.classList.contains('checked');
            if (aDone === bDone) return 0;
            return aDone ? 1 : -1; // incomplete first
        });

        // Re-append in sorted order
        items.forEach(item => list.appendChild(item));

        // Toggle button state for next click
        btn.dataset.asc = (!asc).toString();
        btn.textContent = asc ? 'Trier (faits en bas)' : 'Trier (non faits d\'abord)';
    }

    // Close modal when clicking outside
    // Build a client-side schedule from reminders rendered by the server (pending only)
    var serverScheduledReminders = [
        {% set __first = true %}
        {% for r in reminders %}
            {% if r.status == 'pending' %}
                {% if not __first %},{% endif %}
                {
                    id: {{ r.id }},
                    title: "{{ r.title|e('js') }}",
                    description: "{{ r.description|default('')|e('js') }}",
                    datetime: "{{ r.reminderTime ? r.reminderTime|date('Y-m-d H:i:s') : '' }}"
                }
                {% set __first = false %}
            {% endif %}
        {% endfor %}
    ];

    document.addEventListener('DOMContentLoaded', function() {
        const modal = document.querySelector('.reminder-modal');
        if (modal) {
            modal.addEventListener('click', function(e) {
                if (e.target === this) {
                    document.getElementById('reminderModalToggle').checked = false;
                }
            });
        }

        // Schedule client-side timers for server reminders (fallback + immediate show if due)
        try {
            serverScheduledReminders.forEach(function(rem) {
                if (!rem.datetime) return;
                // parse as local time (browser) from server-provided Y-m-d H:i:s
                const parts = rem.datetime.split(/[- :]/).map(Number);
                // parts: [Y, M, D, H, i, s]
                const dt = new Date(parts[0], parts[1] - 1, parts[2], parts[3] || 0, parts[4] || 0, parts[5] || 0);
                const ms = dt.getTime() - Date.now();
                if (ms <= 0) {
                    // already due - show immediately
                    showReminderAlert(rem, 0);
                } else if (ms < 2147483647) { // safe timeout range
                    setTimeout(function() { showReminderAlert(rem, 0); }, ms);
                } else {
                    // fallback: schedule via periodic check
                    console.log('[Journal] Reminder delay too long for setTimeout, relying on periodic checks for', rem.id);
                }
            });
        } catch (e) {
            console.error('[Journal] scheduling error:', e);
        }

        // Check for due reminders immediately on page load
        console.log('[Journal] Page loaded, checking reminders...');
        checkDueReminders();
        
        // Check for due reminders every 5 seconds
        setInterval(checkDueReminders, 5000);
    });

    function checkDueReminders() {
        console.log('[Journal] Checking for due reminders...');
        fetch('/student/reminders-check', {
            method: 'GET',
            headers: {
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => {
            console.log('[Journal] Response status:', response.status);
            if (!response.ok) {
                throw new Error('Network response was not ok: ' + response.status);
            }
            return response.json();
        })
        .then(data => {
            console.log('[Journal] Reminders data received:', data);
            if (data.reminders && data.reminders.length > 0) {
                console.log('[Journal] Found ' + data.reminders.length + ' due reminders');
                data.reminders.forEach((reminder, index) => {
                    console.log('[Journal] Showing reminder:', reminder.title);
                    showReminderAlert(reminder, index);
                });
            } else {
                console.log('[Journal] No due reminders');
            }
        })
        .catch(error => console.error('[Journal] Error checking reminders:', error));
    }

    function showReminderAlert(reminder, index) {
        const alertId = `reminder-alert-${reminder.id}-${Date.now()}`;
        const alertHtml = `
            <div style="position: fixed; top: 20px; right: 20px; background: linear-gradient(135deg, #fca726 0%, #f78e1c 100%); color: white; padding: 1.5rem; border-radius: 12px; box-shadow: 0 10px 40px rgba(252, 167, 38, 0.3); max-width: 400px; z-index: 9999; animation: slideIn 0.3s ease-out;" id="${alertId}">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;">
                    <div>
                        <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 0.5rem;">
                            <i class="ri-time-line" style="font-size: 1.2rem;"></i>
                            <strong style="font-size: 1.1rem;">${reminder.title}</strong>
                        </div>
                        ${reminder.description ? `<p style="margin: 0.5rem 0 0 0; opacity: 0.95; font-size: 0.95rem;">${reminder.description}</p>` : ''}
                        <small style="display: block; margin-top: 0.5rem; opacity: 0.8;">Scheduled for ${reminder.time}</small>
                    </div>
                    <button onclick="document.getElementById('${alertId}').remove();" style="background: none; border: none; color: white; cursor: pointer; font-size: 1.5rem; padding: 0; opacity: 0.8;">
                        <i class="ri-close-line"></i>
                    </button>
                </div>
            </div>
        `;
        console.log('[Journal] Inserting alert:', alertId);
        document.body.insertAdjacentHTML('beforeend', alertHtml);
        
        // Auto-remove after 10 seconds
        setTimeout(() => {
            const element = document.getElementById(alertId);
            if (element) {
                console.log('[Journal] Auto-removing alert:', alertId);
                element.remove();
            }
        }, 10000);
    }

    // Toggle defer menu visibility
    function toggleDeferMenu(button) {
        const menu = button.nextElementSibling;
        if (!menu || !menu.classList.contains('defer-menu')) {
            console.error('Defer menu not found');
            return;
        }

        // Close other menus
        document.querySelectorAll('.defer-menu').forEach(m => {
            if (m !== menu && m.style.display !== 'none') {
                m.style.display = 'none';
            }
        });

        // Toggle current menu
        menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
    }

    // Close defer menus when clicking outside
    document.addEventListener('click', function(e) {
        if (!e.target.closest('.defer-menu') && !e.target.closest('[onclick*="toggleDeferMenu"]')) {
            document.querySelectorAll('.defer-menu').forEach(menu => {
                menu.style.display = 'none';
            });
        }
    });

    // Notes search: filter notes by title (client-side)
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('noteSearch');
        const clearBtn = document.getElementById('noteSearchClear');
        if (!searchInput) return;

        function filterNotes() {
            const q = (searchInput.value || '').trim().toLowerCase();
            document.querySelectorAll('.note-card').forEach(card => {
                const title = (card.dataset.title || '').toLowerCase();
                if (q === '' || title.indexOf(q) !== -1) {
                    card.style.display = '';
                } else {
                    card.style.display = 'none';
                }
            });
        }

        searchInput.addEventListener('input', filterNotes);
        clearBtn?.addEventListener('click', function() { searchInput.value = ''; filterNotes(); searchInput.focus(); });
    });


    // Close modal when clicking outside
    document.getElementById('editReminderModal')?.addEventListener('click', function(e) {
        if (e.target === this) {
            // Modal removed - edit now uses dedicated page
        }
    });

    // ===== AI STUDY ADVISOR =====
    function fetchStudyAdvice() {
        const contentEl = document.getElementById('adviceContent');
        const textEl = document.getElementById('adviceText');
        const timestampEl = document.getElementById('adviceTimestamp');
        const errorEl = document.getElementById('adviceError');
        const loadingEl = document.getElementById('adviceLoading');
        const emptyEl = document.getElementById('adviceEmpty');
        const btn = document.getElementById('getAdviceBtn');

        // Show loading state
        contentEl.style.display = 'none';
        errorEl.style.display = 'none';
        emptyEl.style.display = 'none';
        loadingEl.style.display = 'block';
        btn.disabled = true;
        btn.innerHTML = '<i class="ri-loader-4-line"></i> Generating...';

        fetch('/student/study-advice', {
            method: 'GET',
            headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(response => response.json())
        .then(data => {
            loadingEl.style.display = 'none';

            if (data.error) {
                errorEl.textContent = data.error;
                errorEl.style.display = 'block';
                emptyEl.style.display = 'block';
            } else if (data.advice) {
                textEl.innerHTML = formatAdvice(data.advice);
                timestampEl.textContent = 'Generated: ' + new Date(data.generated_at).toLocaleString();
                contentEl.style.display = 'block';
                btn.innerHTML = '<i class="ri-refresh-line"></i> Refresh Advice';
            }

            btn.disabled = false;
        })
        .catch(err => {
            loadingEl.style.display = 'none';
            errorEl.textContent = 'Could not connect to the AI advisor. Please try again later.';
            errorEl.style.display = 'block';
            emptyEl.style.display = 'block';
            btn.disabled = false;
            btn.innerHTML = '<i class="ri-sparkling-2-fill"></i> Get Weekly Advice';
        });
    }

    function formatAdvice(text) {
        // Convert markdown-style bold and line breaks to HTML
        return text
            .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
            .replace(/\n/g, '<br>')
            .replace(/(\d+\.)/g, '<br><strong>$1</strong>')
            .replace(/^<br>/, '');
    }
</script>


