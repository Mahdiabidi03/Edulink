{% extends 'base.html.twig' %}

{% block title %}My Journal - EduLink{% endblock %}

{% block content %}
{# Quill.js CDN CSS #}
<link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet">
<div class="journal-container" style="max-height: 90vh; display: flex; flex-direction: column;">

    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1 class="page-title" style="margin: 0; font-size: 2rem; background: var(--brand-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">My Journal</h1>
            <p style="color: var(--text-secondary); margin-top: 0.5rem;">Capture your thoughts, track tasks, and stay organized.</p>
        </div>
        <div style="display: flex; gap: 1rem;">
            <button class="btn" onclick="document.getElementById('noteFormContainer').scrollIntoView({behavior: 'smooth'}); document.querySelector('#note_title').focus();" style="background: var(--brand-gradient); color: white; border: none; box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);"><i class="ri-add-line"></i> New Note</button>
        </div>
    </div>

    <div class="grid" style="grid-template-columns: 2fr 1fr; gap: 2rem; align-items: start;">
        
        <!-- LEFT COLUMN: NOTES AREA -->
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            
            <!-- Quick Input -->
            <div class="card" style="padding: 1.5rem;" id="noteFormContainer">
                {{ form_start(noteForm, {'attr': {'style': 'display: contents;', 'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }}
                    <input type="hidden" name="note_ai_tags" id="note_ai_tags_input" value="" />
                    <input type="hidden" name="note_ai_category" id="note_ai_category_input" value="" />
                    {{ form_widget(noteForm.title, {'attr': {'class': 'form-input', 'style': 'margin-bottom: 10px; box-sizing: border-box;', 'placeholder': 'Note Title'}}) }}
                    
                    {% if noteForm.title.vars.errors %}
                        <div style="color: var(--error); font-size: 0.9rem; margin-bottom: 10px;">
                            {% for error in noteForm.title.vars.errors %}
                                {{ error.message }}
                            {% endfor %}
                        </div>
                    {% endif %}
                    
                    {# Quill Editor for inline note #}
                    <div id="inline-quill-editor" style="min-height: 120px; border-radius: 0 0 8px 8px;"></div>
                    <div style="display: none;">
                        {{ form_widget(noteForm.content, {'attr': {'id': 'inline-note-content-hidden'}}) }}
                    </div>
                    
                    {% if noteForm.content.vars.errors %}
                        <div style="color: var(--error); font-size: 0.9rem; margin-bottom: 10px;">
                            {% for error in noteForm.content.vars.errors %}
                                {{ error.message }}
                            {% endfor %}
                        </div>
                    {% endif %}

                    {{ form_widget(noteForm.attachment, {'attr': {'class': 'form-input file-input', 'style': 'margin-bottom: 1rem; box-sizing: border-box;'}}) }}
                    
                    {% if noteForm.attachment.vars.errors %}
                         <div style="color: var(--error); font-size: 0.9rem; margin-bottom: 10px;">
                             {% for error in noteForm.attachment.vars.errors %}
                                 {{ error.message }}
                             {% endfor %}
                         </div>
                     {% endif %}

                    {% if userCategories is empty %}
                        <div class="alert-bar alert-warning" style="margin-bottom: 1rem;">
                            <i class="ri-alert-line"></i>
                            You need to create categories before adding notes.
                            <a href="{{ path('category_new') }}" class="btn secondary" style="margin-left: 8px; text-decoration: none;">Create Category</a>
                        </div>
                    {% endif %}
                    <div style="display:flex; justify-content: space-between; align-items:center; margin-bottom: 6px;">
                        <label style="font-weight:600; color: var(--text-main);">Category</label>
                        <a href="{{ path('category_new') }}" class="btn secondary" style="text-decoration:none; font-size:0.85rem; padding:6px 10px;">+ Add Category</a>
                    </div>
                    {{ form_widget(noteForm.category, {'attr': {'class': 'form-input', 'style': 'margin-bottom: 1rem; box-sizing: border-box;'}}) }}
                    
                    <div style="display: flex; justify-content: flex-end; gap: 1rem;">
                        <button type="button" id="aiPredictBtn" class="btn secondary" style="padding: 10px 24px; border-radius: 8px; font-weight: 600; background: var(--bg-card); border: 1px solid var(--border); color: var(--text-main); transition: all 0.2s;"><i class="ri-sparkling-2-line" style="color: #4285F4;"></i> Test AI Prediction</button>
                        <button type="submit" class="btn" style="padding: 10px 24px; background: var(--brand-gradient); color: white; border: none; border-radius: 8px; font-weight: 600; box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3); transition: transform 0.2s;"><i class="ri-save-3-line"></i> Save Note</button>
                    </div>
                {{ form_end(noteForm) }}
            </div>

            <!-- AI Prediction Results Container -->
            <div id="aiPredictionResultsContainer" style="display: none; margin-bottom: 1.5rem;">
                <div class="card card-pro" style="padding: 1.5rem; background: var(--bg-card); border: 1px solid var(--brand-accent); border-radius: 12px;">
                    <h3 style="margin-top: 0; color: var(--text-main); display: flex; align-items: center; gap: 8px;">
                        <i class="ri-robot-2-fill" style="color: #4285F4;"></i> AI Models Analysis
                    </h3>
                    <div id="aiPredictionLoading" style="display: none; padding: 1rem; text-align: center;">
                        <div style="width: 24px; height: 24px; border: 3px solid var(--border); border-top-color: #4285F4; border-radius: 50%; animation: advisorSpin 0.8s linear infinite; margin: 0 auto 0.5rem;"></div>
                        <span style="font-size: 0.9rem; color: var(--text-secondary);">Analyzing with Python Models...</span>
                    </div>
                    <div id="aiPredictionContent" style="display: none;">
                        <div style="margin-bottom: 1rem;">
                            <strong style="color: var(--text-main);">📂 Predicted Category:</strong> 
                            <span id="aiPredictedCategory" style="margin-left: 8px; padding: 4px 10px; border-radius: 20px; background: rgba(66, 133, 244, 0.1); color: #4285F4; font-weight: 600; font-size: 0.85rem;"></span>
                        </div>
                        <div style="margin-bottom: 1rem;">
                            <strong style="color: var(--text-main);">🏷️ Generated Tags (Multi-Label):</strong> 
                            <div id="aiGeneratedTags" style="display: flex; gap: 6px; flex-wrap: wrap; margin-top: 6px;"></div>
                        </div>
                        <div>
                            <strong style="color: var(--text-main);">🔍 Top Semantic Matches (Word2Vec):</strong>
                            <ul id="aiSemanticMatches" style="list-style: none; padding: 0; margin: 8px 0 0 0; display: flex; flex-direction: column; gap: 8px;"></ul>
                        </div>
                    </div>
                    <div id="aiPredictionError" style="display: none; margin-top: 1rem; padding: 1rem; border-radius: 8px; background: rgba(234,67,53,0.1); border: 1px solid rgba(234,67,53,0.2); color: var(--error); font-size: 0.9rem;">
                    </div>
                </div>
            </div>

            <!-- Saved Notes List -->
            <h3 style="margin: 0; color: var(--text-muted); font-size: 1rem; display:flex; align-items:center; justify-content:space-between;">Recent Notes
                <small style="font-weight:600; color:var(--text-secondary); font-size:0.9rem;">({{ notes|length }})</small>
            </h3>

            <!-- Search and Filter -->
            <div style="margin: 0.75rem 0 1rem;">
                <form method="GET" action="{{ path('student_journal') }}" style="display:flex; flex-direction: column; gap: 12px;">
                    <div style="display:flex; gap:8px; align-items:center;">
                        <input name="q" type="search" value="{{ searchQuery }}" placeholder="Search notes by title or content..." aria-label="Search notes" style="flex:1; padding:10px 12px; border-radius:10px; border:1px solid var(--border); background: var(--bg-card); color:var(--text-main);" />
                        <button type="submit" class="btn" style="padding: 10px 16px; background: var(--brand-gradient); color: white;"><i class="ri-search-line"></i></button>
                        <a href="{{ path('student_journal') }}" class="btn secondary" style="padding:10px 16px;">Clear</a>
                    </div>
                    
                    {% if userCategories|length > 0 %}
                    <div style="display: flex; gap: 8px; flex-wrap: wrap; align-items: center;">
                        <span style="font-size: 0.85rem; color: var(--text-secondary); margin-right: 4px;">Filter by category:</span>
                        <a href="{{ path('student_journal', {q: searchQuery}) }}" class="tag-filter {{ not currentCategory ? 'active' : '' }}" style="padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; text-decoration: none; border: 1px solid var(--border); background: {{ not currentCategory ? 'var(--brand-main)' : 'var(--bg-card)' }}; color: {{ not currentCategory ? 'white' : 'var(--text-secondary)' }};">All</a>
                        {% for cat in userCategories %}
                            <a href="{{ path('student_journal', {category: cat.id, q: searchQuery}) }}" class="tag-filter {{ currentCategory == cat.id ? 'active' : '' }}" style="padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; text-decoration: none; border: 1px solid var(--border); background: {{ currentCategory == cat.id ? 'var(--brand-main)' : 'var(--bg-card)' }}; color: {{ currentCategory == cat.id ? 'white' : 'var(--text-secondary)' }};">
                                {{ cat.name }}
                            </a>
                        {% endfor %}
                    </div>
                    {% endif %}
                </form>
            </div>

            {% if notes|length == 0 %}
                <div class="card" style="padding: 2rem; text-align: center; color: var(--text-muted);">
                    <i class="ri-note-line" style="font-size: 2.5rem; display: block; margin-bottom: 1rem; opacity: 0.5;"></i>
                    No notes yet. Create your first note above!
                </div>
            {% else %}
                <div class="notes-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem;">
                    {% for note in notes %}
                        <div class="card card-pro note-card" data-title="{{ note.title|lower|e('html_attr') }}" style="cursor: pointer; transition: all 0.3s ease; border-top: 4px solid var(--brand-accent); position: relative; group: hover; box-shadow: var(--shadow-sm); overflow:hidden;">
                            
                            <!-- Colorful header background fade -->
                            <div style="position: absolute; top:0; left:0; width:100%; height: 60px; background: linear-gradient(180deg, var(--brand-accent)15 0%, transparent 100%); opacity: 0.5;"></div>

                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; position: relative;">
                                <h4 style="margin: 0; flex: 1; color: var(--text-main); font-weight: 700; font-size: 1.1rem;">{{ note.title }}</h4>
                                <div style="display: flex; gap: 4px;">
                                    <a href="{{ path('student_note_export_pdf', {id: note.id}) }}" class="icon-btn-hover" style="padding: 6px; color: var(--text-secondary); cursor: pointer; border-radius: 50%; transition: background 0.2s;" title="Export PDF" target="_blank">
                                        <i class="ri-file-pdf-line"></i>
                                    </a>
                                    <a href="{{ path('student_note_edit', {id: note.id}) }}" class="icon-btn-hover" style="padding: 6px; color: var(--text-secondary); cursor: pointer; border-radius: 50%; transition: background 0.2s;" title="Edit">
                                        <i class="ri-edit-line"></i>
                                    </a>
                                    <form method="POST" action="{{ path('student_note_delete', {id: note.id}) }}" style="display: inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('student_note_delete' ~ note.id) }}" />
                                        <button type="submit" class="icon-btn-hover" style="padding: 6px; color: var(--text-secondary); border: none; background: none; cursor: pointer; border-radius: 50%; transition: background 0.2s;" title="Delete" onclick="return confirm('Are you sure?')">
                                            <i class="ri-delete-bin-line"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>

                            <div style="position: relative;">
                                {% if note.category %}
                                    <span style="display: inline-block; padding: 2px 8px; border-radius: 4px; background: rgba(99, 102, 241, 0.1); color: var(--brand-main); font-size: 0.75rem; font-weight: 600; margin-bottom: 0.75rem;">
                                        <i class="ri-bookmark-2-line"></i> {{ note.category.name }}
                                    </span>
                                {% endif %}
                                {% if note.tag %}
                                    <span style="display: inline-block; padding: 2px 8px; border-radius: 4px; background: rgba(52, 168, 83, 0.1); color: #34A853; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.75rem; margin-left: 4px;">
                                        <i class="ri-price-tag-3-line"></i> {{ note.tag }}
                                    </span>
                                {% endif %}
                                <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.5; margin: 0; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                    {{ note.content|raw }}
                                </p>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

        </div>

        <!-- RIGHT COLUMN: AI ADVISOR, TASKS & REMINDERS -->
        <div style="display: flex; flex-direction: column; gap: 2rem;">

            <!-- AI Study Advisor Widget -->
            <div class="card card-pro" id="studyAdvisorCard" style="padding: 0; overflow: hidden; background: var(--bg-card); border: 1px solid var(--border); position: relative;">
                <!-- Gradient header -->
                <div style="padding: 1.5rem; border-bottom: 1px solid var(--border); background: linear-gradient(135deg, rgba(66,133,244,0.08) 0%, rgba(52,168,83,0.08) 50%, rgba(234,67,53,0.05) 100%);">
                    <h3 style="margin: 0; display: flex; align-items: center; gap: 8px; color: var(--text-main);">
                        <i class="ri-sparkling-2-fill" style="color: #4285F4; font-size: 1.2rem;"></i> AI Study Advisor
                        <span style="font-size: 0.65rem; padding: 2px 8px; border-radius: 20px; background: linear-gradient(135deg, #4285F4, #34A853); color: white; font-weight: 600; margin-left: auto;">Gemini</span>
                    </h3>
                    <p style="margin: 0.5rem 0 0; font-size: 0.8rem; color: var(--text-secondary);">Get personalized study tips based on your notes & tasks</p>
                </div>

                <div style="padding: 1.5rem;">
                    <!-- Advice content area -->
                    <div id="adviceContent" style="display: none; margin-bottom: 1rem;">
                        <div id="adviceText" style="font-size: 0.9rem; line-height: 1.7; color: var(--text-main); white-space: pre-line;"></div>
                        <div id="adviceTimestamp" style="margin-top: 0.75rem; font-size: 0.75rem; color: var(--text-muted); text-align: right;"></div>
                    </div>

                    <!-- Error area -->
                    <div id="adviceError" style="display: none; margin-bottom: 1rem; padding: 1rem; border-radius: 10px; background: rgba(234,67,53,0.08); border: 1px solid rgba(234,67,53,0.2); color: var(--error); font-size: 0.85rem;">
                    </div>

                    <!-- Loading spinner -->
                    <div id="adviceLoading" style="display: none; text-align: center; padding: 2rem;">
                        <div style="width: 36px; height: 36px; border: 3px solid var(--border); border-top-color: #4285F4; border-radius: 50%; animation: advisorSpin 0.8s linear infinite; margin: 0 auto 1rem;"></div>
                        <p style="color: var(--text-secondary); font-size: 0.85rem; margin: 0;">Analyzing your activity...</p>
                    </div>

                    <!-- Empty state / button -->
                    <div id="adviceEmpty" style="text-align: center;">
                        <div style="font-size: 2.5rem; margin-bottom: 0.75rem; opacity: 0.7;">🧠</div>
                        <p style="color: var(--text-secondary); font-size: 0.85rem; margin: 0 0 1rem;">Click below to get AI-powered study advice based on your recent notes and tasks.</p>
                    </div>

                    <button id="getAdviceBtn" onclick="fetchStudyAdvice()" style="width: 100%; padding: 12px; border-radius: 10px; border: none; background: linear-gradient(135deg, #4285F4, #34A853); color: white; font-weight: 600; font-size: 0.9rem; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 4px 14px rgba(66,133,244,0.3);">
                        <i class="ri-sparkling-2-fill"></i> Get Weekly Advice
                    </button>
                </div>
            </div>
            
            <!-- Tasks Widget -->
            <div class="card card-pro" style="padding: 0; overflow: hidden; background: var(--bg-card); border: 1px solid var(--border);">
                <div style="padding: 1.5rem; border-bottom: 1px solid var(--border); background: var(--bg-main); display:flex; align-items:center; justify-content:space-between; gap:12px;">
                    <h3 style="margin: 0; display: flex; align-items: center; gap: 8px; color: var(--text-main);">
                        <i class="ri-checkbox-circle-line" style="color: var(--success);"></i> My Tasks
                    </h3>
                    <div style="display:flex; gap:8px; align-items:center;">
                        <button id="sortTasksBtn" data-asc="true" class="icon-btn" style="width:auto; padding:6px 10px; font-size:0.9rem;" onclick="sortTasks();">Trier (non faits d'abord)</button>
                    </div>
                </div>
                
                <div style="padding: 1.5rem;">
                    <div style="display: flex; gap: 8px; margin-bottom: 1.5rem;">
                    {{ form_start(taskForm, {'attr': {'style': 'display: flex; gap: 8px; width: 100%;', 'novalidate': 'novalidate'}}) }}
                            {{ form_widget(taskForm.title, {'attr': {'class': 'form-input', 'style': 'flex:1;', 'placeholder': 'New Task...'}}) }}
                            <button type="submit" class="icon-btn" style="background: var(--brand-main); color: var(--text-inverted); width: 44px; height: 44px;"><i class="ri-add-line"></i></button>
                        {{ form_end(taskForm) }}
                    </div>

                    {% if taskForm.title.vars.errors %}
                        <div style="color: var(--error); font-size: 0.85rem; margin-bottom: 10px;">
                            {% for error in taskForm.title.vars.errors %}
                                {{ error.message }}
                            {% endfor %}
                        </div>
                    {% endif %}

                    {% if tasks|length == 0 %}
                        <div style="text-align: center; color: var(--text-muted); padding: 1rem; font-size: 0.9rem;">
                            No tasks yet. Add one above!
                        </div>
                    {% else %}
                        <ul id="tasksList" style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
                            {% for task in tasks %}
                                <li class="task-item {% if task.isCompleted %}checked{% endif %}" style="background: var(--bg-main); border: 1px solid var(--border);">
                                    <form method="POST" action="{{ path('student_personal_task_toggle', {id: task.id}) }}" style="display: inline; margin:0; padding:0; flex:1; display:flex; align-items:center;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('student_personal_task_toggle' ~ task.id) }}" />
                                        <input type="checkbox" id="task{{ task.id }}" name="toggle" class="task-checkbox" {% if task.isCompleted %}checked{% endif %} onchange="this.form.submit();" style="vertical-align: middle; margin-right:8px;">
                                        <label for="task{{ task.id }}" style="color: var(--text-main);">{{ task.title }}</label>
                                    </form>
                                    <span class="badge badge-success" style="margin-left:8px; {% if not task.isCompleted %}display:none;{% endif %}">{% if task.isCompleted %}Fait{% endif %}</span>
                                    <form method="POST" action="{{ path('student_personal_task_delete', {id: task.id}) }}" style="display: inline; margin-left:8px;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('student_personal_task_delete' ~ task.id) }}" />
                                        <button type="submit" onclick="return confirm('Delete this task?');" class="icon-btn" style="width:24px; height:24px; color: var(--text-muted);" title="Delete">
                                            <i class="ri-delete-line"></i>
                                        </button>
                                    </form>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>
            </div>

            <!-- Reminders Widget -->
            <div class="card card-pro" style="padding: 0; overflow: hidden; background: var(--bg-card); border: 1px solid var(--border);">
                <div style="padding: 1.5rem; border-bottom: 1px solid var(--border); background: var(--bg-main);">
                    <h3 style="margin: 0; display: flex; align-items: center; gap: 8px; color: var(--text-main);">
                        <i class="ri-alarm-warning-line" style="color: var(--warning);"></i> Upcoming Reminders
                    </h3>
                </div>
                
                {% if reminders|length == 0 %}
                    <div style="padding: 1.5rem; text-align: center; color: var(--text-muted); font-size: 0.9rem;">
                        <i class="ri-time-line" style="font-size: 2rem; display: block; margin-bottom: 0.5rem; opacity: 0.5;"></i>
                        No reminders yet. Create one below!
                    </div>
                {% else %}
                    <div style="padding: 1rem;">
                        {% for reminder in reminders %}
                            {% if reminder.status == 'pending' %}
                                <div class="reminder-item" style="position: relative; group: hover; display: flex; align-items: center; gap: 15px; padding: 12px; border-bottom: 1px solid var(--border-light); background: var(--bg-main); border: 1px solid var(--border); margin-bottom: 8px;">
                                    <div class="reminder-date" style="background: var(--brand-accent); box-shadow: var(--shadow-sm);">
                                        <span style="font-size: 1.2rem; font-weight: 700;">{{ reminder.reminderTime|date('d') }}</span>
                                        <span style="font-size: 0.7rem; text-transform: uppercase;">{{ reminder.reminderTime|date('M') }}</span>
                                    </div>
                                    <div class="reminder-content" style="flex: 1;">
                                        <div style="font-weight: 600; color: var(--text-main);" title="{{ reminder.title }}">{{ reminder.title }}</div>
                                        <div style="font-size: 0.8rem; color: var(--text-muted);">{{ reminder.reminderTime|date('H:i') }} • {% if reminder.description %}{{ reminder.description|slice(0, 20) }}...{% endif %}</div>
                                    </div>
                                    <div class="reminder-actions" style="display: flex; gap: 8px;">
                                        <a href="{{ path('student_reminder_edit', {id: reminder.id}) }}" class="icon-btn" style="width: 32px; height: 32px; color: var(--text-secondary);" title="Edit reminder">
                                            <i class="ri-edit-line"></i>
                                        </a>
                                        <div style="position: relative; display: inline-block;">
                                            <button type="button" onclick="toggleDeferMenu(this)" class="icon-btn" style="width: 32px; height: 32px; color: var(--text-secondary);" title="Snooze reminder">
                                                <i class="ri-alarm-snooze-line"></i>
                                            </button>
                                            <div class="defer-menu" style="display: none; position: absolute; top: 100%; right: 0; background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; padding: 8px 0; z-index: 1000; min-width: 160px; box-shadow: var(--shadow-lg); margin-top: 4px;">
                                                <form method="POST" action="{{ path('student_reminder_defer', {id: reminder.id}) }}" style="display: block;">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('student_reminder_defer' ~ reminder.id) }}" />
                                                    <button type="submit" name="defer_minutes" value="15" style="width: 100%; padding: 8px 12px; text-align: left; background: none; border: none; color: var(--text-main); cursor: pointer; font-size: 0.9rem;" onmouseover="this.style.background='var(--bg-main)'" onmouseout="this.style.background='none'">⏱️ 15 minutes</button>
                                                    <button type="submit" name="defer_minutes" value="30" style="width: 100%; padding: 8px 12px; text-align: left; background: none; border: none; color: var(--text-main); cursor: pointer; font-size: 0.9rem;" onmouseover="this.style.background='var(--bg-main)'" onmouseout="this.style.background='none'">⏱️ 30 minutes</button>
                                                    <button type="submit" name="defer_minutes" value="60" style="width: 100%; padding: 8px 12px; text-align: left; background: none; border: none; color: var(--text-main); cursor: pointer; font-size: 0.9rem;" onmouseover="this.style.background='var(--bg-main)'" onmouseout="this.style.background='none'">⏱️ 1 hour</button>
                                                    <button type="submit" name="defer_minutes" value="240" style="width: 100%; padding: 8px 12px; text-align: left; background: none; border: none; color: var(--text-main); cursor: pointer; font-size: 0.9rem;" onmouseover="this.style.background='var(--bg-main)'" onmouseout="this.style.background='none'">⏱️ 4 hours</button>
