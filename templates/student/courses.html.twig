{% extends 'base.html.twig' %}

{% block content %}
<div style="max-width: 1400px; margin: 0 auto; padding: 0 1rem;">
    
    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1 style="margin: 0; font-size: 2.5rem; background: var(--brand-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Marketplace</h1>
            <p style="color: var(--text-secondary); margin-top: 0.5rem;">Explore categories and courses or manage your content.</p>
        </div>
    </div>

   <!-- Tabs -->
    <div class="tabs" style="display: flex; gap: 2rem; margin-bottom: 2.5rem; border-bottom: 2px solid #ecf0f1;">
        <button class="tab-btn active" onclick="switchTab('browse-categories')" style="padding: 10px 0; background: none; border: none; border-bottom: 3px solid transparent; font-size: 1.1rem; color: #7f8c8d; cursor: pointer; font-weight: 600; transition: all 0.2s;">Browse Categories</button>
        <button class="tab-btn" onclick="switchTab('my-learning')" style="padding: 10px 0; background: none; border: none; border-bottom: 3px solid transparent; font-size: 1.1rem; color: #7f8c8d; cursor: pointer; font-weight: 600; transition: all 0.2s;">My Learning</button>
        <button class="tab-btn" onclick="switchTab('creator-studio')" style="padding: 10px 0; background: none; border: none; border-bottom: 3px solid transparent; font-size: 1.1rem; color: #7f8c8d; cursor: pointer; font-weight: 600; transition: all 0.2s;">Creator Studio</button>
    </div>

    <!-- TAB 1: BROWSE CATEGORIES -->
    <section id="browse-categories" class="tab-content">
        {% if selectedCategory %}
            {# Browsing courses in a category #}
            <div style="margin-bottom: 2rem;">
                <a href="{{ path('app_student_courses') }}" style="color: var(--text-secondary); text-decoration: none;">← Back to Categories</a>
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <h2 style="margin-top: 0.5rem;">{{ selectedCategory.name }}</h2>
                    <a href="{{ path('app_creator_course_new') }}?category={{ selectedCategory.id }}" class="btn info" style="text-decoration: none;">+ Create Course in Category</a>
                </div>
            </div>

            {# Search and Filter for Courses #}
            <div style="background: var(--bg-card); padding: 1.5rem; border-radius: 12px; margin-bottom: 2rem; border: 2px solid var(--border); box-shadow: var(--shadow-sm);">
                <form method="get" style="display: flex; gap: 2rem; flex-wrap: wrap; align-items: center;">
                    <input type="hidden" name="category" value="{{ selectedCategory.id }}">
                    
                    <div style="flex: 1 1 300px; position: relative;">
                        <i data-lucide="search" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-muted); width: 18px; height: 18px;"></i>
                        <input type="text" name="q" placeholder="Search courses..." value="{{ searchQuery ?? '' }}" style="width: 100%; padding: 12px 12px 12px 40px; border: 1px solid var(--border); border-radius: 10px; background: var(--bg-main); color: var(--text-main); font-size: 0.95rem; outline: none; transition: border-color 0.2s;">
                    </div>

                    <div style="display: flex; gap: 1rem; flex: 2; align-items: center; justify-content: flex-end;">
                        <div style="display: flex; align-items: center; gap: 0.5rem; background: var(--bg-main); padding: 5px 12px; border: 1px solid var(--border); border-radius: 10px;">
                            <i data-lucide="filter" style="width: 16px; height: 16px; color: var(--text-muted);"></i>
                            <select name="level" style="border: none; background: none; color: var(--text-main); font-weight: 500; cursor: pointer; height: 32px; outline: none;">
                                <option value="">All Levels</option>
                                <option value="Beginner" {{ currentLevel == 'Beginner' ? 'selected' : '' }}>Beginner</option>
                                <option value="Intermediate" {{ currentLevel == 'Intermediate' ? 'selected' : '' }}>Intermediate</option>
                                <option value="Advanced" {{ currentLevel == 'Advanced' ? 'selected' : '' }}>Advanced</option>
                            </select>
                        </div>
                        <div style="display: flex; align-items: center; gap: 0.5rem; background: var(--bg-main); padding: 5px 12px; border: 1px solid var(--border); border-radius: 10px;">
                            <i data-lucide="sort-asc" style="width: 16px; height: 16px; color: var(--text-muted);"></i>
                            <select name="sort" style="border: none; background: none; color: var(--text-main); font-weight: 500; cursor: pointer; height: 32px; outline: none;">
                                <option value="newest" {{ currentSort == 'newest' ? 'selected' : '' }}>Newest First</option>
                                <option value="reward_high" {{ currentSort == 'reward_high' ? 'selected' : '' }}>XP: High to Low</option>
                                <option value="reward_low" {{ currentSort == 'reward_low' ? 'selected' : '' }}>XP: Low to High</option>
                                <option value="alpha_asc" {{ currentSort == 'alpha_asc' ? 'selected' : '' }}>Alphabetical (A-Z)</option>
                            </select>
                        </div>
                        <button type="submit" class="btn brand" style="padding: 10px 24px;">Search</button>
                        {% if searchQuery or currentLevel or currentSort != 'newest' %}
                            <a href="{{ path('app_student_courses', {'category': selectedCategory.id}) }}" class="btn secondary" style="padding: 10px 15px; text-decoration: none;">Clear Filters</a>
                        {% endif %}
                    </div>
                </form>
            </div>

            {# Courses Grid #}
            {% if marketplaceCourses is not empty %}
                <div class="grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem;">
                    {% for cours in marketplaceCourses %}
                        <div class="card" style="display: flex; flex-direction: column;">
                            <h3 style="margin: 0 0 0.5rem 0;">{{ cours.title }}</h3>
                            <p style="color: var(--text-secondary); font-size: 0.9rem; flex: 1; margin-bottom: 1rem;">{{ cours.description|slice(0, 100) }}...</p>
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                                <span class="badge" style="background: var(--info); color: white; padding: 4px 10px; border-radius: 12px; font-size: 0.8rem;">{{ cours.level }}</span>
                                <span style="color: var(--success); font-weight: 600;">+{{ cours.xp }} XP</span>
                            </div>
                            <div style="margin-top: auto;">
                                <a href="{{ path('app_student_course_detail', {'id': cours.id}) }}" class="btn brand" style="width: 100%; text-align: center; text-decoration: none; padding: 10px; display: block;">View Course</a>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p style="text-align: center; color: var(--text-muted); padding: 3rem;">No courses in this category yet.</p>
            {% endif %}

        {% else %}
            {# Browsing categories #}
            <div style="margin-bottom: 2.5rem;">
                <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 1.5rem;">
                    <div>
                        <h2 style="margin: 0; font-size: 2rem;">All Categories</h2>
                        <p style="color: var(--text-secondary); margin-top: 0.5rem;">Choose a category to explore courses or use search to find a specific topic.</p>
                    </div>
                </div>

                <div style="background: var(--bg-card); padding: 1.5rem; border-radius: 12px; border: 2px solid var(--border); margin-bottom: 2rem; box-shadow: var(--shadow-sm);">
                    <form method="get" style="display: flex; gap: 2rem; flex-wrap: wrap; align-items: center;">
                        <div style="flex: 1 1 300px; position: relative;">
                            <i data-lucide="search" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-muted); width: 18px; height: 18px;"></i>
                            <input type="text" name="q" value="{{ searchQuery ?? '' }}" placeholder="Search categories..." style="width: 100%; padding: 12px 12px 12px 40px; background: var(--bg-main); border: 1px solid var(--border); border-radius: 10px; color: var(--text-main); font-size: 0.95rem; outline: none;">
                        </div>
                        
                        <div style="display: flex; gap: 1rem; flex: 2; align-items: center; justify-content: flex-end;">
                            <div style="display: flex; align-items: center; gap: 0.5rem; background: var(--bg-main); padding: 5px 12px; border: 1px solid var(--border); border-radius: 10px;">
                                <i data-lucide="sort-asc" style="width: 16px; height: 16px; color: var(--text-muted);"></i>
                                <select name="sort" style="border: none; background: none; color: var(--text-main); font-weight: 500; cursor: pointer; height: 32px; outline: none;">
                                    <option value="alpha_asc" {{ currentSort == 'alpha_asc' ? 'selected' : '' }}>Alphabetical (A-Z)</option>
                                    <option value="newest" {{ currentSort == 'newest' ? 'selected' : '' }}>Newest First</option>
                                </select>
                            </div>
                            <button type="submit" class="btn brand" style="padding: 10px 24px;">Search</button>
                            {% if searchQuery or currentSort != 'alpha_asc' %}
                                <a href="{{ path('app_student_courses') }}" class="btn secondary" style="padding: 10px 15px; text-decoration: none;">Clear Filters</a>
                            {% endif %}
                        </div>
                    </form>
                </div>
            </div>

            {% if searchQuery and marketplaceCourses is not empty %}
                <div style="margin-bottom: 2rem;">
                    <h3 style="margin-bottom: 1.5rem; color: var(--text-main);">Course Results for "{{ searchQuery }}"</h3>
                    <div class="grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem;">
                        {% for cours in marketplaceCourses %}
                            <div class="card" style="display: flex; flex-direction: column; border: 2px solid var(--border);">
                                <h3 style="margin: 0 0 0.5rem 0;">{{ cours.title }}</h3>
                                <p style="color: var(--text-secondary); font-size: 0.9rem; flex: 1; margin-bottom: 1rem;">{{ cours.description|slice(0, 100) }}...</p>
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                                    <span class="badge" style="background: var(--info); color: white; padding: 4px 10px; border-radius: 12px; font-size: 0.8rem;">{{ cours.level }}</span>
                                    <span style="color: var(--success); font-weight: 600;">{{ cours.xp }} XP</span>
                                </div>
                                <div style="margin-top: auto;">
                                    <a href="{{ path('app_student_course_detail', {'id': cours.id}) }}" class="btn brand" style="width: 100%; text-align: center; text-decoration: none; padding: 10px; display: block;">View Course</a>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                    <hr style="margin: 3rem 0; border: 0; border-top: 1px solid var(--border);">
                </div>
            {% endif %}

            <h3 style="margin-bottom: 1.5rem; color: var(--text-main);">{% if searchQuery %}Category Results{% else %}All Categories{% endif %}</h3>
            <div class="grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
                {% for matiere in matieres %}
                    <a href="{{ path('app_student_courses', {'category': matiere.id}) }}" class="card marketplace-card" style="text-decoration: none; color: inherit; padding: 0; overflow: hidden; transition: transform 0.2s; cursor: pointer; border: 2px solid var(--border);" onmouseover="this.style.transform='scale(1.02)'" onmouseout="this.style.transform='scale(1)'">
                        <div class="{% if not matiere.imageUrl %}unsplash-cover{% endif %}" {% if not matiere.imageUrl %}data-query="{{ matiere.name }}"{% endif %} style="height: 160px; background: {{ matiere.imageUrl ? 'url(' ~ matiere.imageUrl ~ ')' : 'linear-gradient(135deg, #6c5ce7, #a29bfe)' }}; background-size: cover; background-position: center;">
                            {% if not matiere.imageUrl %}
                                <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: white; background: rgba(0,0,0,0.2);">
                                    <i data-lucide="book-open" style="width: 48px; height: 48px; opacity: 0.8;"></i>
                                </div>
                            {% endif %}
                        </div>
                        <div style="padding: 1.5rem;">
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <h3 style="margin: 0; font-size: 1.25rem;">{{ matiere.name }}</h3>
                                <span class="badge" style="background: rgba(59, 130, 246, 0.1); color: var(--info); padding: 4px 10px; border-radius: 12px; font-size: 0.8rem; font-weight: 600;">
                                    {{ matiere.cours|length }}
                                </span>
                            </div>
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% endif %}
    </section>

    <!-- TAB 2: MY LEARNING -->
    <section id="my-learning" class="tab-content" style="display: none;">
        <h2 style="margin-bottom: 1.5rem;">My Enrolled Courses</h2>
        <div class="grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem;">
            {% for enrollment in myEnrollments %}
                <div class="card learning-card" style="display: flex; flex-direction: column; overflow: hidden; padding: 0; border: 2px solid var(--border);">
                    <div style="height: 140px; background: {{ enrollment.cours.matiere.imageUrl ? 'url(' ~ enrollment.cours.matiere.imageUrl ~ ')' : 'linear-gradient(135deg, #6c5ce7, #a29bfe)' }}; background-size: cover; background-position: center; border-bottom: 2px solid var(--border);">
                        {% if not enrollment.cours.matiere.imageUrl %}
                            <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: white; background: rgba(0,0,0,0.1);">
                                <i data-lucide="book-open" style="width: 48px; height: 48px; opacity: 0.8;"></i>
                            </div>
                        {% endif %}
                    </div>
                    <div style="padding: 1.5rem; flex: 1; display: flex; flex-direction: column;">
                        <h3 style="margin: 0 0 0.5rem 0;">{{ enrollment.cours.title }}</h3>
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                            <span style="color: var(--text-secondary); font-size: 0.9rem;">{{ enrollment.cours.matiere.name }}</span>
                            <span style="color: var(--success); font-weight: 700; font-size: 0.9rem;">+{{ enrollment.cours.xp }} XP</span>
                        </div>
                        <div style="margin-bottom: 1.5rem;">
                            <div style="background: var(--border-light); height: 6px; border-radius: 3px; overflow: hidden;">
                                <div style="background: var(--success); height: 100%; width: {{ enrollment.progress }}%;"></div>
                            </div>
                            <p style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.5rem; font-weight: 500;">Progress: {{ enrollment.progress }}%</p>
                        </div>
                        {% if enrollment.progress == 100 %}
                            <div style="display: flex; gap: 10px; align-items: center; justify-content: center; width: 100%;">
                                <span style="background: rgba(16, 185, 129, 0.1); color: var(--success); padding: 8px 16px; border-radius: 8px; font-weight: 700; font-size: 0.9rem; flex: 1; text-align: center; border: 1px solid rgba(16, 185, 129, 0.2);">
                                    <i data-lucide="check-circle" style="width: 16px; height: 16px; margin-right: 5px;"></i> Completed
                                </span>
                                <a href="{{ path('app_student_course_detail', {'id': enrollment.cours.id}) }}" class="btn secondary" style="padding: 8px 12px; border-radius: 8px; display: flex; align-items: center; justify-content: center;" title="Review Course">
                                    <i data-lucide="eye" style="width: 20px; height: 20px;"></i>
                                </a>
                            </div>
                        {% else %}
                            <a href="{{ path('app_student_course_detail', {'id': enrollment.cours.id}) }}" class="btn" style="width: 100%; background: var(--brand-gradient); color: white; padding: 10px; font-size: 0.95rem; text-decoration: none; border-radius: 10px; font-weight: 600; text-align: center; box-shadow: 0 4px 15px rgba(99, 102, 241, 0.2); display: flex; align-items: center; justify-content: center; gap: 8px;">
                                <i data-lucide="play-circle" style="width: 18px; height: 18px;"></i> Continue Learning
                            </a>
                        {% endif %}
                    </div>
                </div>
            {% else %}
                <p style="text-align: center; color: var(--text-muted); padding: 3rem;">You haven't enrolled in any courses yet.</p>
            {% endfor %}
        </div>
    </section>

    <!-- TAB 3: CREATOR STUDIO (same as before) -->
    <section id="creator-studio" class="tab-content" style="display: none;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
            <h2 style="margin: 0;">My Created Content</h2>
            <div style="display: flex; gap: 10px;">
                <a href="{{ path('app_creator_matiere_new') }}" class="btn" style="text-decoration: none; background: var(--brand-main); color: white;">+ Propose Category</a>
            </div>
        </div>
        
        <!-- My Courses -->
        <h3 style="margin-bottom: 1rem; color: var(--text-secondary);">My Courses</h3>
        {% if myCreatedCourses is not empty %}
            <div class="grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem; margin-bottom: 3rem;">
                {% for course in myCreatedCourses %}
                    <div class="card" style="padding: 0; overflow: hidden; display: flex; flex-direction: column;">
                        <div style="padding: 1.5rem; flex: 1; display: flex; flex-direction: column;">
                            <div style="display: flex; justify-content: space-between; margin-bottom: 1rem;">
                                <h4 style="margin: 0;">{{ course.title }}</h4>
                                {% if course.status == 'PENDING' %}
                                    <span class="badge" style="background: var(--warning); color: white; padding: 4px 8px; border-radius: 12px; font-size: 0.7rem;">Pending</span>
                                {% elseif course.status == 'APPROVED' %}
                                    <span class="badge" style="background: var(--success); color: white; padding: 4px 8px; border-radius: 12px; font-size: 0.7rem;">Approved</span>
                                {% endif %}
                            </div>
                            <p style="color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 1.5rem; flex: 1;">{{ course.description|slice(0, 80) }}...</p>
                            <a href="{{ path('app_creator_course_manage', {'id': course.id}) }}" class="btn" style="width: fit-content; background: var(--brand-gradient); color: white; padding: 8px 20px; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 0.9rem; align-self: flex-start;">Manage</a>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p style="color: var(--text-muted); margin-bottom: 2rem;">You haven't created any courses yet.</p>
        {% endif %}

        <!-- My Categories -->
        <h3 style="margin-bottom: 1rem; color: var(--text-secondary);">My Proposed Categories</h3>
        {% if myCreatedMatieres is not empty %}
            <div style="margin-bottom: 3rem;">
                {% for matiere in myCreatedMatieres %}
                    <div class="card" style="padding: 1rem; margin-bottom: 0.5rem; display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-weight: 600;">{{ matiere.name }}</span>
                        {% if matiere.status == 'PENDING' %}
                            <span class="badge" style="background: var(--warning); color: white; padding: 4px 8px; border-radius: 12px; font-size: 0.75rem;">Pending Approval</span>
                        {% elseif matiere.status == 'APPROVED' %}
                            <span class="badge" style="background: var(--success); color: white; padding: 4px 8px; border-radius: 12px; font-size: 0.75rem;">Approved</span>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p style="color: var(--text-muted); margin-bottom: 2rem;">You haven't proposed any categories yet.</p>
        {% endif %}

        <!-- My Resources -->
        <h3 style="margin-bottom: 1rem; color: var(--text-secondary);">My Proposed Resources</h3>
        {% if myCreatedResources is not empty %}
            <div>
                {% for resource in myCreatedResources %}
                    <div class="card" style="padding: 1rem; margin-bottom: 0.5rem; display: flex; justify-content: space-between; align-items: center;">
                        <div style="flex: 1;">
                            <div style="font-weight: 600;">{{ resource.title ?? resource.url|slice(0, 50) }}</div>
                            <div style="font-size: 0.85rem; color: var(--text-secondary);">{{ resource.cours.title }}</div>
                        </div>
                        <span class="badge" style="background: var(--info); color: white; padding: 4px 8px; border-radius: 12px; font-size: 0.75rem; margin-right: 10px;">{{ resource.type }}</span>
                        {% if resource.status == 'PENDING' %}
                            <span class="badge" style="background: var(--warning); color: white; padding: 4px 8px; border-radius: 12px; font-size: 0.75rem;">Pending</span>
                        {% elseif resource.status == 'APPROVED' %}
                            <span class="badge" style="background: var(--success); color: white; padding: 4px 8px; border-radius: 12px; font-size: 0.75rem;">Approved</span>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p style="color: var(--text-muted);">You haven't proposed any resources yet.</p>
        {% endif %}
    </section>

</div>

<script>
    function switchTab(id) {
        // Hide all sections
        document.querySelectorAll('.tab-content').forEach(s => s.style.display = 'none');
        // Show target
        document.getElementById(id).style.display = 'block';
        
        // Update button styles
        document.querySelectorAll('.tab-btn').forEach(b => {
            b.classList.remove('active');
            b.style.color = 'var(--text-muted)';
            b.style.borderBottomColor = 'transparent';
        });
        
        // Activate clicked button
        const activeBtn = Array.from(document.querySelectorAll('.tab-btn')).find(b => b.getAttribute('onclick').includes(id));
        if (activeBtn) {
            activeBtn.classList.add('active');
            activeBtn.style.color = 'var(--text-main)';
            activeBtn.style.borderBottomColor = 'var(--brand-main)';
        }
    }

    // Initialize first tab or selected category tab
    document.addEventListener('DOMContentLoaded', () => {
        {% if selectedCategory %}
            switchTab('browse-categories');
        {% elseif currentTab == 'my-learning' %}
            switchTab('my-learning');
        {% elseif currentTab == 'creator-studio' %}
            switchTab('creator-studio');
        {% else %}
            switchTab('browse-categories');
        {% endif %}

        // Catch Flash Messages for SweetAlert
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                showToast('{{ label == 'error' ? 'error' : 'success' }}', '{{ message|e('js') }}');
                {% if label == 'success' and ('enrolled' in message|lower or 'completed' in message|lower) %}
                    triggerConfetti();
                {% endif %}
            {% endfor %}
        {% endfor %}
    });
</script>

<style>
    .tab-btn:hover {
        color: var(--brand-main) !important;
    }
    
    .card:hover {
        box-shadow: 0 6px 12px rgba(0,0,0,0.1);
    }
</style>
{% endblock %}
