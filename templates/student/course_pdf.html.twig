<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{{ cours.title }} - Summary</title>
    <style>
        body { font-family: Arial, sans-serif; font-size: 14px; color: #333; line-height: 1.6; }
        .header { border-bottom: 2px solid #5b2a6e; padding-bottom: 20px; margin-bottom: 30px; text-align: center; }
        .title { font-size: 28px; font-weight: bold; color: #5b2a6e; margin: 0; }
        .subtitle { font-size: 14px; color: #666; margin-top: 5px; }
        .section { margin-bottom: 30px; page-break-inside: avoid; }
        .section-title { font-size: 18px; font-weight: bold; color: #222; border-bottom: 1px solid #ddd; padding-bottom: 5px; margin-bottom: 10px; }
        .chapter { margin-bottom: 15px; padding-left: 10px; border-left: 3px solid #eee; }
        .chapter-title { font-weight: bold; color: #444; }
        .resource-list { font-size: 12px; color: #666; margin-top: 5px; }
        .footer { position: fixed; bottom: 0; left: 0; right: 0; text-align: center; font-size: 10px; color: #aaa; border-top: 1px solid #eee; padding-top: 10px; }
    </style>
</head>
<body>
    <div class="header">
        <h1 class="title">{{ cours.title }}</h1>
        <div class="subtitle">
            Category: {{ cours.matiere.name }} | Author: {{ cours.author.fullName }} | XP: {{ cours.xp }}
        </div>
    </div>

    <div class="section">
        <div class="section-title">Course Description</div>
        <div>{{ cours.description }}</div>
    </div>

    <div class="section">
        <div class="section-title">Chapters & Resources</div>
        <!-- Assuming chapters are implied or resources are direct children for now, adjusting to entity structure -->
        {% if cours.resources is not empty %}
            <ul>
            {% for resource in cours.resources %}
                <li style="margin-bottom: 5px;">
                    <strong>{{ resource.title }}</strong> 
                    <span style="color: #666; font-size: 11px;">({{ resource.type }})</span>
                    {% if resource.description %}
                        <br><i style="font-size: 12px;">{{ resource.description }}</i>
                    {% endif %}
                </li>
            {% endfor %}
            </ul>
        {% else %}
            <p>No resources listed.</p>
        {% endif %}
    </div>

    <div class="footer">
        Exported from EduLink on {{ "now"|date("F j, Y") }}
    </div>
</body>
</html>
