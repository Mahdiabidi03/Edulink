<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{{ title }}</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            font-size: 14px;
            line-height: 1.6;
            color: #333;
        }
        .header {
            border-bottom: 2px solid #3b82f6;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }
        .title {
            font-size: 24px;
            font-weight: bold;
            color: #111;
            margin: 0;
        }
        .meta {
            color: #666;
            font-size: 12px;
            margin-top: 10px;
        }
        .badge {
            display: inline-block;
            padding: 4px 8px;
            background-color: #eee;
            border-radius: 4px;
            font-size: 10px;
            font-weight: bold;
            margin-left: 10px;
        }
        .content {
            white-space: pre-wrap;
        }
        .footer {
            margin-top: 50px;
            border-top: 1px solid #eee;
            padding-top: 10px;
            font-size: 10px;
            color: #999;
            text-align: center;
        }
        .attachment-section {
            margin-top: 30px;
            padding: 15px;
            background-color: #f9f9f9;
            border: 1px solid #eee;
            border-radius: 5px;
        }
        .attachment-img {
            max-width: 100%;
            height: auto;
            margin-top: 10px;
            border: 1px solid #ddd;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1 class="title">{{ note.title }}</h1>
        <div class="meta">
            Created: {{ note.createdAt|date('F j, Y, g:i a') }}
            {% if note.category %}
                <span class="badge" style="background-color: {{ note.category.color }}; color: #fff;">{{ note.category.name }}</span>
            {% endif %}
        </div>
    </div>

    <div class="content">
        {{ note.content }}
    </div>

    {% if note.attachment %}
        <div class="attachment-section">
            <strong>Attachment:</strong> {{ note.attachment }}
            
            {% set extension = note.attachment|split('.')|last|lower %}
            {% if extension in ['jpg', 'jpeg', 'png'] %}
                {# Attempt to show image if possible. 
                   path() or absolute url might be needed. 
                   For dompdf with local files, absolute path is best.
                #}
                <div style="margin-top:10px;">
                    <img src="{{ absolute_url(asset('uploads/notes/' ~ note.attachment)) }}" class="attachment-img" alt="Attachment">
                </div>
            {% else %}
                <p><em>(File attachment not previewable in PDF)</em></p>
            {% endif %}
        </div>
    {% endif %}

    <div class="footer">
        Generated by EduLink
    </div>
</body>
</html>
