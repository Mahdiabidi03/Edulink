{% extends 'base.html.twig' %}

{% block content %}
<!-- Welcome & Profile Section -->
<div class="profile-header card" style="display: flex; align-items: center; gap: 2rem; margin-bottom: 2rem;">
  <div class="profile-avatar-lg" style="position: relative;">
    <img src="https://ui-avatars.com/api/?name={{ app.user.fullName|url_encode }}&size=128&background=random" alt="Student" style="width: 100px; height: 100px; border-radius: 50%; border: 3px solid var(--brand-accent); box-shadow: var(--shadow-md);">
    {% set current_level = ((app.user.walletBalance / 100)|round(0, 'floor')) + 1 %}
    <div class="level-badge" style="position: absolute; bottom: -5px; right: -5px; background: var(--brand-gradient); color: white; width: 32px; height: 32px; border-radius: 50%; display: grid; place-items: center; font-weight: bold; font-size: 0.9rem; border: 2px solid var(--bg-card);">{{ current_level }}</div>
  </div>
  
  <div class="profile-info" style="flex: 1;">
    <h1 style="margin: 0; font-size: 2.2rem; background: var(--brand-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-weight: 800; letter-spacing: -1px;">Hello, {{ app.user.fullName }}!</h1>
    <p style="color: var(--text-secondary); margin: 0.5rem 0 0; font-weight: 500;">{{ app.user.email }}</p>
    
    <div class="stats-row" style="display: flex; gap: 2rem; margin-top: 1.5rem;">
      <div class="stat-item" style="display: flex; align-items: center; gap: 12px;">
        <div style="background: rgba(16, 185, 129, 0.1); padding: 8px; border-radius: 12px;">
            <i data-lucide="sparkles" style="color: var(--success);"></i>
        </div>
        <div>
          <div style="font-size: 1.2rem; font-weight: 800;">{{ app.user.walletBalance|number_format }} XP</div>
          <div style="font-size: 0.8rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">Current Balance</div>
        </div>
      </div>
    </div>
  </div>
  
  <div class="profile-actions" style="border-left: 1px solid var(--border); padding-left: 2rem; min-width: 220px;">
    <button class="btn secondary" style="width: 100%; margin-bottom: 0.75rem;" onclick="openEditModal()"><i data-lucide="user-cog"></i> Edit Profile</button>
    <a href="{{ path('student_face_setup') }}" class="btn secondary" style="width: 100%; margin-bottom: 0.75rem;"><i data-lucide="scan-face"></i> Setup Face ID</a>
    <button class="btn" style="width: 100%;"><i data-lucide="share"></i> View Profile</button>
  </div>
</div>

<!-- Badges Section -->
<div class="card" style="margin-bottom: 2rem; padding: 1.5rem;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <h2 style="font-size: 1.25rem; margin: 0; display: flex; align-items: center; gap: 10px;">
      <i data-lucide="award" style="color: var(--brand-main);"></i>
      Mes Badges & Succès
    </h2>
    <span style="font-size: 0.85rem; color: var(--text-muted); font-weight: 600;">{{ app.user.userBadges|length }} DÉBLOQUÉS</span>
  </div>

  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 1rem;">
    {% for ub in app.user.userBadges %}
      <div class="badge-item" style="text-align: center; background: var(--bg-main); padding: 1rem; border-radius: 16px; border: 1px solid var(--border); transition: all 0.3s ease; cursor: default;">
        <div style="width: 50px; height: 50px; background: var(--brand-gradient); border-radius: 50%; display: grid; place-items: center; margin: 0 auto 0.75rem; box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);">
          <i data-lucide="{{ ub.badge.icon|default('medal') }}" style="color: white; width: 24px; height: 24px;"></i>
        </div>
        <div style="font-weight: 700; font-size: 0.85rem; color: var(--text-main); line-height: 1.2;">{{ ub.badge.name }}</div>
        <div style="font-size: 0.7rem; color: var(--success); margin-top: 4px; font-weight: 600;">DÉBLOQUÉ</div>
      </div>
    {% else %}
      <div style="grid-column: 1 / -1; text-align: center; padding: 1rem; color: var(--text-muted); font-style: italic; border: 2px dashed var(--border); border-radius: 12px;">
        <i data-lucide="lock" style="width: 20px; height: 20px; margin-bottom: 0.5rem; opacity: 0.5;"></i>
        <p style="margin: 0;">Complète des challenges pour débloquer tes premiers badges !</p>
      </div>
    {% endfor %}
  </div>
</div>

<!-- Edit Profile Modal -->
<div id="editProfileModal" style="display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(0,0,0,0.8); backdrop-filter: blur(5px);">
  <div class="card" style="margin: 10% auto; padding: 2rem; width: 80%; max-width: 500px; position: relative; animation: slideDown 0.3s ease-out;">
    <button onclick="closeEditModal()" style="position: absolute; top: 1rem; right: 1rem; background: none; border: none; color: var(--text-muted); font-size: 1.5rem; cursor: pointer;">&times;</button>
    <h2 style="margin-top: 0; margin-bottom: 1.5rem;">Edit Profile</h2>
    
    {{ form_start(editProfileForm, {'attr': {'novalidate': 'novalidate'}}) }}
        <div class="form-group" style="margin-bottom: 1rem;">
            {{ form_label(editProfileForm.fullName, null, {'label_attr': {'style': 'display: block; margin-bottom: 0.5rem; color: var(--text-secondary);'}}) }}
            {{ form_widget(editProfileForm.fullName, {'attr': {'class': 'form-input', 'style': 'width: 100%; padding: 10px; background: var(--bg-main); border: 1px solid var(--border); color: var(--text-main); border-radius: 8px;'}}) }}
            {{ form_errors(editProfileForm.fullName) }}
        </div>
        
        <div class="form-group" style="margin-bottom: 1.5rem;">
            {{ form_label(editProfileForm.email, null, {'label_attr': {'style': 'display: block; margin-bottom: 0.5rem; color: var(--text-secondary);'}}) }}
            {{ form_widget(editProfileForm.email, {'attr': {'class': 'form-input', 'style': 'width: 100%; padding: 10px; background: var(--bg-main); border: 1px solid var(--border); color: var(--text-main); border-radius: 8px;'}}) }}
            {{ form_errors(editProfileForm.email) }}
        </div>

        <div class="form-group" style="margin-bottom: 1rem;">
             {{ form_label(editProfileForm.plainPassword.first, null, {'label_attr': {'style': 'display: block; margin-bottom: 0.5rem; color: var(--text-secondary);'}}) }}
             {{ form_widget(editProfileForm.plainPassword.first, {'attr': {'class': 'form-input', 'style': 'width: 100%; padding: 10px; background: var(--bg-main); border: 1px solid var(--border); color: var(--text-main); border-radius: 8px;'}}) }}
             {{ form_errors(editProfileForm.plainPassword.first) }}
        </div>

        <div class="form-group" style="margin-bottom: 1.5rem;">
             {{ form_label(editProfileForm.plainPassword.second, null, {'label_attr': {'style': 'display: block; margin-bottom: 0.5rem; color: var(--text-secondary);'}}) }}
             {{ form_widget(editProfileForm.plainPassword.second, {'attr': {'class': 'form-input', 'style': 'width: 100%; padding: 10px; background: var(--bg-main); border: 1px solid var(--border); color: var(--text-main); border-radius: 8px;'}}) }}
        </div>

        <button type="submit" class="btn" style="width: 100%;">Save Changes</button>
    {{ form_end(editProfileForm) }}
  </div>
</div>

<script>
function openEditModal() {
    document.getElementById('editProfileModal').style.display = 'block';
}

function closeEditModal() {
    document.getElementById('editProfileModal').style.display = 'none';
}

// Close modal if clicking outside of it
window.onclick = function(event) {
    var modal = document.getElementById('editProfileModal');
    if (event.target == modal) {
        modal.style.display = "none";
    }
}
</script>

<style>
@keyframes slideDown {
    from { transform: translateY(-50px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
}
</style>

<!-- My Courses Section -->
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
  <h2 style="font-size: 1.5rem; margin: 0;">My Courses</h2>
  <a href="{{ path('app_student_courses') }}" style="color: var(--brand-main); text-decoration: none; font-weight: 500;">View All <i class="ri-arrow-right-line"></i></a>
</div>

<div class="grid courses-grid" style="grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));">
  {% if app.user.id > 1000 %} 
     <!-- Logic here to loop through user courses if they existed. For now showing empty placeholder or keeping generic cards if desired. The prompt said "number courses is 0 when he just registered", so I will show an empty state message if course count is 0. -->
  {% else %}
     <div class="card" style="grid-column: 1 / -1; text-align: center; padding: 3rem; color: var(--text-muted);">
        <i data-lucide="book-open" style="width: 48px; height: 48px; margin-bottom: 1rem; opacity: 0.5; margin-inline: auto;"></i>
        <h3>No courses yet</h3>
        <p>Start your learning journey today!</p>
        <a href="{{ path('app_student_courses') }}" class="btn" style="margin-top: 1rem;">Browse Courses</a>
     </div>
  {% endif %}
</div>
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; margin-top: 3rem;">
    <h2 style="font-size: 1.5rem; margin: 0;">Smart Tools</h2>
  </div>

  <div class="grid" style="grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); margin-bottom: 3rem;">
      <a href="{{ path('student_ai_tools') }}" class="card" style="display: flex; align-items: center; gap: 1.5rem; text-decoration: none; color: inherit; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
          <div style="width: 60px; height: 60px; background: linear-gradient(135deg, #8b5cf6, #3b82f6); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
              <i data-lucide="bot" style="color: white; width: 32px; height: 32px;"></i>
          </div>
          <div>
              <h3 style="margin: 0; font-size: 1.1rem; color: var(--text-main);">AI Study Companion</h3>
              <p style="margin: 0.25rem 0 0; font-size: 0.85rem; color: var(--text-secondary);">Summaries, Quizzes & Explanations</p>
          </div>
      </a>
      
      <a href="{{ path('student_face_setup') }}" class="card" style="display: flex; align-items: center; gap: 1.5rem; text-decoration: none; color: inherit; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
          <div style="width: 60px; height: 60px; background: var(--bg-main); border: 2px solid var(--border); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
              <i data-lucide="scan-eye" style="color: var(--text-secondary); width: 32px; height: 32px;"></i>
          </div>
          <div>
              <h3 style="margin: 0; font-size: 1.1rem; color: var(--text-main);">Security Settings</h3>
              <p style="margin: 0.25rem 0 0; font-size: 0.85rem; color: var(--text-secondary);">Manage Face ID & Password</p>
          </div>
      </a>
  </div>
{% endblock %}
