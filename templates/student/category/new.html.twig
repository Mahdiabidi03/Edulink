{% extends 'base.html.twig' %}

{% block title %}Create Category - EduLink{% endblock %}

{% block content %}
<div class="journal-container" style="max-height: 90vh; display: flex; flex-direction: column;">

    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1 class="page-title" style="margin: 0; font-size: 2rem; background: var(--brand-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Create New Category</h1>
            <p style="color: var(--text-secondary); margin-top: 0.5rem;">Add a new category to organize your notes.</p>
        </div>
        <a href="{{ path('category_index') }}" class="btn secondary"><i class="ri-arrow-left-line"></i> Back</a>
    </div>

    <!-- Form Container -->
    <div class="grid" style="grid-template-columns: 1fr; max-width: 600px;">
        <div class="card" style="padding: 2rem;">
            {{ form_start(form, {'attr': {'style': 'display: contents;', 'novalidate': 'novalidate'}}) }}
                
                <!-- Name Field -->
                <div style="margin-bottom: 1.5rem;">
                    {{ form_label(form.name, 'Category Name', {'label_attr': {'style': 'display: block; color: var(--text-main); font-weight: 600; margin-bottom: 0.5rem;'}}) }}
                    {{ form_widget(form.name, {'attr': {'style': 'width: 100%; padding: 10px; background: rgba(0,0,0,0.2); border: 1px solid var(--border); border-radius: 8px; color: var(--text-main); font-size: 1rem;'}}) }}
                    {% if form.name.vars.errors %}
                        <div style="color: #ff6b6b; font-size: 0.9rem; margin-top: 0.5rem;">
                            {% for error in form.name.vars.errors %}
                                {{ error.message }}
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>

                <!-- Color Field -->
                <div style="margin-bottom: 1.5rem;">
                    {{ form_label(form.color, 'Color', {'label_attr': {'style': 'display: block; color: var(--text-main); font-weight: 600; margin-bottom: 0.5rem;'}}) }}
                    {{ form_widget(form.color, {'attr': {'style': 'width: 60px; height: 60px; padding: 5px; background: rgba(0,0,0,0.2); border: 1px solid var(--border); border-radius: 8px; cursor: pointer;'}}) }}
                    {% if form.color.vars.errors %}
                        <div style="color: #ff6b6b; font-size: 0.9rem; margin-top: 0.5rem;">
                            {% for error in form.color.vars.errors %}
                                {{ error.message }}
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>

                <!-- Submit Button -->
                <div style="display: flex; justify-content: flex-end; gap: 1rem;">
                    <a href="{{ path('category_index') }}" class="btn secondary" style="padding: 10px 20px;">Cancel</a>
                    <button type="submit" class="btn" style="padding: 10px 20px;"><i class="ri-save-3-line"></i> Create Category</button>
                </div>

            {{ form_end(form) }}
        </div>
    </div>

</div>
{% endblock %}
