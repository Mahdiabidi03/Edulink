{% extends 'base.html.twig' %}

{% block title %}Note Categories - EduLink{% endblock %}

{% block content %}
<div class="journal-container" style="max-height: 90vh; display: flex; flex-direction: column;">

    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1 class="page-title" style="margin: 0; font-size: 2rem; background: var(--brand-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Note Categories</h1>
            <p style="color: var(--text-secondary); margin-top: 0.5rem;">Organize your notes by categories.</p>
        </div>
        <a href="{{ path('category_new') }}" class="btn"><i class="ri-add-line"></i> New Category</a>
    </div>

    <!-- Categories Grid -->
    <div class="grid" style="grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1.5rem;">
        {% if categories is empty %}
            <div class="card" style="grid-column: 1 / -1; padding: 2rem; text-align: center;">
                <p style="color: var(--text-secondary); margin: 0;">No categories yet. <a href="{{ path('category_new') }}" style="color: var(--brand); text-decoration: none;">Create one</a></p>
            </div>
        {% else %}
            {% for category in categories %}
                <div class="card" style="padding: 1.5rem; border-left: 4px solid {{ category.color }};">
                    <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 1rem;">
                        <div>
                            <h3 style="margin: 0; color: var(--text-main);">{{ category.name }}</h3>
                            <p style="color: var(--text-secondary); font-size: 0.9rem; margin: 0.5rem 0 0 0;">
                                {{ category.notes|length }} note{{ category.notes|length > 1 ? 's' : '' }}
                            </p>
                        </div>
                        <div style="display: flex; gap: 0.5rem;">
                            <a href="{{ path('category_edit', {'id': category.id}) }}" class="btn secondary" style="padding: 6px 10px; font-size: 0.85rem;">
                                <i class="ri-edit-line"></i>
                            </a>
                            <form method="POST" action="{{ path('category_delete', {'id': category.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
                                <button type="submit" class="btn secondary" style="padding: 6px 10px; font-size: 0.85rem; color: #ff6b6b;">
                                    <i class="ri-delete-line"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                    <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
                        <span style="display: inline-block; width: 20px; height: 20px; background-color: {{ category.color }}; border-radius: 4px;"></span>
                    </div>
                </div>
            {% endfor %}
        {% endif %}
    </div>

</div>
{% endblock %}
