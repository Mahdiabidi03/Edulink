<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Certificate of Completion</title>
    <style>
        @page {
            size: A4 landscape;
            margin: 0;
        }
        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            font-family: 'Arial', sans-serif;
            color: #333;
        }
        .certificate-container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            box-sizing: border-box;
            background-color: #6c5ce7;
            padding: 40px;
        }
        .outer-border {
            width: 100%;
            height: 100%;
            background: #fff;
            border: 15px solid #a29bfe;
            box-sizing: border-box;
            display: table;
        }
        .content {
            display: table-cell;
            vertical-align: middle;
            text-align: center;
            padding: 40px;
        }
        .logo {
            font-weight: bold;
            font-size: 28px;
            color: #6c5ce7;
            margin-bottom: 20px;
        }
        h1 {
            font-size: 60px;
            margin: 0;
            color: #6c5ce7;
            letter-spacing: 5px;
        }
        h2 {
            font-size: 28px;
            margin: 5px 0 30px 0;
            color: #2d3436;
        }
        .text-certify {
            font-size: 18px;
            margin: 10px 0;
        }
        .student-name {
            font-size: 45px;
            font-weight: bold;
            color: #2d3436;
            margin: 20px 0;
            border-bottom: 2px solid #6c5ce7;
            display: inline-block;
            padding: 0 40px;
        }
        .course-title {
            font-size: 26px;
            font-style: italic;
            margin: 20px 0;
            color: #6c5ce7;
        }
        .footer-table {
            width: 100%;
            margin-top: 40px;
            border: none;
        }
        .footer-td {
            width: 50%;
            text-align: center;
            vertical-align: bottom;
        }
        .footer-label {
            font-size: 12px;
            color: #636e72;
            margin-top: 5px;
        }
        .footer-value {
            font-size: 18px;
            font-weight: bold;
            color: #2d3436;
        }
        .cert-id {
            font-size: 11px;
            color: #b2bec3;
            margin-top: 30px;
        }
    </style>
</head>
<body>
    <div class="certificate-container">
        <div class="outer-border">
            <div class="content">
                <div class="logo">EduLink Academy</div>
                <h1>CERTIFICATE</h1>
                <h2>OF COMPLETION</h2>
                
                <p class="text-certify">This acknowledges that</p>
                <div class="student-name">{{ user.fullName ?: user.email }}</div>
                <p class="text-certify">has successfully completed the interactive course</p>
                <div class="course-title">{{ cours.title }}</div>
                
                <table class="footer-table">
                    <tr>
                        <td class="footer-td">
                            <div class="footer-value">{{ date|date('F d, Y') }}</div>
                            <div class="footer-label">DATE OF COMPLETION</div>
                        </td>
                        <td class="footer-td">
                            <div class="footer-value" style="border-bottom: 1px solid #333; width: 220px; margin: 0 auto; padding-bottom: 5px;">Academy Board</div>
                            <div class="footer-label">AUTHORIZED SIGNATURE</div>
                        </td>
                    </tr>
                </table>
                
                <div class="cert-id">Verification ID: {{ certId }}</div>
            </div>
        </div>
    </div>
</body>
</html>
