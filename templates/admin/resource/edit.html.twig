{% extends 'admin_base.html.twig' %}

{% block title %}Edit Resource{% endblock %}

{% block content %}
<div style="max-width: 800px; margin: 2rem auto; padding: 0 1rem;">
    <h1>Edit Resource</h1>
    
    <div class="card" style="padding: 2rem;">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            <div style="margin-bottom: 1.5rem;">
                {{ form_label(form.title, 'Resource Title', {'label_attr': {'style': 'display: block; margin-bottom: 0.5rem; font-weight: 600;'}}) }}
                {{ form_widget(form.title, {'attr': {'class': 'form-control', 'style': 'width: 100%; padding: 10px; border: 1px solid var(--border); border-radius: 8px;'}}) }}
                {{ form_errors(form.title) }}
            </div>

            <div style="margin-bottom: 1.5rem;">
                {{ form_label(form.type, 'Resource Type', {'label_attr': {'style': 'display: block; margin-bottom: 0.5rem; font-weight: 600;'}}) }}
                {{ form_widget(form.type, {
                    'attr': {
                        'class': 'form-control', 
                        'style': 'width: 100%; padding: 10px; border: 1px solid var(--border); border-radius: 8px;',
                        'onchange': 'toggleResourceType(this.value)'
                    }
                }) }}
                {{ form_errors(form.type) }}
            </div>
            
            <div id="url-group" style="margin-bottom: 2rem;">
                {{ form_label(form.url, 'Resource URL / Video ID', {'label_attr': {'style': 'display: block; margin-bottom: 0.5rem; font-weight: 600;'}}) }}
                {{ form_widget(form.url, {'attr': {'class': 'form-control', 'style': 'width: 100%; padding: 10px; border: 1px solid var(--border); border-radius: 8px;'}}) }}
                {{ form_errors(form.url) }}
            </div>

            <div id="file-group" style="margin-bottom: 2rem; display: none;">
                {{ form_label(form.file, 'File Upload', {'label_attr': {'style': 'display: block; margin-bottom: 0.5rem; font-weight: 600;'}}) }}
                <div class="file-upload-wrapper">
                    <label for="{{ form.file.vars.id }}" class="file-upload-label">
                        <i class="ri-file-upload-line"></i>
                        <span id="filename-display">Change File (current: {{ resource.url|split('/')|last }})</span>
                    </label>
                    {{ form_widget(form.file, {
                        'attr': {
                            'class': 'file-upload-input',
                            'onchange': 'updateFileNameResource(this)'
                        }
                    }) }}
                </div>
                {{ form_errors(form.file) }}
            </div>

            <div style="display: flex; gap: 10px; margin-bottom: 2rem;">
                <button type="submit" class="btn" style="flex: 1; background: var(--brand-main); color: white;">Update Resource</button>
                <a href="{{ path('app_admin_course_manage', {'id': resource.cours.id}) }}" class="btn secondary" style="text-decoration: none; text-align: center;">Cancel</a>
            </div>
        {{ form_end(form) }}
        
        <div style="border-top: 1px solid var(--border); padding-top: 2rem;">
            <form method="post" action="{{ path('app_admin_resource_delete', {'id': resource.id}) }}" onsubmit="return confirm('Are you sure you want to delete this resource?');" novalidate>
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ resource.id) }}">
                <button class="btn" style="background: var(--error); color: white;">Delete Resource</button>
            </form>
        </div>
    </div>
</div>

<script>
function toggleResourceType(type) {
    const urlGroup = document.getElementById('url-group');
    const fileGroup = document.getElementById('file-group');
    
    if (type === 'VIDEO') {
        if(urlGroup) urlGroup.style.display = 'block';
        if(fileGroup) fileGroup.style.display = 'none';
    } else {
        if(urlGroup) urlGroup.style.display = 'none';
        if(fileGroup) fileGroup.style.display = 'block';
    }
}

function updateFileNameResource(input) {
    const display = document.getElementById('filename-display');
    if (input.files && input.files[0]) {
        display.textContent = input.files[0].name;
        display.style.color = 'var(--brand-main)';
        display.style.fontWeight = 'bold';
    }
}

document.addEventListener('DOMContentLoaded', () => {
    toggleResourceType(document.querySelector('select[name*="[type]"]').value);
});
</script>
{% endblock %}
