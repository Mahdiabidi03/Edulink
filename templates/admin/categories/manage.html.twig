{% extends 'admin_base.html.twig' %}

{% block content %}
<div style="max-width: 1200px; margin: 0 auto;">
    
    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <a href="{{ path('app_admin_categories') }}" style="color: var(--text-secondary); text-decoration: none; margin-bottom: 0.5rem; display: inline-block;">← Back to Categories</a>
            <h1 style="margin: 0;">{{ matiere.name }}</h1>
        </div>
        <a href="{{ path('app_admin_category_new_course', {'id': matiere.id}) }}" class="btn" style="background: var(--success); color: white;">+ Add Course</a>
    </div>

    <!-- Flash Messages -->
    {% for message in app.flashes('success') %}
        <div style="background: rgba(16, 185, 129, 0.1); border: 1px solid var(--success); color: var(--success); padding: 10px; border-radius: 6px; margin-bottom: 1rem;">
            {{ message }}
        </div>
    {% endfor %}

    <div class="card" style="padding: 1.5rem; margin-bottom: 2rem;">
        <form method="get" style="display: flex; gap: 2rem; flex-wrap: wrap; align-items: center;">
            <div style="flex: 0 0 300px; position: relative;">
                <i class="ri-search-line" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
                <input type="text" name="q" value="{{ q ?? '' }}" placeholder="Search courses in this category..." style="width: 100%; padding: 10px 10px 10px 40px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; color: var(--text-main);">
            </div>

            <div style="display: flex; gap: 1rem; flex: 1; min-width: 300px; align-items: center; justify-content: flex-end;">
                <select name="level" style="max-width: 150px; padding: 10px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; color: var(--text-main);">
                    <option value="">All Levels</option>
                    <option value="Beginner" {{ level == 'Beginner' ? 'selected' : '' }}>Beginner</option>
                    <option value="Intermediate" {{ level == 'Intermediate' ? 'selected' : '' }}>Intermediate</option>
                    <option value="Advanced" {{ level == 'Advanced' ? 'selected' : '' }}>Advanced</option>
                </select>

                <select name="sort" style="max-width: 200px; padding: 10px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; color: var(--text-main);">
                    <option value="newest" {{ sort == 'newest' ? 'selected' : '' }}>Newest First</option>
                    <option value="alpha_asc" {{ sort == 'alpha_asc' ? 'selected' : '' }}>Alphabetical (A-Z)</option>
                    <option value="reward_high" {{ sort == 'reward_high' ? 'selected' : '' }}>XP: High to Low</option>
                    <option value="reward_low" {{ sort == 'reward_low' ? 'selected' : '' }}>XP: Low to High</option>
                </select>

                <button type="submit" class="btn brand" style="padding: 10px 24px;">Apply</button>
                
                {% if q or level or sort != 'newest' %}
                    <a href="{{ path('app_admin_category_manage', {'id': matiere.id}) }}" class="btn secondary" style="padding: 10px 15px; text-decoration: none;">Clear</a>
                {% endif %}
            </div>
        </form>
    </div>

    <!-- Courses Table -->
    <div class="card">
        <h2 style="margin-top: 0; padding-bottom: 1rem; border-bottom: 2px solid var(--border);">Courses in this Category</h2>
        
        {% if pagination is not empty %}
            <table style="width: 100%; border-collapse: collapse; margin-top: 1rem;">
                <thead>
                    <tr style="border-bottom: 2px solid var(--border);">
                        <th style="text-align: left; padding: 12px; color: var(--text-muted);">Course Title</th>
                        <th style="text-align: left; padding: 12px; color: var(--text-muted);">Level</th>
                        <th style="text-align: center; padding: 12px; color: var(--text-muted);">XP</th>
                        <th style="text-align: center; padding: 12px; color: var(--text-muted);">Resources</th>
                        <th style="text-align: right; padding: 12px; color: var(--text-muted);">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for course in pagination %}
                    <tr style="border-bottom: 1px solid var(--border-light);">
                        <td style="padding: 15px; font-weight: 600;">{{ course.title }}</td>
                        <td style="padding: 15px;">
                            <span class="badge" style="background: var(--info); color: white; padding: 4px 8px; border-radius: 12px; font-size: 0.8rem;">{{ course.level }}</span>
                        </td>
                        <td style="padding: 15px; text-align: center; font-weight: 600; color: var(--success);">+{{ course.xp }} XP</td>
                        <td style="padding: 15px; text-align: center;">{{ course.resources|length }}</td>
                        <td style="padding: 15px; text-align: right;">
                            <div style="display: flex; gap: 5px; justify-content: flex-end;">
                                <a href="{{ path('app_admin_course_manage', {'id': course.id}) }}" class="btn secondary" style="text-decoration: none;">Manage Resources</a>
                                <a href="{{ path('app_admin_course_edit', {'id': course.id}) }}" class="btn secondary" style="text-decoration: none;">Edit</a>
                                <form method="post" action="{{ path('app_admin_course_delete', {'id': course.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this course?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ course.id) }}">
                                    <button type="submit" class="btn" style="background: var(--error); color: white; padding: 8px 12px; min-width: auto;"><i class="ri-delete-bin-line"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            <div class="navigation" style="margin-top: 2rem;">
                <div class="pagination">
                    {{ knp_pagination_render(pagination) }}
                </div>
            </div>
        {% else %}
            <p style="text-align: center; padding: 2rem; color: var(--text-muted);">No courses in this category yet.</p>
        {% endif %}
    </div>

</div>
{% endblock %}
