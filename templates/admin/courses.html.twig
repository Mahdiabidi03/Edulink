{% extends 'admin_base.html.twig' %}

{% block content %}
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <h1>Courses Moderation</h1>
    <a href="{{ path('app_admin_course_new') }}" class="btn" style="background: blue; color: white; padding: 10px;">+ Create Official Course</a>
</div>

<div class="card">
<table class="admin-table" style="width: 100%; border-collapse: collapse;">
  <tr style="text-align: left; background: #f4f4f4;">
    <th style="padding: 10px;">Title</th>
    <th style="padding: 10px;">Author</th>
    <th style="padding: 10px;">Status</th>
    <th style="padding: 10px;">Actions</th>
  </tr>
  
  {% for course in courses %}
      <tr style="border-bottom: 1px solid #ddd;">
        <td style="padding: 10px;">{{ course.title }}</td>
        <td style="padding: 10px;">{{ course.author.email }}</td>
        <td style="padding: 10px;">
            <span style="padding: 4px 8px; border-radius: 4px; background: {{ course.status == 'APPROVED' ? '#d1fae5' : '#fef3c7' }}; color: {{ course.status == 'APPROVED' ? '#065f46' : '#92400e' }}">
                {{ course.status }}
            </span>
        </td>
        <td style="padding: 10px;">
          <!-- EDIT CONTENT -->
          <a href="{{ path('app_admin_course_manage', {'id': course.id}) }}" class="btn" style="padding: 5px 10px; border: 1px solid #ccc; text-decoration:none; color:black;">Manage</a>
          
          <!-- APPROVE/REJECT -->
          {% if course.status == 'PENDING' %}
              <a href="{{ path('app_admin_course_status', {id: course.id, status: 'APPROVED'}) }}" style="color: green; margin-left: 5px;">Approve</a>
              <a href="{{ path('app_admin_course_status', {id: course.id, status: 'REJECTED'}) }}" style="color: red; margin-left: 5px;">Reject</a>
          {% endif %}
        </td>
      </tr>
  {% endfor %}
</table>
</div>
{% endblock %}