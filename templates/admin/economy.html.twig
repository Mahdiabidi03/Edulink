{% extends 'admin_base.html.twig' %}

{% block title %}Economy System - Admin{% endblock %}

{% block content %}
<style>
    /* Economy Pro Layout */
    .economy-layout {
        display: grid;
        grid-template-columns: 1fr 400px;
        gap: var(--space-xl);
        max-width: 1400px;
    }

    /* Credit Card Style KPIs */
    .finance-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 1.5rem;
        position: relative;
        overflow: hidden;
        transition: 0.3s;
        box-shadow: var(--shadow-sm);
    }
    
    .finance-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-lg);
    }

    .finance-card.highlight {
        background: var(--brand-gradient);
        color: white;
        border: none;
    }
    .finance-card.highlight .stat-label, 
    .finance-card.highlight .stat-value {
        color: white;
    }

    .card-pattern {
        position: absolute;
        top: 0;
        right: 0;
        width: 150px;
        height: 150px;
        background: linear-gradient(135deg, rgba(255,255,255,0.1), transparent);
        border-radius: 0 0 0 100%;
        pointer-events: none;
    }

    /* Operations Terminal */
    .terminal-panel {
        background: var(--bg-card);
        border-radius: 24px;
        padding: 2rem;
        border: 1px solid var(--border);
        box-shadow: var(--shadow-xl);
        position: sticky;
        top: 2rem;
    }

    .terminal-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 2rem;
    }

    .terminal-input {
        background: var(--bg-main);
        border: 2px solid var(--border);
        border-radius: 16px;
        padding: 1rem;
        width: 100%;
        color: var(--text-main);
        font-family: 'Fira Code', monospace;
        font-size: 1rem;
        transition: 0.3s;
    }
    
    .terminal-input:focus {
        border-color: var(--brand-main);
        box-shadow: 0 0 0 4px rgba(91, 42, 110, 0.1);
        outline: none;
    }

    .amount-display {
        background: var(--bg-deep);
        border-radius: 16px;
        padding: 2rem;
        text-align: center;
        margin-bottom: 2rem;
        position: relative;
        overflow: hidden;
    }
    
    .amount-input {
        background: transparent;
        border: none;
        color: white;
        font-size: 3rem;
        font-weight: 700;
        text-align: center;
        width: 80%;
        outline: none;
        font-family: 'Fira Sans', sans-serif;
    }
    
    .amount-display::before {
        content: 'PTS';
        position: absolute;
        bottom: 10px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 0.8rem;
        color: rgba(255,255,255,0.5);
        letter-spacing: 2px;
    }

    /* Advanced Toggle */
    .toggle-group {
        background: var(--bg-main);
        padding: 4px;
        border-radius: 12px;
        display: flex;
        margin-bottom: 1.5rem;
    }
    
    .toggle-opt {
        flex: 1;
        padding: 10px;
        text-align: center;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.9rem;
        transition: 0.3s;
        color: var(--text-secondary);
    }
    
    .toggle-opt.active.grant {
        background: var(--success);
        color: white;
        box-shadow: 0 2px 10px rgba(34, 197, 94, 0.3);
    }
    
    .toggle-opt.active.refund {
        background: var(--brand-accent);
        color: white;
        box-shadow: 0 2px 10px rgba(184, 50, 128, 0.3);
    }
    
    /* Transaction List */
    .tx-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem;
        border-bottom: 1px solid var(--border-light);
        transition: 0.2s;
    }
    .tx-row:hover {
        background: rgba(91, 42, 110, 0.02);
    }
    
    .tx-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: grid;
        place-items: center;
        font-size: 1.2rem;
    }

</style>

<!-- Header -->
<div class="page-header">
    <div>
        <h1 class="page-title">Global Economy</h1>
        <p class="page-subtitle">Liquidity pool & asset management</p>
    </div>
    <div style="text-align: right;">
        <span style="display: block; font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase;">Current Exchange Rate</span>
        <span style="font-weight: 700; color: var(--brand-main);">100 XP = 10 PTS</span>
    </div>
</div>

<div class="economy-layout">
    
    <!-- LEFT: Financial Overview -->
    <div>
        <!-- Pro Cards Grid -->
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-bottom: 2rem;">
            
            <div class="finance-card highlight">
                <div class="card-pattern"></div>
                <div style="margin-bottom: 1rem; font-size: 2rem;"><i class="ri-global-line"></i></div>
                <div class="stat-value" style="font-size: 1.8rem; font-weight: 800;">{{ total_points|number_format }}</div>
                <div class="stat-label" style="opacity: 0.9;">Total Points Issued</div>
            </div>

            <div class="finance-card">
                <div style="display: flex; justify-content: space-between; margin-bottom: 1rem;">
                    <div class="stat-label">Points Today</div>
                    <span style="color: var(--success); font-size: 0.9rem; background: rgba(34, 197, 94, 0.1); padding: 2px 6px; border-radius: 4px;">Live</span>
                </div>
                <div class="stat-value" style="font-size: 1.8rem; font-weight: 800; color: var(--text-main);">{{ daily_points|number_format }}</div>
                <div style="height: 4px; width: 100%; background: var(--border); margin-top: 15px; border-radius: 2px;">
                    <div style="width: 100%; height: 100%; background: var(--brand-main); border-radius: 2px;"></div>
                </div>
            </div>

            <div class="finance-card">
                 <div style="display: flex; justify-content: space-between; margin-bottom: 1rem;">
                    <div class="stat-label">Active Users</div>
                    <i class="ri-user-smile-line" style="color: var(--brand-accent);"></i>
                </div>
                <div class="stat-value" style="font-size: 1.8rem; font-weight: 800; color: var(--text-main);">{{ active_users|number_format }}</div>
                <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 5px;">Active wallets today</div>
            </div>

        </div>

        <!-- Ledger -->
        <div class="table-container">
            <div style="padding: 1.5rem; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between;">
                <h3 style="margin: 0;">Ledger History</h3>
                <button class="icon-btn"><i class="ri-filter-3-line"></i></button>
            </div>
            
            <div class="tx-list">
                {% for tx in transactions %}
                <div class="tx-row">
                    <div style="display: flex; align-items: center; gap: 15px;">
                        <div class="tx-icon" style="background: rgba({{ tx.amount > 0 ? '34, 197, 94' : '239, 68, 68' }}, 0.1); color: {{ tx.amount > 0 ? 'var(--success)' : 'var(--error)' }};">
                            <i class="{{ tx.amount > 0 ? 'ri-arrow-down-line' : 'ri-arrow-up-line' }}"></i>
                        </div>
                        <div>
                            <div style="font-weight: 600; color: var(--text-main);">{{ tx.type|default('Transaction') }}</div>
                            <div style="font-size: 0.8rem; color: var(--text-muted);">{{ tx.user.email }}</div>
                        </div>
                    </div>
                    <div style="text-align: right;">
                        <div style="font-weight: 700; color: {{ tx.amount > 0 ? 'var(--success)' : 'var(--text-main)' }};">
                            {{ tx.amount > 0 ? '+' : '' }}{{ tx.amount }} PTS
                        </div>
                        <div style="font-size: 0.75rem; color: var(--text-muted);">{{ tx.date|date('M d, H:i') }}</div>
                    </div>
                </div>
                {% else %}
                <div style="padding: 2rem; text-align: center; color: var(--text-muted);">
                    No transactions found.
                </div>
                {% endfor %}
            </div>
        </div>
    </div>

    <!-- RIGHT: Transaction Terminal -->
    <div class="terminal-panel">
        <div class="terminal-header">
            <div style="width: 40px; height: 40px; background: var(--brand-main); border-radius: 50%; display: grid; place-items: center; color: white; font-size: 1.2rem;">
                <i class="ri-terminal-box-line"></i>
            </div>
            <div>
                <h3 style="margin: 0; font-size: 1.1rem;">Transaction Terminal</h3>
                <span style="font-size: 0.8rem; color: var(--text-muted);">Secure Gateway</span>
            </div>
        </div>
        
        {% for message in app.flashes('success') %}
            <div style="background: rgba(34, 197, 94, 0.1); color: var(--success); padding: 10px; border-radius: 8px; margin-bottom: 1rem; font-size: 0.9rem;">
                {{ message }}
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
             <div style="background: rgba(239, 68, 68, 0.1); color: var(--error); padding: 10px; border-radius: 8px; margin-bottom: 1rem; font-size: 0.9rem;">
                {{ message }}
            </div>
        {% endfor %}

        <form action="{{ path('admin_economy_transfer') }}" method="POST">
            <div class="toggle-group">
                <input type="hidden" name="type" id="txType" value="grant">
                <div class="toggle-opt active grant" onclick="setMode('grant')">Grant</div>
                <div class="toggle-opt" onclick="setMode('refund')">Refund</div>
            </div>

            <div class="amount-display">
                <input type="number" name="amount" class="amount-input" value="100" min="1" required>
            </div>

            <div class="form-group">
                <label class="form-label">Beneficiary Email</label>
                <input type="email" name="email" class="terminal-input" placeholder="student@example.com" required>
            </div>

             <div class="form-group">
                <label class="form-label">Authorization Note</label>
                <textarea name="reason" class="terminal-input" rows="2" style="resize: none;" placeholder="Reason (Optional)"></textarea>
            </div>

            <button class="btn btn-primary" id="actionBtn" style="width: 100%; justify-content: center; padding: 15px; margin-top: 1rem; font-size: 1rem;">
                <i class="ri-fingerprint-line"></i> Authorize Transfer
            </button>
        </form>
    </div>

</div>

<script>
    function setMode(mode) {
        document.querySelectorAll('.toggle-opt').forEach(el => {
            el.classList.remove('active'); // Remove active from all
        });
        
        // Add active class to clicked element logic needs to be robust
        // Simple way: re-select by validation
        const target = event.target; 
        
        // This simple toggle logic in previous code had bugs with classList manipulation
        // Let's just hard reset
        if(mode === 'grant') {
             document.querySelector('.toggle-opt:nth-child(2)').classList.add('active', 'grant');
             document.querySelector('.toggle-opt:nth-child(3)').classList.remove('active', 'refund');
        } else {
             document.querySelector('.toggle-opt:nth-child(2)').classList.remove('active', 'grant');
             document.querySelector('.toggle-opt:nth-child(3)').classList.add('active', 'refund');
        }
        
        document.getElementById('txType').value = mode;
        
        const btn = document.getElementById('actionBtn');
        if(mode === 'refund') {
            btn.style.background = 'var(--brand-accent)';
            btn.innerHTML = '<i class="ri-refund-line"></i> Process Refund';
        } else {
            btn.style.background = 'var(--brand-gradient)';
            btn.innerHTML = '<i class="ri-fingerprint-line"></i> Authorize Transfer';
        }
    }
</script>
{% endblock %}
