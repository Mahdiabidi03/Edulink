{% extends 'admin_base.html.twig' %}

{% block title %}Challenges - Admin{% endblock %}

{% block content %}
<style>
    /* Challenges Grid Layout */
    .challenge-layout {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: var(--space-lg);
        height: calc(100vh - 180px); /* Fixed height for scrolling */
    }

    /* Challenge Card */
    .challenge-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.5rem;
        margin-bottom: 1rem;
        position: relative;
        transition: all 0.2s;
        box-shadow: var(--shadow-sm);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .challenge-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
        border-color: var(--brand-main);
    }

    /* Difficulty Colors */
    .diff-badge {
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
    }
    .diff-easy { background: rgba(34, 197, 94, 0.1); color: var(--success); }
    .diff-medium { background: rgba(245, 158, 11, 0.1); color: var(--warning); }
    .diff-hard { background: rgba(239, 68, 68, 0.1); color: var(--error); }
    
    /* Reward Box */
    .reward-box {
        display: flex;
        align-items: center;
        gap: 6px;
        background: rgba(202, 138, 4, 0.1);
        color: var(--brand-accent);
        padding: 6px 12px;
        border-radius: 20px;
        font-weight: 700;
        font-size: 0.9rem;
    }

    /* Type Badge */
    .type-badge {
        position: absolute;
        top: -10px;
        left: 20px;
        background: var(--bg-deep);
        color: white;
        padding: 2px 10px;
        border-radius: 10px;
        font-size: 0.7rem;
        font-weight: 600;
        border: 1px solid var(--border);
        box-shadow: var(--shadow-sm);
    }

    /* Right Panel: Challenge Builder */
    .challenge-editor {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        height: 100%;
        overflow-y: auto;
    }

    .form-group {
        margin-bottom: 1.2rem;
    }
    
    /* Scrollable List Container */
    .challenge-list-container {
        overflow-y: auto;
        padding-right: 10px;
        height: 100%;
    }

    /* Filters */
    .filter-bar {
        display: flex;
        gap: 10px;
        margin-bottom: 1rem;
    }
    
    .filter-chip {
        padding: 6px 16px;
        border-radius: 20px;
        border: 1px solid var(--border);
        background: var(--bg-card);
        color: var(--text-secondary);
        font-size: 0.85rem;
        cursor: pointer;
        transition: 0.2s;
    }
    .filter-chip.active {
        background: var(--brand-main);
        color: white;
        border-color: var(--brand-main);
    }

</style>

<!-- Header -->
<div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2rem;">
    <div>
        <h1 style="margin: 0; font-size: 2rem;">Challenges & Quests</h1>
        <p style="color: var(--text-muted); font-family: 'Fira Code', monospace; margin-top: 5px;">Gamify learning with custom quests</p>
    </div>
    
    <div style="display: flex; gap: 20px; align-items: center; background: var(--bg-card); padding: 10px 20px; border-radius: 12px; border: 1px solid var(--border);">
        <div style="text-align: center;">
            <div style="font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase;">Active</div>
            <div style="font-weight: 700; font-size: 1.1rem; color: var(--success);">24</div>
        </div>
        <div style="width: 1px; height: 30px; background: var(--border);"></div>
        <div style="text-align: center;">
            <div style="font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase;">Pending</div>
            <div style="font-weight: 700; font-size: 1.1rem; color: var(--warning);">8</div>
        </div>
    </div>
</div>

<div class="challenge-layout">
    
    <!-- LEFT: Challenge List -->
    <div style="display: flex; flex-direction: column; height: 100%;">
        
        <!-- Filters -->
        <div class="filter-bar">
            <div class="filter-chip active" onclick="filterList('all')">All Quest</div>
            <div class="filter-chip" onclick="filterList('official')">Official</div>
            <div class="filter-chip" onclick="filterList('community')">Community Created</div>
            <div class="filter-chip" onclick="filterList('pending')">Pending Review <span style="background: var(--warning); color: white; border-radius: 50%; width: 16px; height: 16px; display: inline-flex; justify-content: center; align-items: center; font-size: 0.6rem; margin-left: 5px;">8</span></div>
        </div>

        <div class="challenge-list-container">
            
            <!-- Pending Item 1 -->
            <div class="challenge-card" style="border-left: 4px solid var(--warning);">
                <div class="type-badge" style="background: var(--warning);">Pending Review</div>
                <div>
                    <h3 style="margin: 0 0 5px 0; font-size: 1.1rem;">Cybersecurity Basics Quiz</h3>
                    <p style="margin: 0; color: var(--text-secondary); font-size: 0.9rem;">Created by: <b>John Doe (Student)</b></p>
                    <div style="display: flex; gap: 10px; margin-top: 10px;">
                        <span class="diff-badge diff-easy">Easy</span>
                        <span style="font-size: 0.8rem; color: var(--text-muted);"><i class="ri-time-line"></i> 15 mins</span>
                    </div>
                </div>
                <div style="text-align: right;">
                    <div class="reward-box">+150 XP</div>
                    <div style="margin-top: 10px; display: flex; gap: 5px;">
                        <button class="icon-btn" style="color: var(--success); background: rgba(34, 197, 94, 0.1);" title="Approve"><i class="ri-check-line"></i></button>
                        <button class="icon-btn" style="color: var(--error); background: rgba(239, 68, 68, 0.1);" title="Reject"><i class="ri-close-line"></i></button>
                    </div>
                </div>
            </div>

            <!-- Official Item 1 -->
            <div class="challenge-card">
                 <div class="type-badge" style="background: var(--brand-main);">Official</div>
                <div>
                    <h3 style="margin: 0 0 5px 0; font-size: 1.1rem;">JS Algorithm Master</h3>
                    <p style="margin: 0; color: var(--text-secondary); font-size: 0.9rem;">Solve 5 complex LeetCode problems.</p>
                     <div style="display: flex; gap: 10px; margin-top: 10px;">
                        <span class="diff-badge diff-hard">Hard</span>
                        <span style="font-size: 0.8rem; color: var(--text-muted);"><i class="ri-calendar-line"></i> Ends in 2 days</span>
                    </div>
                </div>
                 <div style="text-align: right;">
                    <div class="reward-box">+1000 XP</div>
                    <button class="btn secondary" style="font-size: 0.8rem; padding: 4px 10px; margin-top: 10px;">Edit</button>
                </div>
            </div>

             <!-- Official Item 2 -->
            <div class="challenge-card">
                 <div class="type-badge" style="background: var(--brand-main);">Official</div>
                <div>
                    <h3 style="margin: 0 0 5px 0; font-size: 1.1rem;">Daily Login Streak</h3>
                    <p style="margin: 0; color: var(--text-secondary); font-size: 0.9rem;">Log in for 7 consecutive days.</p>
                     <div style="display: flex; gap: 10px; margin-top: 10px;">
                        <span class="diff-badge diff-easy">Easy</span>
                        <span style="font-size: 0.8rem; color: var(--text-muted);"><i class="ri-refresh-line"></i> Repeating</span>
                    </div>
                </div>
                 <div style="text-align: right;">
                    <div class="reward-box">+50 pts</div>
                    <button class="btn secondary" style="font-size: 0.8rem; padding: 4px 10px; margin-top: 10px;">Edit</button>
                </div>
            </div>

        </div>
    </div>

    <!-- RIGHT: Challenge Builder -->
    <div class="challenge-editor">
        <h3 style="margin: 0 0 1.5rem 0; border-bottom: 1px solid var(--border); padding-bottom: 1rem;">
            <i class="ri-edit-circle-line" style="color: var(--brand-accent);"></i> Challenge Builder
        </h3>

        <form>
            <div class="form-group">
                <label style="display: block; font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 5px;">Challenge Title</label>
                <input type="text" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid var(--border); background: var(--bg-main); color: var(--text-main); outline: none;" placeholder="Ex. Speed Coding">
            </div>

            <div class="form-group">
                <label style="display: block; font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 5px;">Description</label>
                <textarea style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid var(--border); background: var(--bg-main); color: var(--text-main); outline: none; height: 80px; resize: none;" placeholder="Explain the rules..."></textarea>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                <div class="form-group">
                    <label style="display: block; font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 5px;">Difficulty</label>
                    <select style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid var(--border); background: var(--bg-main); color: var(--text-main); outline: none;">
                        <option>Easy</option>
                        <option>Medium</option>
                        <option>Hard</option>
                        <option>Expert</option>
                    </select>
                </div>
                <div class="form-group">
                    <label style="display: block; font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 5px;">Category</label>
                    <select style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid var(--border); background: var(--bg-main); color: var(--text-main); outline: none;">
                        <option>Quiz</option>
                        <option>Coding</option>
                        <option>Social</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label style="display: block; font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 5px;">Reward (XP/Points)</label>
                <div style="position: relative;">
                    <i class="ri-copper-coin-line" style="position: absolute; left: 10px; top: 12px; color: var(--brand-accent);"></i>
                    <input type="number" style="width: 100%; padding: 10px 10px 10px 35px; border-radius: 8px; border: 1px solid var(--border); background: var(--bg-main); color: var(--text-main); outline: none;" value="100">
                </div>
            </div>
            
            <div class="form-group">
                <label style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                    <input type="checkbox" style="width: 16px; height: 16px;">
                    <span style="font-size: 0.9rem;">Auto-Approve Submissions</span>
                </label>
            </div>

            <div style="margin-top: auto; display: flex; gap: 10px;">
                <button type="button" class="btn secondary" style="flex: 1;">Clear</button>
                <button type="submit" class="btn btn-primary" style="flex: 1;">Create Quest</button>
            </div>
        </form>
    </div>

</div>

<script>
    function filterList(type) {
        document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
        event.target.classList.add('active');
        // Filter logic would go here
    }
</script>
{% endblock %}
