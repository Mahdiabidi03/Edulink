{% extends 'admin_base.html.twig' %}

{% block title %}Assistance Center - Admin{% endblock %}

{% block content %}
<style>
    /* Inbox Layout */
    .inbox-layout {
        display: grid;
        grid-template-columns: 350px 1fr;
        gap: var(--space-lg);
        height: calc(100vh - 140px);
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
    }

    /* Left Sidebar: Message List */
    .inbox-sidebar {
        border-right: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        background: var(--bg-main);
    }
    
    .inbox-header {
        padding: 1.5rem;
        border-bottom: 1px solid var(--border);
    }
    
    .msg-list {
        overflow-y: auto;
        flex: 1;
    }

    .msg-item {
        padding: 1.2rem;
        border-bottom: 1px solid var(--border-light);
        cursor: pointer;
        transition: background 0.2s;
        position: relative;
    }
    .msg-item:hover {
        background: rgba(255,255,255,0.5);
    }
    .msg-item.active {
        background: rgba(99, 102, 241, 0.05); /* Light Indigo tint */
        border-left: 3px solid var(--brand-main);
    }
    .msg-item.unread::after {
        content: '';
        position: absolute;
        top: 1.5rem;
        right: 1.2rem;
        width: 8px;
        height: 8px;
        background: var(--brand-accent);
        border-radius: 50%;
    }

    .msg-avatar {
        width: 32px; 
        height: 32px; 
        border-radius: 50%; 
        background: var(--border); 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        font-size: 0.8rem; 
        color: var(--text-secondary);
    }

    /* Right Panel: Chat/Details */
    .inbox-content {
        display: flex;
        flex-direction: column;
        background: var(--bg-card);
    }

    .chat-header {
        padding: 1.5rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: rgba(255,255,255,0.5);
        backdrop-filter: blur(10px);
    }

    .chat-body {
        flex: 1;
        padding: 2rem;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        background: var(--bg-main);
    }

    .message-bubble {
        max-width: 70%;
        padding: 1rem;
        border-radius: 12px;
        font-size: 0.95rem;
        line-height: 1.5;
        position: relative;
    }
    .msg-received {
        align-self: flex-start;
        background: white;
        border: 1px solid var(--border);
        border-bottom-left-radius: 2px;
    }
    .msg-sent {
        align-self: flex-end;
        background: var(--brand-main);
        color: white;
        border-bottom-right-radius: 2px;
    }

    .chat-footer {
        padding: 1.5rem;
        border-top: 1px solid var(--border);
        background: white;
        display: flex;
        gap: 1rem;
        align-items: flex-end;
    }

    .reply-input {
        flex: 1;
        border: 1px solid var(--border);
        background: var(--bg-main);
        padding: 1rem;
        border-radius: 8px;
        resize: none;
        font-family: 'Fira Sans', sans-serif;
        outline: none;
        transition: 0.2s;
    }
    .reply-input:focus {
        border-color: var(--brand-main);
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
    }

    /* Status Tags */
    .status-badge {
        font-size: 0.75rem;
        padding: 4px 8px;
        border-radius: 4px;
        font-weight: 600;
        text-transform: uppercase;
    }
    .status-open { background: rgba(239, 68, 68, 0.1); color: var(--error); }
    .status-resolved { background: rgba(34, 197, 94, 0.1); color: var(--success); }

</style>

<!-- Header -->
<div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: var(--space-xl);">
    <div>
        <h1 style="margin: 0; font-size: 2rem;">Support Inbox</h1>
        <p style="color: var(--text-muted); font-family: 'Fira Code', monospace; margin-top: 5px;">
            <i class="ri-mail-unread-line"></i> 5 Unresolved Tickets
        </p>
    </div>
</div>

<div class="inbox-layout">
    
    <!-- Sidebar -->
    <div class="inbox-sidebar">
        <div class="inbox-header">
            <div style="position: relative;">
                <i class="ri-search-line" style="position: absolute; left: 12px; top: 10px; color: var(--text-muted);"></i>
                <input type="text" placeholder="Search tickets..." style="width: 100%; padding: 8px 8px 8px 36px; border-radius: 8px; border: 1px solid var(--border); background: var(--bg-card); outline: none;">
            </div>
        </div>
        
        <div class="msg-list">
            <!-- Item 1 -->
            <div class="msg-item active unread" onclick="loadTicket(1)">
                <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <div class="msg-avatar" style="background: #e0e7ff; color: #6366f1;">JD</div>
                        <span style="font-weight: 600; font-size: 0.9rem;">John Doe</span>
                    </div>
                    <span style="font-size: 0.75rem; color: var(--text-muted);">2m ago</span>
                </div>
                <div style="font-weight: 500; font-size: 0.9rem; margin-bottom: 4px;">Database Connection Issue</div>
                <div style="font-size: 0.8rem; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                    I can't seem to connect to the SQL server...
                </div>
            </div>

            <!-- Item 2 -->
            <div class="msg-item unread" onclick="loadTicket(2)">
                <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <div class="msg-avatar" style="background: #fef3c7; color: #d97706;">SS</div>
                        <span style="font-weight: 600; font-size: 0.9rem;">Sarah Smith</span>
                    </div>
                    <span style="font-size: 0.75rem; color: var(--text-muted);">1h ago</span>
                </div>
                <div style="font-weight: 500; font-size: 0.9rem; margin-bottom: 4px;">Course Content Error</div>
                <div style="font-size: 0.8rem; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                    Typo in module 3, slide 4 regarding variables...
                </div>
            </div>

             <!-- Item 3 -->
            <div class="msg-item" onclick="loadTicket(3)">
                <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <div class="msg-avatar">AM</div>
                        <span style="font-weight: 600; font-size: 0.9rem;">Alex Morgan</span>
                    </div>
                    <span style="font-size: 0.75rem; color: var(--text-muted);">1d ago</span>
                </div>
                <div style="font-weight: 500; font-size: 0.9rem; margin-bottom: 4px; color: var(--text-muted);">Account Verification</div>
                <div style="font-size: 0.8rem; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                    Can you check my tutor application status?
                </div>
            </div>
        </div>
    </div>

    <!-- Content Area -->
    <div class="inbox-content">
        
        <!-- Chat Header -->
        <div class="chat-header">
            <div>
                <h2 style="margin: 0; font-size: 1.1rem;">Database Connection Issue</h2>
                 <div style="display: flex; gap: 10px; margin-top: 5px; font-size: 0.85rem; color: var(--text-secondary);">
                    <span>Ticket #8821</span>
                    <span>•</span>
                    <span class="status-badge status-open">Open</span>
                 </div>
            </div>
            <div style="display: flex; gap: 10px;">
                <button class="btn secondary" title="Mark as Resolved"><i class="ri-checkbox-circle-line"></i> Resolve</button>
                <button class="icon-btn" title="More Options"><i class="ri-more-2-fill"></i></button>
            </div>
        </div>

        <!-- Chat Body -->
        <div class="chat-body">
            <div style="text-align: center; margin: 1rem 0;">
                <span style="background: var(--border); padding: 4px 12px; border-radius: 12px; font-size: 0.75rem; color: var(--text-secondary);">Today</span>
            </div>

            <!-- Student Msg -->
            <div class="message-bubble msg-received">
                <strong>John Doe:</strong> <br>
                Hi support, I'm trying to complete the "MySQL Basics" project but I keep getting an "Access Denied" error when connecting to the playground server. Can you help?
                <div style="font-size: 0.7rem; color: var(--text-muted); margin-top: 5px; text-align: right;">10:30 AM</div>
            </div>

            <!-- System Auto-Reply -->
             <div class="message-bubble msg-received" style="background: #f8fafc; border: 1px dashed var(--border);">
                <strong style="color: var(--brand-main);"><i class="ri-robot-line"></i> EduBot:</strong> <br>
                Hello John! I've logged your request. An admin will review your server credentials shortly.
                <div style="font-size: 0.7rem; color: var(--text-muted); margin-top: 5px; text-align: right;">10:31 AM</div>
            </div>
        </div>

        <!-- Chat Footer (Reply) -->
        <div class="chat-footer">
            <button class="icon-btn"><i class="ri-attachment-2"></i></button>
            <textarea class="reply-input" rows="1" placeholder="Type your reply..."></textarea>
            <button class="btn btn-primary" style="padding: 0 20px;"><i class="ri-send-plane-fill"></i></button>
        </div>

    </div>
</div>

<script>
    function loadTicket(id) {
        // Highlight active item
        document.querySelectorAll('.msg-item').forEach(i => i.classList.remove('active'));
        event.currentTarget.classList.add('active');
        
        // In a real app, this would fetch data via AJAX
        // For now, we just simulate updating the view
    }
</script>
{% endblock %}
