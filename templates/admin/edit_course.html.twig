{% extends 'admin_base.html.twig' %}

{% block title %}Edit Course - {{ cours.title }}{% endblock %}

{% block content %}
<div style="max-width: 900px; margin: 2rem auto; padding: 0 1rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <a href="{{ path('app_admin_category_manage', {'id': cours.matiere.id}) }}" style="color: var(--text-secondary); text-decoration: none; margin-bottom: 0.5rem; display: inline-block;">← Back to Category</a>
            <h1 style="color: #2c3e50; margin:0;">Edit Course: {{ cours.title }}</h1>
        </div>
        <div style="display: flex; gap: 10px;">
            <form method="post" action="{{ path('app_admin_course_delete', {'id': cours.id}) }}" onsubmit="return confirm('Are you sure you want to delete this course? This will also delete all its resources.');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ cours.id) }}">
                <button type="submit" class="btn" style="background: var(--error); color: white; padding: 10px 20px; border-radius: 6px; font-weight: 500;">Delete Course</button>
            </form>
        </div>
    </div>

    <div class="card" style="background: white; padding: 2.5rem; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border: 1px solid #e1e8ed;">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            
            <!-- Title Section -->
            <div style="margin-bottom: 2rem;">
                {{ form_label(form.title, 'Course Title', {'label_attr': {'style': 'font-weight: 600; display: block; margin-bottom: 0.5rem; color: #34495e;'}}) }}
                {{ form_widget(form.title, {'attr': {'class': 'form-control', 'style': 'width: 100%; padding: 12px; border: 1px solid #bdc3c7; border-radius: 6px; font-size: 1rem;'}}) }}
                {{ form_errors(form.title) }}
            </div>

            <!-- Description Section -->
            <div style="margin-bottom: 2rem;">
                {{ form_label(form.description, 'Description', {'label_attr': {'style': 'font-weight: 600; display: block; margin-bottom: 0.5rem; color: #34495e;'}}) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'style': 'width: 100%; padding: 12px; border: 1px solid #bdc3c7; border-radius: 6px; font-size: 1rem; min-height: 120px; resize: vertical;'}}) }}
                {{ form_errors(form.description) }}
            </div>

            <div style="margin-bottom: 2rem;">
                {{ form_label(form.xp, 'Course XP (Earned on completion)', {'label_attr': {'style': 'font-weight: 600; display: block; margin-bottom: 0.5rem; color: #34495e;'}}) }}
                {{ form_widget(form.xp, {'attr': {'class': 'form-control', 'style': 'width: 100%; padding: 12px; border: 1px solid #bdc3c7; border-radius: 6px; font-size: 1rem;'}}) }}
                {{ form_errors(form.xp) }}
            </div>

            <div style="margin-bottom: 2rem;">
                {{ form_label(form.level, 'Difficulty Level', {'label_attr': {'style': 'font-weight: 600; display: block; margin-bottom: 0.5rem; color: #34495e;'}}) }}
                {{ form_widget(form.level, {'attr': {'class': 'form-control', 'style': 'width: 100%; padding: 12px; border: 1px solid #bdc3c7; border-radius: 6px; font-size: 1rem;'}}) }}
                {{ form_errors(form.level) }}
            </div>

            <div style="display: flex; gap: 1rem;">
                <button type="submit" class="btn btn-primary" style="flex: 1; padding: 14px; border: none; border-radius: 6px; font-size: 1.1rem; font-weight: 600; cursor: pointer;">
                    Save Changes
                </button>
                <a href="{{ path('app_admin_category_manage', {'id': cours.matiere.id}) }}" class="btn secondary" style="flex: 1; text-align: center; padding: 14px; text-decoration: none;">Cancel</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
