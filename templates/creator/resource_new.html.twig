{% extends 'base.html.twig' %}

{% block title %}Add Resource - {{ cours.title }}{% endblock %}

{% block content %}
<div style="max-width: 800px; margin: 0 auto; padding: 2rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1>Add Resource</h1>
            <p style="color: #666; margin-top: 0.5rem;">For course: <strong>{{ cours.title }}</strong></p>
        </div>
        <a href="{{ path('app_creator_course_manage', {'id': cours.id}) }}" class="btn secondary" style="background: var(--text-secondary); color: white; padding: 8px 16px; text-decoration: none; border-radius: 4px;">Cancel</a>
    </div>

    <div class="card" style="padding: 2.5rem; background: var(--bg-card); border-radius: 12px; box-shadow: var(--shadow-lg);">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            
            <div style="margin-bottom: 2rem;">
                {{ form_label(form.title, 'Resource Title', {'label_attr': {'style': 'font-weight: 600; display: block; margin-bottom: 0.75rem; color: var(--text-main);'}}) }}
                {{ form_widget(form.title, {'attr': {
                    'class': 'form-control', 
                    'style': 'width: 100%; padding: 12px; border: 1px solid var(--border); border-radius: 8px; background: var(--bg-card); color: var(--text-main);',
                    'placeholder': 'e.g. Chapter 1: Introduction'
                }}) }}
                {{ form_errors(form.title) }}
            </div>

            <div style="margin-bottom: 2rem;">
                {{ form_label(form.type, 'Resource Type', {'label_attr': {'style': 'font-weight: 600; display: block; margin-bottom: 0.75rem; color: var(--text-main);'}}) }}
                {{ form_widget(form.type, {'attr': {
                    'class': 'form-control', 
                    'style': 'width: 100%; padding: 12px; border: 1px solid var(--border); border-radius: 8px; background: var(--bg-card); color: var(--text-main);',
                    'onchange': 'toggleResourceType(this.value)'
                }}) }}
                {{ form_errors(form.type) }}
            </div>

            <div id="url-group" style="margin-bottom: 2rem;">
                {{ form_label(form.url, 'Video URL or ID', {'label_attr': {'style': 'font-weight: 600; display: block; margin-bottom: 0.75rem; color: var(--text-main);'}}) }}
                {{ form_widget(form.url, {'attr': {
                    'class': 'form-control', 
                    'style': 'width: 100%; padding: 12px; border: 1px solid var(--border); border-radius: 8px; background: var(--bg-card); color: var(--text-main);',
                    'placeholder': 'https://www.youtube.com/watch?v=...'
                }}) }}
                <p style="color: var(--text-secondary); font-size: 0.85rem; margin-top: 0.75rem;">
                    <i class="ri-information-line"></i> Paste the full YouTube link or the Video ID.
                </p>
                {{ form_errors(form.url) }}
            </div>

            <div id="file-group" style="margin-bottom: 2rem; display: none;">
                <label style="font-weight: 600; display: block; margin-bottom: 0.75rem; color: var(--text-main);">Upload File</label>
                <div class="file-upload-wrapper" style="border: 2px dashed var(--border); padding: 2rem; border-radius: 12px; text-align: center; transition: all 0.3s; cursor: pointer;" onmouseover="this.style.borderColor='var(--brand-main)'; this.style.background='rgba(99, 102, 241, 0.05)'" onmouseout="this.style.borderColor='var(--border)'; this.style.background='transparent'">
                    <label for="{{ form.file.vars.id }}" style="cursor: pointer; display: block; width: 100%;">
                        <i class="ri-file-upload-line" style="font-size: 2.5rem; color: var(--brand-main); display: block; margin-bottom: 1rem;"></i>
                        <span id="filename-display" style="color: var(--text-secondary); font-weight: 500;">Click to browse file</span>
                    </label>
                    {{ form_widget(form.file, {
                        'attr': {
                            'class': 'file-upload-input',
                            'style': 'display: none;',
                            'onchange': 'updateFileNameResource(this)'
                        }
                    }) }}
                </div>
                {{ form_errors(form.file) }}
            </div>

            <button type="submit" class="btn" style="width: 100%; background: var(--brand-gradient); color: white; padding: 14px; border: none; border-radius: 10px; cursor: pointer; font-size: 1.1rem; font-weight: 700; box-shadow: var(--shadow-neon); margin-top: 1rem;">
                Add Resource & Finish
            </button>
        {{ form_end(form) }}
    </div>
</div>

<script>
function toggleResourceType(type) {
    const urlGroup = document.getElementById('url-group');
    const fileGroup = document.getElementById('file-group');
    
    if (type === 'VIDEO') {
        urlGroup.style.display = 'block';
        fileGroup.style.display = 'none';
    } else {
        urlGroup.style.display = 'none';
        fileGroup.style.display = 'block';
    }
}

function updateFileNameResource(input) {
    const display = document.getElementById('filename-display');
    if (input.files && input.files[0]) {
        display.textContent = input.files[0].name;
        display.style.color = 'var(--brand-main)';
        display.style.fontWeight = 'bold';
    }
}

// Initial call
document.addEventListener('DOMContentLoaded', () => {
    toggleResourceType(document.querySelector('select[name*="[type]"]').value);
});
</script>
{% endblock %}
