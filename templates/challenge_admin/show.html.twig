{% extends 'base.html.twig' %}

{% block title %}Challenge #{{ challenge.id }}{% endblock %}

{% block body %}
<div style="padding: 24px; max-width: 900px; margin: 0 auto;">
  <div style="display:flex; justify-content: space-between; align-items:center; margin-bottom: 16px;">
    <div>
      <h1 style="margin:0; font-size: 1.4rem;">Challenge #{{ challenge.id }}</h1>
      <div style="color: var(--text-muted); font-size: .9rem;">Details</div>
    </div>

    <div style="display:flex; gap: 10px;">
      <a href="{{ path('app_challenge_admin_edit', {id: challenge.id}) }}"
         style="padding: 10px 14px; border-radius: 10px; background: var(--brand-accent); color: white; text-decoration:none;">
        Edit
      </a>
      <a href="{{ path('app_challenge_admin_index') }}"
         style="padding: 10px 14px; border-radius: 10px; border: 1px solid var(--border); color: var(--text-main); text-decoration:none;">
        Back
      </a>
    </div>
  </div>

  <div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; padding: 16px;">
    <div style="display:grid; gap: 10px;">
      <div>
        <div style="color: var(--text-muted); font-size: .85rem;">Title</div>
        <div style="font-weight: 600;">{{ challenge.title }}</div>
      </div>

      <div>
        <div style="color: var(--text-muted); font-size: .85rem;">Goal</div>
        <div>{{ challenge.goal }}</div>
      </div>

      <div>
        <div style="color: var(--text-muted); font-size: .85rem;">Reward</div>
        <span style="display:inline-block; padding: 6px 10px; border-radius: 999px; background: rgba(34,197,94,.12); color: rgba(34,197,94,1); font-weight: 600;">
          {{ challenge.rewardPoints }} pts
        </span>
      </div>
    </div>
  </div>

  <div style="margin-top: 14px;">
    {{ include('challenge_admin/_delete_form.html.twig') }}
  </div>
</div>
{% endblock %}
