{% extends 'admin_base.html.twig' %}

{% block title %}Modifier la Tâche{% endblock %}

{% block content %}
<div style="padding: 24px; max-width: 700px; margin: 0 auto;">
  <div style="display:flex; justify-content: space-between; align-items:center; margin-bottom: 16px;">
    <div>
      <h1 style="margin:0; font-size: 1.4rem; color: var(--text-main);">Modifier la tâche</h1>
      <div style="color: var(--text-muted); font-size: .9rem;">{{ task.title }}</div>
    </div>

    <div style="display:flex; gap: 10px; align-items:center;">
      <a href="{{ path('app_challenge_admin_edit', {id: challenge.id}) }}" class="btn secondary">
        <i data-lucide="arrow-left"></i> Retour au challenge
      </a>
    </div>
  </div>

  <div class="card" style="padding: 2rem;">
    {{ form_start(form) }}
        {{ form_widget(form) }}
        <div style="margin-top: 2rem;">
            <button class="btn" style="width: 100%;">Mettre à jour la tâche</button>
        </div>
    {{ form_end(form) }}

    <hr style="margin: 2rem 0; border-color: var(--border);">

    <form method="post" action="{{ path('app_challenge_admin_task_delete', {'id': task.id}) }}" onsubmit="return confirm('Supprimer cette tâche ?');">
        <input type="hidden" name="_token" value="{{ csrf_token('delete_task' ~ task.id) }}">
        <button class="btn" style="background: var(--error); color: white; width: 100%;">Supprimer la tâche</button>
    </form>
  </div>
</div>
{% endblock %}
