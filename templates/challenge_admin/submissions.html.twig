{% extends 'admin_base.html.twig' %}

{% block title %}Soumissions en attente{% endblock %}

{% block content %}
<div style="padding: 2rem; max-width: 1200px; margin: 0 auto;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1 style="margin: 0; font-size: 1.8rem; font-weight: 700; color: var(--text-main);">Soumissions en attente</h1>
            <p style="color: var(--text-secondary); margin-top: 0.5rem;">Review student proofs to award XP points.</p>
        </div>

        <a href="{{ path('app_challenge_admin_index') }}" class="btn secondary">
            <i data-lucide="arrow-left"></i> Back to Challenges
        </a>
    </div>

    <div class="card" style="overflow: hidden;">
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: var(--bg-main); border-bottom: 1px solid var(--border);">
                    <th style="padding: 1rem; text-align: left; font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">ID</th>
                    <th style="padding: 1rem; text-align: left; font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">CHALLENGE</th>
                    <th style="padding: 1rem; text-align: left; font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">STUDENT</th>
                    <th style="padding: 1rem; text-align: left; font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">PROOF</th>
                    <th style="padding: 1rem; text-align: right; font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                {% for s in submissions %}
                    <tr style="border-bottom: 1px solid var(--border);">
                        <td style="padding: 1rem; color: var(--text-muted); font-family: monospace;">#{{ s.id }}</td>
                        <td style="padding: 1rem;">
                            <div style="font-weight: 600; color: var(--text-main);">{{ s.challenge.title }}</div>
                            <div class="wallet-badge" style="background: rgba(139, 92, 246, 0.1); color: var(--brand-main); font-size: 0.75rem; margin-top: 4px; display: inline-flex;">+{{ s.challenge.rewardPoints }} XP</div>
                        </td>
                        <td style="padding: 1rem;">
                            <div style="font-weight: 600; color: var(--text-main);">{{ s.user.fullName }}</div>
                            <div style="font-size: 0.8rem; color: var(--text-secondary);">{{ s.user.email }}</div>
                        </td>
                        <td style="padding: 1rem;">
                            {% if s.proofFileName %}
                                <a href="{{ asset('uploads/proofs/' ~ s.proofFileName) }}" target="_blank" class="btn secondary" style="padding: 6px 12px; font-size: 0.8rem;">
                                    <i data-lucide="file-text"></i> Voir fichier
                                </a>
                            {% else %}
                                <span style="color: var(--text-muted); font-size: 0.85rem;">Aucun fichier</span>
                            {% endif %}
                        </td>
                        <td style="padding: 1rem; text-align: right;">
                            <div style="display: flex; justify-content: flex-end; gap: 8px;">
                                {# ✅ VALIDER #}
                                <form method="post" action="{{ path('admin_validate_submission', {id: s.id}) }}" onsubmit="return confirm('Valider cette soumission ? Les points seront crédités.')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('validate_' ~ s.id) }}">
                                    <button type="submit" class="btn" style="background: rgba(16, 185, 129, 0.1); color: var(--success); border: none; padding: 6px 12px; font-size: 0.85rem;">
                                        <i data-lucide="check"></i> Valider
                                    </button>
                                </form>

                                {# ❌ REFUSER #}
                                <form method="post" action="{{ path('admin_reject_submission', {id: s.id}) }}" onsubmit="return confirm('Refuser cette soumission ? Le challenge repasse en IN_PROGRESS.')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('reject_' ~ s.id) }}">
                                    <button type="submit" class="btn" style="background: rgba(239, 68, 68, 0.1); color: var(--error); border: none; padding: 6px 12px; font-size: 0.85rem;">
                                        <i data-lucide="x"></i> Refuser
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" style="padding: 3rem; text-align: center; color: var(--text-muted);">Aucune soumission en attente.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
