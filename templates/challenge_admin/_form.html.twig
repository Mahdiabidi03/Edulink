{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

<div style="display:grid; gap: 20px;">
  <div style="display:grid; gap: 15px;">
    <div class="form-group">
      {{ form_label(form.title, null, {'label_attr': {'class': 'form-label'}}) }}
      {{ form_widget(form.title, {'attr': {'class': 'form-input', 'placeholder': 'Ex: Master React Hooks'}}) }}
      <div style="color: var(--error); font-size: 0.8rem; margin-top: 4px;">
        {{ form_errors(form.title) }}
      </div>
    </div>

    <div class="form-group">
      {{ form_label(form.goal, null, {'label_attr': {'class': 'form-label'}}) }}
      {{ form_widget(form.goal, {'attr': {'class': 'form-input', 'placeholder': 'Describe what needs to be done...', 'rows': 4}}) }}
      <div style="color: var(--error); font-size: 0.8rem; margin-top: 4px;">
        {{ form_errors(form.goal) }}
      </div>
    </div>

    <div class="form-group">
      {{ form_label(form.rewardPoints, null, {'label_attr': {'class': 'form-label'}}) }}
      {{ form_widget(form.rewardPoints, {'attr': {'class': 'form-input', 'placeholder': 'Points to earn'}}) }}
      <div style="color: var(--error); font-size: 0.8rem; margin-top: 4px;">
        {{ form_errors(form.rewardPoints) }}
      </div>
    </div>
  </div>

  <div style="display:flex; justify-content:flex-end; gap: 12px; margin-top: 10px;">
    <a href="{{ path('app_challenge_admin_index') }}" class="btn secondary">
      Cancel
    </a>
    <button type="submit" class="btn">
      <i data-lucide="save"></i> {{ button_label|default('Save') }}
    </button>
  </div>
</div>

{{ form_end(form) }}
