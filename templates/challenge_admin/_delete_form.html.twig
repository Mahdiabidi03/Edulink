<form method="post"
      action="{{ path('app_challenge_admin_delete', {'id': challenge.id}) }}"
      onsubmit="return confirm('Are you sure you want to delete this challenge?');"
      style="display:inline-block;">
  <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ challenge.id) }}">
  <button style="padding: 10px 14px; border-radius: 10px; border: 1px solid rgba(239,68,68,.35); background: rgba(239,68,68,.10); color: rgba(239,68,68,1); cursor:pointer;">
    Delete
  </button>
</form>
