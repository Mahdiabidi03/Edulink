{% extends 'admin_base.html.twig' %}

{% block title %}Challenges — Admin{% endblock %}

{% block content %}
<style>
    .search-bar-container {
        display: flex;
        gap: 12px;
        align-items: center;
        margin-bottom: 2rem;
        background: #111827; /* Darker background like the image */
        padding: 1.5rem;
        border-radius: 16px;
        border: 1px solid #374151;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }

    .search-wrapper {
        position: relative;
        flex: 1;
        max-width: 400px;
        display: flex;
        align-items: center;
    }

    .search-wrapper i {
        position: absolute;
        left: 16px;
        color: #9ca3af;
        width: 18px;
        height: 18px;
        z-index: 10;
        pointer-events: none;
    }

    .search-wrapper input {
        width: 100%;
        padding: 10px 16px 10px 44px !important;
        background: #1f2937 !important;
        border: 1px solid #374151 !important;
        color: #f3f4f6 !important;
        border-radius: 8px !important;
        font-size: 0.95rem;
        transition: all 0.2s;
    }

    .search-wrapper input:focus {
        border-color: #8b5cf6 !important;
        outline: none;
        box-shadow: 0 0 0 2px rgba(139, 92, 246, 0.2);
    }

    .filters-wrapper {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .filter-select {
        background: #1f2937 !important;
        border: 1px solid #374151 !important;
        color: #f3f4f6 !important;
        padding: 10px 32px 10px 16px !important;
        border-radius: 8px !important;
        cursor: pointer;
        font-size: 0.95rem;
    }

    .btn-search {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #8b5cf6 !important;
        color: white !important;
        padding: 10px 24px !important;
        border-radius: 8px !important;
        font-weight: 600;
        border: none !important;
        transition: all 0.2s;
        cursor: pointer;
    }

    .btn-search:hover {
        background: #7c3aed !important;
        transform: translateY(-1px);
    }

    .btn-clear {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #374151 !important;
        color: #f3f4f6 !important;
        padding: 10px 20px !important;
        border-radius: 8px !important;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-clear:hover {
        background: #4b5563 !important;
    }
</style>

<div style="padding: 2rem; max-width: 1200px; margin: 0 auto;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1 style="margin: 0; font-size: 1.8rem; font-weight: 700; color: var(--text-main);">Gestion des Challenges</h1>
            <p style="color: var(--text-secondary); margin-top: 0.5rem;">Create and manage challenges for students.</p>
        </div>

        <div style="display: flex; gap: 1rem;">
            <a href="{{ path('admin_submissions') }}" class="btn secondary">
                <i data-lucide="inbox"></i> Submissions
            </a>
            <a href="{{ path('app_challenge_admin_new') }}" class="btn">
                <i data-lucide="plus"></i> New Challenge
            </a>
        </div>
    </div>

    {# Improved Search bar and Filters #}
    <form method="get" action="{{ path('app_challenge_admin_index') }}" class="search-bar-container">
        <div class="search-wrapper">
            <i data-lucide="search"></i>
            <input type="text" name="q" value="{{ q|default('') }}" placeholder="Search by title or goal...">
        </div>
        
        <div class="filters-wrapper">
            <select name="order" class="filter-select" style="min-width: 250px;">
                <option value="newest" {{ order == 'newest' ? 'selected' : '' }}>Most Recent</option>
                <option value="alpha_asc" {{ order == 'alpha_asc' ? 'selected' : '' }}>Ordre alphabétique (A-Z)</option>
                <option value="alpha_desc" {{ order == 'alpha_desc' ? 'selected' : '' }}>Ordre alphabétique (Z-A)</option>
                <option value="xp_desc" {{ order == 'xp_desc' ? 'selected' : '' }}>XP rewarded (High to Low)</option>
                <option value="xp_asc" {{ order == 'xp_asc' ? 'selected' : '' }}>XP rewarded (Low to High)</option>
            </select>

            <button type="submit" class="btn-search">
                <i data-lucide="search" style="width: 18px; height: 18px;"></i>
                <span>Search</span>
            </button>

            {% if q or order != 'newest' %}
                <a href="{{ path('app_challenge_admin_index') }}" class="btn-clear">
                    <i data-lucide="rotate-ccw" style="width: 18px; height: 18px;"></i>
                    <span>Clear</span>
                </a>
            {% endif %}
        </div>
    </form>

    <div class="card" style="overflow: hidden;">
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: var(--bg-main); border-bottom: 1px solid var(--border);">
                    <th style="padding: 1rem; text-align: left; font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">ID</th>
                    <th style="padding: 1rem; text-align: left; font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">TITLE</th>
                    <th style="padding: 1rem; text-align: left; font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">GOAL</th>
                    <th style="padding: 1rem; text-align: left; font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">TASKS</th>
                    <th style="padding: 1rem; text-align: left; font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">REWARD</th>
                    <th style="padding: 1rem; text-align: right; font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                {% for challenge in challenges %}
                    <tr style="border-bottom: 1px solid var(--border);">
                        <td style="padding: 1rem; color: var(--text-muted); font-family: monospace;">#{{ challenge.id }}</td>
                        <td style="padding: 1rem; font-weight: 600; color: var(--text-main);">{{ challenge.title }}</td>
                        <td style="padding: 1rem; color: var(--text-secondary); max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{ challenge.goal }}</td>
                        <td style="padding: 1rem;">
                            <span style="font-size: 0.9rem; font-weight: 500;">
                                <i data-lucide="list-checks" style="width: 16px; height: 16px; vertical-align: middle; margin-right: 4px;"></i>
                                {{ challenge.tasks|length }} tasks
                            </span>
                        </td>
                        <td style="padding: 1rem;">
                            <span class="wallet-badge" style="background: rgba(139, 92, 246, 0.1); color: var(--brand-main); font-weight: 700;">+{{ challenge.rewardPoints }} XP</span>
                        </td>
                        <td style="padding: 1rem; text-align: right;">
                            <div style="display: flex; justify-content: flex-end; gap: 8px;">
                                <a href="{{ path('app_challenge_admin_edit', {id: challenge.id}) }}" class="btn secondary" style="padding: 6px; min-width: auto;" title="Edit">
                                    <i data-lucide="edit-3" style="width: 18px; height: 18px;"></i>
                                </a>
                                {{ include('challenge_admin/_delete_form.html.twig') }}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" style="padding: 3rem; text-align: center; color: var(--text-muted);">No challenges found.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
