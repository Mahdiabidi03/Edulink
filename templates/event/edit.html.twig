{% extends 'base.html.twig' %}

{% block title %}Edit Event - {{ event.title }}{% endblock %}

{% block content %}
<div style="max-width: 700px; margin: 2rem auto; padding: 1.5rem;">

    <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
        <a href="{{ path('app_event_index') }}" style="color: var(--text-secondary, #94a3b8); text-decoration: none; font-size: 1.2rem;">←</a>
        <h1 style="margin: 0; font-size: 1.6rem; font-weight: 700;">Edit Event</h1>
    </div>

    {% for flash in app.flashes('error') %}
        <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3); color: #ef4444; padding: 12px 16px; border-radius: 12px; margin-bottom: 1rem; font-size: 0.9rem;">
            ⚠️ {{ flash }}
        </div>
    {% endfor %}

    <form method="POST" action="{{ path('app_event_edit', {'id': event.id}) }}" enctype="multipart/form-data" style="display: flex; flex-direction: column; gap: 1.2rem;">

        <div>
            <label style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 6px; color: var(--text-secondary, #94a3b8);">Title *</label>
            <input type="text" name="title" value="{{ event.title }}" required minlength="3" maxlength="255"
                   style="width: 100%; padding: 10px 14px; border-radius: 10px; border: 1px solid var(--border, rgba(255,255,255,0.1)); background: var(--bg-card, rgba(255,255,255,0.05)); color: var(--text-main, #e2e8f0); font-size: 0.95rem; outline: none;">
        </div>

        <div>
            <label style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 6px; color: var(--text-secondary, #94a3b8);">Description</label>
            <textarea name="description" rows="4" maxlength="5000"
                      style="width: 100%; padding: 10px 14px; border-radius: 10px; border: 1px solid var(--border, rgba(255,255,255,0.1)); background: var(--bg-card, rgba(255,255,255,0.05)); color: var(--text-main, #e2e8f0); font-size: 0.95rem; outline: none; resize: vertical;">{{ event.description }}</textarea>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div>
                <label style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 6px; color: var(--text-secondary, #94a3b8);">Start Date *</label>
                <input type="datetime-local" name="dateStart" value="{{ event.dateStart|date('Y-m-d\\TH:i') }}" required
                       style="width: 100%; padding: 10px 14px; border-radius: 10px; border: 1px solid var(--border, rgba(255,255,255,0.1)); background: var(--bg-card, rgba(255,255,255,0.05)); color: var(--text-main, #e2e8f0); font-size: 0.95rem; outline: none;">
            </div>
            <div>
                <label style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 6px; color: var(--text-secondary, #94a3b8);">End Date *</label>
                <input type="datetime-local" name="dateEnd" value="{{ event.dateEnd|date('Y-m-d\\TH:i') }}" required
                       style="width: 100%; padding: 10px 14px; border-radius: 10px; border: 1px solid var(--border, rgba(255,255,255,0.1)); background: var(--bg-card, rgba(255,255,255,0.05)); color: var(--text-main, #e2e8f0); font-size: 0.95rem; outline: none;">
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div>
                <label style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 6px; color: var(--text-secondary, #94a3b8);">Max Capacity *</label>
                <input type="number" name="maxCapacity" value="{{ event.maxCapacity }}" min="1" required
                       style="width: 100%; padding: 10px 14px; border-radius: 10px; border: 1px solid var(--border, rgba(255,255,255,0.1)); background: var(--bg-card, rgba(255,255,255,0.05)); color: var(--text-main, #e2e8f0); font-size: 0.95rem; outline: none;">
            </div>
            <div>
                <label style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 6px; color: var(--text-secondary, #94a3b8);">Location</label>
                <input type="text" name="location" value="{{ event.location }}" id="locationInput"
                       style="width: 100%; padding: 10px 14px; border-radius: 10px; border: 1px solid var(--border, rgba(255,255,255,0.1)); background: var(--bg-card, rgba(255,255,255,0.05)); color: var(--text-main, #e2e8f0); font-size: 0.95rem; outline: none;"
                       {{ event.isOnline ? 'disabled' : '' }}>
            </div>
        </div>

        <div style="display: flex; align-items: center; gap: 10px;">
            <input type="checkbox" name="isOnline" id="isOnlineCheck" {{ event.isOnline ? 'checked' : '' }}
                   style="width: 18px; height: 18px; accent-color: #6366f1;"
                   onchange="document.getElementById('locationInput').disabled = this.checked;">
            <label for="isOnlineCheck" style="font-size: 0.9rem; color: var(--text-secondary, #94a3b8); cursor: pointer;">Online Event (auto-generates meeting link)</label>
        </div>

        <div>
            <label style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 6px; color: var(--text-secondary, #94a3b8);">Event Image</label>
            {% if event.image %}
                <div style="margin-bottom: 8px;">
                    <img src="{{ asset('uploads/events/' ~ event.image) }}" style="max-width: 200px; border-radius: 10px; border: 1px solid var(--border, rgba(255,255,255,0.1));" alt="Current image">
                    <div style="font-size: 0.75rem; color: var(--text-muted, #64748b); margin-top: 4px;">Current image — upload a new one to replace it</div>
                </div>
            {% endif %}
            <input type="file" name="image" accept="image/jpeg,image/png,image/webp,image/gif"
                   style="width: 100%; padding: 10px; border-radius: 10px; border: 1px solid var(--border, rgba(255,255,255,0.1)); background: var(--bg-card, rgba(255,255,255,0.05)); color: var(--text-main, #e2e8f0); font-size: 0.9rem;">
        </div>

        <div style="display: flex; gap: 1rem; margin-top: 0.5rem;">
            <button type="submit" style="flex: 1; padding: 12px 20px; background: linear-gradient(135deg, #6366f1, #a855f7); color: white; border: none; border-radius: 12px; font-size: 1rem; font-weight: 600; cursor: pointer; transition: 0.3s;">
                Save Changes
            </button>
            <a href="{{ path('app_event_index') }}" style="padding: 12px 20px; background: transparent; border: 1px solid var(--border, rgba(255,255,255,0.1)); color: var(--text-secondary, #94a3b8); border-radius: 12px; font-size: 1rem; text-decoration: none; text-align: center;">
                Cancel
            </a>
        </div>
    </form>
</div>
{% endblock %}
