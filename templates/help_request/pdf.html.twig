<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Help Request #{{ session.helpRequest.id }}</title>
    <style>
        body { font-family: Arial, sans-serif; font-size: 14px; color: #333; line-height: 1.5; }
        .header { border-bottom: 2px solid #6366f1; padding-bottom: 20px; margin-bottom: 30px; }
        .title { font-size: 24px; font-weight: bold; color: #111; margin: 0; }
        .meta { color: #666; font-size: 12px; margin-top: 5px; }
        .status { font-weight: bold; color: #6366f1; }
        .section { margin-bottom: 25px; }
        .section-title { font-size: 16px; font-weight: bold; border-bottom: 1px solid #eee; padding-bottom: 5px; margin-bottom: 15px; color: #444; }
        
        /* Chat */
        .message { margin-bottom: 10px; padding: 10px; border-radius: 8px; background-color: #f9f9f9; page-break-inside: avoid; }
        .message.tutor { background-color: #eff6ff; border: 1px solid #dbeafe; }
        .message.student { background-color: #f5f3ff; border: 1px solid #ede9fe; }
        .sender { font-weight: bold; font-size: 11px; color: #555; margin-bottom: 4px; display: block; }
        .timestamp { float: right; color: #999; font-size: 10px; }
        .text { display: block; white-space: pre-wrap; }
    </style>
</head>
<body>
    <div class="header">
        <h1 class="title">{{ session.helpRequest.title }}</h1>
        <div class="meta">
            Status: <span class="status">{{ session.helpRequest.status }}</span> | 
            Bounty: {{ session.helpRequest.bounty }} PTS | 
            Student: {{ session.helpRequest.student.fullName }}
        </div>
        <div class="meta">
            Session Date: {{ session.startedAt|date('F j, Y, H:i') }}
            {% if session.endedAt %} - {{ session.endedAt|date('H:i') }}{% endif %}
        </div>
    </div>

    <div class="section">
        <div class="section-title">Description</div>
        <div>{{ session.helpRequest.description }}</div>
    </div>

    <div class="section">
        <div class="section-title">Session Transcript</div>
        {% for message in session.messages %}
            <div class="message {{ message.sender == session.tutor ? 'tutor' : 'student' }}">
                <span class="timestamp">{{ message.timestamp|date('H:i') }}</span>
                <span class="sender">{{ message.sender.fullName }} ({{ message.sender == session.tutor ? 'Tutor' : 'Student' }})</span>
                <span class="text">{{ message.content }}</span>
            </div>
        {% else %}
            <div style="color: #999; font-style: italic;">No messages in this session.</div>
        {% endfor %}
    </div>

    {% if session.review %}
        <div class="section">
            <div class="section-title">Review</div>
            <div>
                <strong>Rating:</strong> {{ session.review.rating }}/5 stars<br>
                <strong>Comment:</strong> {{ session.review.comment }}
            </div>
        </div>
    {% endif %}
    
    <div style="margin-top: 50px; font-size: 10px; color: #999; text-align: center; border-top: 1px solid #eee; padding-top: 10px;">
        Generated by EduLink Assistance Module
    </div>
</body>
</html>
