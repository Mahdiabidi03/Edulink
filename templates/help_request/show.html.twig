{% extends 'base.html.twig' %}

{% block title %}{{ help_request.title }} - Help Board{% endblock %}

{% block content %}
<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Back Button -->
            <a href="{{ path('app_help_request_index') }}" class="btn btn-outline-secondary mb-3">
                <i class="ri-arrow-left-line me-1"></i> Back to Help Board
            </a>

            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h2 class="fw-bold mb-2">{{ help_request.title }}</h2>
                            <span class="badge {{ help_request.status == 'OPEN' ? 'bg-success' : (help_request.status == 'IN_PROGRESS' ? 'bg-warning' : 'bg-secondary') }}">
                                {{ help_request.status }}
                            </span>
                            {% if help_request.closeReason %}
                                <span class="badge bg-info ms-1">{{ help_request.closeReason }}</span>
                            {% endif %}
                        </div>
                        <span class="badge bg-primary rounded-pill fs-6">{{ help_request.bounty }} Points</span>
                    </div>

                    <hr>

                    <div class="mb-4">
                        <h6 class="text-muted mb-2">Description</h6>
                        <p>{{ help_request.description }}</p>
                    </div>

                    <div class="d-flex justify-content-between align-items-center text-muted small">
                        <div>
                            <i class="ri-user-line me-1"></i> {{ help_request.student.fullName|default('Unknown') }}
                        </div>
                        <div>
                            <i class="ri-time-line me-1"></i> {{ help_request.createdAt|date('M d, Y H:i') }}
                        </div>
                    </div>

                    {% if help_request.session %}
                        <hr>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted">Tutor: <strong>{{ help_request.session.tutor.fullName|default('N/A') }}</strong></span>
                            <a href="{{ path('app_help_request_chat', {'id': help_request.session.id}) }}" class="btn btn-sm btn-primary">
                                <i class="ri-chat-3-line me-1"></i> Open Chat
                            </a>
                        </div>
                    {% endif %}
                </div>

                {% if app.user == help_request.student and help_request.status == 'OPEN' %}
                <div class="card-footer bg-transparent d-flex gap-2">
                    <a href="{{ path('app_help_request_edit', {'id': help_request.id}) }}" class="btn btn-outline-warning">
                        <i class="ri-edit-line me-1"></i> Edit
                    </a>
                    <form action="{{ path('app_help_request_delete', {'id': help_request.id}) }}" method="post" onsubmit="return confirm('Are you sure?');">
                        <button type="submit" class="btn btn-outline-danger">
                            <i class="ri-delete-bin-line me-1"></i> Delete
                        </button>
                    </form>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
