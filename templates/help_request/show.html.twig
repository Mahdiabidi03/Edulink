{% extends 'base.html.twig' %}

{% block title %}{{ help_request.title }} - Help Board{% endblock %}

{% block content %}
<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Back Button -->
            <a href="{{ path('app_help_request_index') }}" class="btn btn-outline-secondary mb-3">
                <i class="ri-arrow-left-line me-1"></i> Back to Help Board
            </a>

            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h2 class="fw-bold mb-2">{{ help_request.title }}</h2>
                            <span class="badge {{ help_request.status == 'OPEN' ? 'bg-success' : (help_request.status == 'IN_PROGRESS' ? 'bg-warning' : 'bg-secondary') }}">
                                {{ help_request.status }}
                            </span>
                            {% if help_request.closeReason %}
                                <span class="badge bg-info ms-1">{{ help_request.closeReason }}</span>
                            {% endif %}
                        </div>
                        <span class="badge bg-primary rounded-pill fs-6">{{ help_request.bounty }} Points</span>
                    </div>

                    <hr>

                    <div class="mb-4">
                        <h6 class="text-muted mb-2">Description</h6>
                        <p>{{ help_request.description }}</p>
                    </div>

                    <div class="d-flex justify-content-between align-items-center text-muted small">
                        <div>
                            <i class="ri-user-line me-1"></i> {{ help_request.student.fullName|default('Unknown') }}
                        </div>
                        <div>
                            <i class="ri-time-line me-1"></i> {{ help_request.createdAt|date('M d, Y H:i') }}
                        </div>
                    </div>

                    {% if help_request.session %}
                        <hr>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted">Tutor: <strong>{{ help_request.session.tutor.fullName|default('N/A') }}</strong></span>
                            <a href="{{ path('app_help_request_chat', {'id': help_request.session.id}) }}" class="btn btn-sm btn-primary">
                                <i class="ri-chat-3-line me-1"></i> Open Chat
                            </a>
                        </div>
                    {% endif %}
                </div>

                {% if app.user == help_request.student and help_request.status == 'OPEN' %}
                <div class="card-footer bg-transparent d-flex gap-2">
                    <a href="{{ path('app_help_request_edit', {'id': help_request.id}) }}" class="btn btn-outline-warning">
                        <i class="ri-edit-line me-1"></i> Edit
                    </a>
                    <form action="{{ path('app_help_request_delete', {'id': help_request.id}) }}" method="post" onsubmit="return confirm('Are you sure?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_help_' ~ help_request.id) }}">
                        <button type="submit" class="btn btn-outline-danger">
                            <i class="ri-delete-bin-line me-1"></i> Delete
                        </button>
                    </form>
                </div>
                {% endif %}
            </div>

            {# ======================== AI SMART MATCHING: RECOMMENDED TUTORS ======================== #}
            {% if suggested_tutors is defined and suggested_tutors|length > 0 and help_request.status == 'OPEN' %}
            <div class="card shadow-sm border-0 mt-4" style="border-left: 3px solid #10b981 !important;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-1" style="display: flex; align-items: center; gap: 8px;">
                        <span style="background: linear-gradient(135deg, #10b981, #059669); color: white; width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1rem;">
                            <i class="ri-robot-line"></i>
                        </span>
                        AI Recommended Tutors
                    </h5>
                    <p class="text-muted small mb-3">ML-powered matching using TF-IDF text similarity, expertise, and availability</p>

                    <div class="row g-3">
                        {% for tutor in suggested_tutors %}
                        <div class="col-md-4">
                            <div style="background: rgba(16, 185, 129, 0.04); border: 1px solid rgba(16, 185, 129, 0.15); border-radius: 12px; padding: 16px; text-align: center; transition: all 0.2s;">
                                {# Avatar #}
                                <div style="width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, #6366f1, #8b5cf6); display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 1.1rem; margin: 0 auto 10px;">
                                    {{ tutor.user.fullName|first|default('?') }}
                                </div>
                                <h6 class="fw-bold mb-1" style="font-size: 0.9rem;">{{ tutor.user.fullName }}</h6>

                                {# Match Score Badge #}
                                <span style="background: linear-gradient(135deg, #10b981, #059669); color: white; padding: 3px 10px; border-radius: 20px; font-size: 0.72rem; font-weight: 700;">
                                    {{ tutor.score }}% Match
                                </span>

                                {# Stats #}
                                <div style="margin-top: 10px; font-size: 0.78rem; color: #64748b; display: flex; flex-direction: column; gap: 4px;">
                                    <div>
                                        {% for i in 1..5 %}
                                            <i class="ri-star-{{ i <= tutor.avgRating|round ? 'fill' : 'line' }}" style="color: {% if i <= tutor.avgRating|round %}#f59e0b{% else %}#cbd5e1{% endif %}; font-size: 0.85rem;"></i>
                                        {% endfor %}
                                        <span style="margin-left: 4px;">{{ tutor.avgRating|number_format(1) }}</span>
                                    </div>
                                    <div><i class="ri-graduation-cap-line"></i> {{ tutor.completedSessions }} sessions completed</div>
                                    {% if tutor.similarity is defined and tutor.similarity > 0 %}
                                        <div style="color: #06b6d4; font-weight: 600;">
                                            <i class="ri-brain-line"></i> {{ (tutor.similarity * 100)|round }}% text similarity (TF-IDF)
                                        </div>
                                    {% endif %}
                                    <div>
                                        {% if tutor.isAvailable %}
                                            <span style="color: #10b981; font-weight: 600;"><i class="ri-checkbox-circle-fill"></i> Available now</span>
                                        {% else %}
                                            <span style="color: #f59e0b;"><i class="ri-time-line"></i> Currently busy</span>
                                        {% endif %}
                                    </div>
                                    {% if tutor.categoryMatch %}
                                        <div style="color: #6366f1; font-weight: 600;"><i class="ri-check-double-line"></i> Expert in {{ help_request.category }}</div>
                                    {% endif %}
                                </div>

                                {# ===== INVITE BUTTON ===== #}
                                {% if app.user == help_request.student %}
                                    <form action="{{ path('app_help_request_invite_tutor', {'id': help_request.id, 'tutorId': tutor.user.id}) }}" method="post" style="margin-top: 12px;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('invite_tutor_' ~ help_request.id ~ '_' ~ tutor.user.id) }}">
                                        <button type="submit" style="width: 100%; padding: 8px 16px; border-radius: 8px; border: none; background: linear-gradient(135deg, #10b981, #059669); color: white; font-size: 0.82rem; font-weight: 700; cursor: pointer; transition: all 0.2s; font-family: inherit; display: flex; align-items: center; justify-content: center; gap: 6px;"
                                            onmouseover="this.style.transform='translateY(-1px)'; this.style.boxShadow='0 4px 12px rgba(16,185,129,0.3)'"
                                            onmouseout="this.style.transform='none'; this.style.boxShadow='none'">
                                            <i class="ri-send-plane-fill"></i> Request Help
                                        </button>
                                    </form>
                                {% else %}
                                    <form action="{{ path('app_help_request_join', {'id': help_request.id}) }}" method="post" style="margin-top: 12px;"
                                          onsubmit="return confirm('Join this help request as tutor?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('join_help_' ~ help_request.id) }}">
                                        <button type="submit" style="width: 100%; padding: 8px 16px; border-radius: 8px; border: 1px solid #10b981; background: transparent; color: #10b981; font-size: 0.82rem; font-weight: 700; cursor: pointer; transition: all 0.2s; font-family: inherit; display: flex; align-items: center; justify-content: center; gap: 6px;"
                                            onmouseover="this.style.background='rgba(16,185,129,0.08)'; this.style.transform='translateY(-1px)'"
                                            onmouseout="this.style.background='transparent'; this.style.transform='none'">
                                            <i class="ri-hand-heart-line"></i> Join as Tutor
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
            {% endif %}

        </div>
    </div>
</div>
{% endblock %}
