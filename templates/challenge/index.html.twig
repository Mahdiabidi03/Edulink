{% extends 'base.html.twig' %}

{% block title %}Challenges{% endblock %}

{% block content %}
<style>
    .search-bar-container {
        display: flex;
        gap: 12px;
        align-items: center;
        margin-bottom: 2rem;
        background: #111827;
        padding: 1.5rem;
        border-radius: 16px;
        border: 1px solid #374151;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }

    .search-wrapper {
        position: relative;
        flex: 1;
        max-width: 400px;
        display: flex;
        align-items: center;
    }

    .search-wrapper i {
        position: absolute;
        left: 16px;
        color: #9ca3af;
        width: 18px;
        height: 18px;
        z-index: 10;
        pointer-events: none;
    }

    .search-wrapper input {
        width: 100%;
        padding: 10px 16px 10px 44px !important;
        background: #1f2937 !important;
        border: 1px solid #374151 !important;
        color: #f3f4f6 !important;
        border-radius: 8px !important;
        font-size: 0.95rem;
        transition: all 0.2s;
    }

    .search-wrapper input:focus {
        border-color: #8b5cf6 !important;
        outline: none;
        box-shadow: 0 0 0 2px rgba(139, 92, 246, 0.2);
    }

    .filters-wrapper {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .filter-select {
        background: #1f2937 !important;
        border: 1px solid #374151 !important;
        color: #f3f4f6 !important;
        padding: 10px 32px 10px 16px !important;
        border-radius: 8px !important;
        cursor: pointer;
        font-size: 0.95rem;
    }

    .btn-search {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #8b5cf6 !important;
        color: white !important;
        padding: 10px 24px !important;
        border-radius: 8px !important;
        font-weight: 600;
        border: none !important;
        transition: all 0.2s;
        cursor: pointer;
    }

    .btn-search:hover {
        background: #7c3aed !important;
        transform: translateY(-1px);
    }

    .btn-clear {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #374151 !important;
        color: #f3f4f6 !important;
        padding: 10px 20px !important;
        border-radius: 8px !important;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-clear:hover {
        background: #4b5563 !important;
    }
</style>

<div class="container-fluid" style="padding: 2rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1 style="margin: 0; font-size: 2.2rem; background: var(--brand-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-weight: 800; letter-spacing: -1px;">Challenge Hub</h1>
            <p style="color: var(--text-secondary); margin-top: 0.5rem;">Join challenges and earn XP points!</p>
        </div>

        <div style="display: flex; gap: 1rem;">
            {% if app.user %}
                <a href="{{ path('my_challenges') }}" class="btn secondary">
                    <i data-lucide="award"></i> Mes Challenges
                </a>
            {% endif %}
        </div>
    </div>

    {# Search & Filter #}
    <form method="get" action="{{ path('challenge_index') }}" class="search-bar-container">
        <div class="search-wrapper">
            <i data-lucide="search"></i>
            <input type="text" name="q" value="{{ q|default('') }}" placeholder="Search challenges...">
        </div>
        
        <div class="filters-wrapper">
            <select name="order" class="filter-select" style="min-width: 250px;">
                <option value="newest" {{ order == 'newest' ? 'selected' : '' }}>Most Recent</option>
                <option value="alpha_asc" {{ order == 'alpha_asc' ? 'selected' : '' }}>Ordre alphabétique (A-Z)</option>
                <option value="alpha_desc" {{ order == 'alpha_desc' ? 'selected' : '' }}>Ordre alphabétique (Z-A)</option>
                <option value="xp_desc" {{ order == 'xp_desc' ? 'selected' : '' }}>XP rewarded (High to Low)</option>
                <option value="xp_asc" {{ order == 'xp_asc' ? 'selected' : '' }}>XP rewarded (Low to High)</option>
            </select>

            <button type="submit" class="btn-search">
                <i data-lucide="search" style="width: 18px; height: 18px;"></i>
                <span>Search</span>
            </button>

            {% if q or order != 'newest' %}
                <a href="{{ path('challenge_index') }}" class="btn-clear">
                    <i data-lucide="rotate-ccw" style="width: 18px; height: 18px;"></i>
                    <span>Clear</span>
                </a>
            {% endif %}
        </div>
    </form>

    <div class="row" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem;">
        {% for c in challenges %}
            <div class="card" style="display: flex; flex-direction: column; transition: transform 0.2s; height: 100%;">
                <div class="card-body" style="padding: 1.5rem; display: flex; flex-direction: column; flex: 1;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
                        <h3 style="margin: 0; font-size: 1.25rem; font-weight: 700; color: var(--text-main);">{{ c.title }}</h3>
                        <div class="wallet-badge" style="background: rgba(139, 92, 246, 0.1); color: var(--brand-main); padding: 4px 12px; border-radius: 20px; font-weight: 700; font-size: 0.85rem;">
                            +{{ c.rewardPoints }} XP
                        </div>
                    </div>
                    
                    <p style="color: var(--text-secondary); line-height: 1.6; margin-bottom: 1.5rem; flex: 1;">{{ c.goal }}</p>

                    <div style="margin-top: auto;">
                        {% if app.user %}
                            {% if c.id in joinedChallengeIds %}
                                <div style="display: flex; align-items: center; gap: 8px; color: var(--success); font-weight: 600; padding: 10px; background: rgba(16, 185, 129, 0.1); border-radius: 8px; justify-content: center;">
                                    <i data-lucide="check-circle"></i> Déjà rejoint
                                </div>
                            {% else %}
                                <form method="post" action="{{ path('challenge_join', {id: c.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('join_challenge_' ~ c.id) }}">
                                    <button class="btn" style="width: 100%;">
                                        <i data-lucide="plus"></i> Rejoindre
                                    </button>
                                </form>
                            {% endif %}
                        {% else %}
                            <a href="{{ path('login') }}" class="btn secondary" style="width: 100%;">
                                Se connecter pour rejoindre
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% else %}
            <div class="card" style="grid-column: 1 / -1; padding: 3rem; text-align: center;">
                <i data-lucide="info" style="width: 48px; height: 48px; color: var(--text-muted); margin-bottom: 1rem;"></i>
                <p style="color: var(--text-secondary); font-size: 1.1rem;">Aucun challenge disponible pour le moment.</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
