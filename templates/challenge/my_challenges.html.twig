{% extends 'base.html.twig' %}

{% block title %}Mes Challenges{% endblock %}

{% block content %}
<div class="container-fluid" style="padding: 2rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1 style="margin: 0; font-size: 2.2rem; background: var(--brand-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-weight: 800; letter-spacing: -1px;">Mes Challenges</h1>
            <p style="color: var(--text-secondary); margin-top: 0.5rem;">Track your progress and complete challenges!</p>
        </div>

        <a href="{{ path('challenge_index') }}" class="btn secondary">
            <i data-lucide="arrow-left"></i> Back to Hub
        </a>
    </div>

    <div class="row" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 1.5rem;">
        {% for p in participations %}
            {% set parts = p.progress|split('/') %}
            {% set current = 0 + (parts[0]|default('0')) %}
            {% set total = 3 %}
            {% set percent = ((current / total) * 100)|round(0, 'floor') %}

            <div class="card" style="display: flex; flex-direction: column;">
                <div class="card-body" style="padding: 1.5rem;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
                        <h3 style="margin: 0; font-size: 1.25rem; font-weight: 700; color: var(--text-main);">{{ p.challenge.title }}</h3>
                        
                        <div>
                            {% if p.status == 'IN_PROGRESS' %}
                                <span class="badge" style="background: rgba(99, 102, 241, 0.1); color: var(--brand-main);">In progress</span>
                            {% elseif p.status == 'PENDING' %}
                                <span class="badge" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b;">Pending validation</span>
                            {% elseif p.status == 'COMPLETED' %}
                                <span class="badge" style="background: rgba(16, 185, 129, 0.1); color: var(--success);">Completed</span>
                            {% endif %}
                        </div>
                    </div>

                    <p style="color: var(--text-secondary); line-height: 1.6; margin-bottom: 1.5rem;">{{ p.challenge.goal }}</p>

                    <div style="margin-bottom: 1.5rem;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                            <span style="font-size: 0.85rem; color: var(--text-muted); font-weight: 600;">PROGRESS</span>
                            <span style="font-weight: 700; color: var(--text-main);">{{ current }}/{{ total }}</span>
                        </div>
                        <div style="background: var(--bg-main); border-radius: 999px; height: 8px; overflow: hidden; border: 1px solid var(--border);">
                            <div style="height: 100%; width: {{ percent }}%; border-radius: 999px; background: var(--brand-gradient);"></div>
                        </div>
                    </div>

                    {% if p.status == 'IN_PROGRESS' %}
                        <form method="post" enctype="multipart/form-data" action="{{ path('update_progress', {id: p.id}) }}" style="background: var(--bg-main); padding: 1rem; border-radius: 12px; border: 1px solid var(--border);">
                            <input type="hidden" name="_token" value="{{ csrf_token('update_progress_' ~ p.id) }}">

                            <div class="form-group" style="margin-bottom: 1rem;">
                                <label style="display: block; margin-bottom: 0.5rem; color: var(--text-secondary); font-size: 0.85rem; font-weight: 600;">Current Step</label>
                                <select name="progress" class="form-input" style="width: 100%; padding: 8px; border-radius: 8px; background: var(--bg-card); border: 1px solid var(--border); color: var(--text-main);">
                                    {% for i in 0..3 %}
                                        {% set value = i ~ '/3' %}
                                        <option value="{{ value }}" {% if value == p.progress %}selected{% endif %}>{{ value }}</option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="form-group" style="margin-bottom: 1rem;">
                                <label style="display: block; margin-bottom: 0.5rem; color: var(--text-secondary); font-size: 0.85rem; font-weight: 600;">Proof (required for 3/3)</label>
                                <input type="file" name="proof_file" class="form-input" style="width: 100%; padding: 6px; border-radius: 8px; background: var(--bg-card); border: 1px solid var(--border); color: var(--text-main); font-size: 0.8rem;">
                            </div>

                            <button class="btn" style="width: 100%; padding: 8px;">
                                <i data-lucide="save"></i> Update Progress
                            </button>
                        </form>
                    {% endif %}

                    {% if p.status == 'PENDING' %}
                        <div style="background: rgba(245, 158, 11, 0.05); padding: 1rem; border-radius: 12px; border: 1px border-dashed #f59e0b; text-align: center;">
                            <p style="color: #f59e0b; margin-bottom: 0.75rem; font-size: 0.9rem;">Waiting for admin validation.</p>
                            {% if p.proofFileName %}
                                <a href="{{ asset('uploads/proofs/' ~ p.proofFileName) }}" target="_blank" class="btn secondary" style="font-size: 0.8rem; padding: 6px 12px;">
                                    <i data-lucide="eye"></i> View Proof
                                </a>
                            {% endif %}
                        </div>
                    {% endif %}

                    {% if p.status == 'COMPLETED' %}
                        <div style="background: rgba(16, 185, 129, 0.05); padding: 1rem; border-radius: 12px; border: 1px border-dashed var(--success); text-align: center;">
                            <p style="color: var(--success); font-weight: 600;">Challenge completed! +{{ p.challenge.rewardPoints }} XP earned.</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        {% else %}
            <div class="card" style="grid-column: 1 / -1; padding: 3rem; text-align: center;">
                <i data-lucide="award" style="width: 48px; height: 48px; color: var(--text-muted); margin-bottom: 1rem;"></i>
                <p style="color: var(--text-secondary); font-size: 1.1rem;">Vous n'avez rejoint aucun challenge.</p>
                <a href="{{ path('challenge_index') }}" class="btn" style="margin-top: 1rem; display: inline-flex;">Parcourir le Hub</a>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
