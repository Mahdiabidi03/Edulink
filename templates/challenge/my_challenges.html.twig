{% extends 'base.html.twig' %}

{% block title %}Mes Challenges{% endblock %}

{% block content %}
<div class="container-fluid" style="padding: 2rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1 style="margin: 0; font-size: 2.2rem; background: var(--brand-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-weight: 800; letter-spacing: -1px;">Mes Challenges</h1>
            <p style="color: var(--text-secondary); margin-top: 0.5rem;">Track your progress and complete challenges!</p>
        </div>

        <a href="{{ path('challenge_index') }}" class="btn secondary">
            <i data-lucide="arrow-left"></i> Back to Hub
        </a>
    </div>

    <div class="row" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 1.5rem;">
        {% for p in participations %}
            {% set parts = p.progress|split('/') %}
            {% set current = 0 + (parts[0]|default('0')) %}
            {% set total = p.challenge.tasks|length %}
            {% set percent = total > 0 ? ((current / total) * 100)|round(0, 'floor') : 100 %}

            <div class="card" style="display: flex; flex-direction: column;">
                <div class="card-body" style="padding: 1.5rem;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
                        <h3 style="margin: 0; font-size: 1.25rem; font-weight: 700; color: var(--text-main);">{{ p.challenge.title }}</h3>
                        
                        <div>
                            {% if p.status == 'IN_PROGRESS' %}
                                <span class="badge" style="background: rgba(245, 158, 11, 0.15); color: #f59e0b; font-weight: 600;">In Progress</span>
                            {% elseif p.status == 'PENDING' %}
                                <span class="badge" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b;">Pending validation</span>
                            {% elseif p.status == 'COMPLETED' %}
                                <span class="badge" style="background: rgba(16, 185, 129, 0.1); color: var(--success);">Completed</span>
                            {% endif %}
                        </div>
                    </div>

                    <p style="color: var(--text-secondary); line-height: 1.6; margin-bottom: 1.5rem;">{{ p.challenge.goal }}</p>

                    <div style="margin-bottom: 1.5rem;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                            <span style="font-size: 0.85rem; color: var(--text-muted); font-weight: 600;">PROGRESS</span>
                            <span style="font-weight: 700; color: var(--text-main);">{{ p.progress }}</span>
                        </div>
                        <div style="background: var(--bg-main); border-radius: 999px; height: 8px; overflow: hidden; border: 1px solid var(--border);">
                            <div style="height: 100%; width: {{ percent }}%; border-radius: 999px; background: var(--brand-gradient);"></div>
                        </div>
                    </div>

                    {% if p.status == 'IN_PROGRESS' %}
                        <div style="margin-top: 1rem; text-align: right; margin-bottom: 1rem;">
                            <button onclick="MotivationCoach.boostMe({{ p.id }})" class="btn" style="background: var(--brand-gradient); color: white; border: none; padding: 8px 16px; border-radius: 8px; font-weight: 600; display: inline-flex; align-items: center; gap: 8px; cursor: pointer; transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                                <i data-lucide="zap" style="width: 16px; height: 16px;"></i> Boost me!
                            </button>
                        </div>
                        
                        <div style="background: var(--bg-main); padding: 1.5rem; border-radius: 12px; border: 1px solid var(--border); margin-top: 1rem;">
                            <h4 style="font-size: 0.9rem; font-weight: 700; color: var(--text-secondary); margin-bottom: 1rem; letter-spacing: 1px;">TASKS</h4>
                            
                            <div class="task-list" style="display: flex; flex-direction: column; gap: 12px;">
                                {% for ut in p.userTasks %}
                                    <div class="task-card" 
                                         data-task-id="{{ ut.id }}"
                                         style="background: var(--bg-card); border: 2px solid {{ ut.isCompleted ? 'var(--success)' : 'var(--border)' }}; border-radius: 8px; padding: 12px; display: flex; align-items: center; gap: 12px; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); cursor: pointer;"
                                         onclick="toggleTask({{ ut.id }}, this)">
                                        
                                        <div class="check-box" style="width: 20px; height: 20px; border: 2px solid {{ ut.isCompleted ? 'var(--success)' : 'var(--text-muted)' }}; border-radius: 4px; display: flex; align-items: center; justify-content: center; background: {{ ut.isCompleted ? 'var(--success)' : 'transparent' }};">
                                            {% if ut.isCompleted %}
                                                <i data-lucide="check" style="width: 14px; height: 14px; color: white;"></i>
                                            {% endif %}
                                        </div>
                                        
                                        <div style="flex: 1;">
                                            <div style="font-weight: 600; font-size: 0.95rem; color: {{ ut.isCompleted ? 'var(--text-muted)' : 'var(--text-main)' }}; text-decoration: {{ ut.isCompleted ? 'line-through' : 'none' }};">{{ ut.task.title }}</div>
                                            <div style="font-size: 0.75rem; color: var(--text-muted);">{{ ut.task.points }} pts</div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>

                            <form id="proof-form-{{ p.id }}" method="post" enctype="multipart/form-data" action="{{ path('update_progress', {id: p.id}) }}" style="margin-top: 1.5rem; display: {{ (total == 0 or current >= total) ? 'block' : 'none' }};">
                                <input type="hidden" name="_token" value="{{ csrf_token('update_progress_' ~ p.id) }}">
                                <input type="hidden" name="progress" id="progress-input-{{ p.id }}" value="{{ p.progress }}">
                                
                                <label class="file-upload-label" style="padding: 1rem; border-style: dashed; border-width: 2px;">
                                    <i data-lucide="upload-cloud"></i>
                                    <span style="display: block; font-size: 0.85rem; font-weight: 600;">Upload Proof to Complete</span>
                                    <input type="file" name="proof_file" class="file-upload-input" accept="image/*,.pdf,.doc,.docx,.zip,.rar" onchange="this.form.submit()">
                                </label>
                            </form>
                        </div>
                    {% endif %}

                    {% if p.status == 'PENDING' %}
                        <div style="background: rgba(245, 158, 11, 0.05); padding: 1rem; border-radius: 12px; border: 1px border-dashed #f59e0b; text-align: center;">
                            <p style="color: #f59e0b; margin-bottom: 0.75rem; font-size: 0.9rem;">Waiting for admin validation.</p>
                            {% if p.proofFileName %}
                                <a href="{{ asset('uploads/proofs/' ~ p.proofFileName) }}" target="_blank" class="btn secondary" style="font-size: 0.8rem; padding: 6px 12px;">
                                    <i data-lucide="eye"></i> View Proof
                                </a>
                            {% endif %}
                        </div>
                    {% endif %}

                    {% if p.status == 'COMPLETED' %}
                        <div style="background: rgba(16, 185, 129, 0.05); padding: 1rem; border-radius: 12px; border: 1px border-dashed var(--success); text-align: center;">
                            <p style="color: var(--success); font-weight: 600;">Challenge completed! +{{ p.challenge.rewardPoints }} XP earned.</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        {% else %}
            <div class="card" style="grid-column: 1 / -1; padding: 3rem; text-align: center;">
                <i data-lucide="award" style="width: 48px; height: 48px; color: var(--text-muted); margin-bottom: 1rem;"></i>
                <p style="color: var(--text-secondary); font-size: 1.1rem;">Vous n'avez rejoint aucun challenge.</p>
                <a href="{{ path('challenge_index') }}" class="btn" style="margin-top: 1rem; display: inline-flex;">Parcourir le Hub</a>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
async function toggleTask(userTaskId, element) {
    try {
        const response = await fetch(`/my-challenges/task/${userTaskId}/toggle`, {
            method: 'POST',
            credentials: 'same-origin',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        });
        
        if (!response.ok) {
            const text = await response.text();
            console.error('Toggle failed:', response.status, text);
            alert('Failed to toggle task (status ' + response.status + '). Check console.');
            return;
        }

        const data = await response.json();
        
        if (data.success) {
            // Update card UI
            const checkBox = element.querySelector('.check-box');
            const titleDiv = element.querySelector('div[style*="flex: 1"] > div:first-child');
            
            if (data.completed) {
                element.style.borderColor = 'var(--success)';
                if (checkBox) {
                    checkBox.style.background = 'var(--success)';
                    checkBox.style.borderColor = 'var(--success)';
                    checkBox.innerHTML = '<i data-lucide="check" style="width: 14px; height: 14px; color: white;"></i>';
                }
                if (titleDiv) {
                    titleDiv.style.textDecoration = 'line-through';
                    titleDiv.style.color = 'var(--text-muted)';
                }
            } else {
                element.style.borderColor = 'var(--border)';
                if (checkBox) {
                    checkBox.style.background = 'transparent';
                    checkBox.style.borderColor = 'var(--text-muted)';
                    checkBox.innerHTML = '';
                }
                if (titleDiv) {
                    titleDiv.style.textDecoration = 'none';
                    titleDiv.style.color = 'var(--text-main)';
                }
            }
            
            if (typeof lucide !== 'undefined') lucide.createIcons();
            
            // Update global progress bar
            const cardBody = element.closest('.card-body');
            if (cardBody) {
                const progressSpan = cardBody.querySelector('span[style*="font-weight: 700"]');
                const progressBar = cardBody.querySelector('div[style*="height: 100%"]');
                
                if (progressSpan) progressSpan.textContent = data.progress;
                
                const [current, total] = data.progress.split('/').map(Number);
                const percent = total > 0 ? (current / total) * 100 : 0;

                if (progressBar) {
                    progressBar.style.width = percent + '%';
                }
                
                // Show/Hide proof form
                const card = cardBody.closest('.card');
                const proofForm = card ? card.querySelector('form[id^="proof-form-"]') : null;
                const progressInput = proofForm ? proofForm.querySelector('input[name="progress"]') : null;
                
                if (progressInput) progressInput.value = data.progress;
                
                if (proofForm) {
                    if (current >= total) {
                        proofForm.style.display = 'block';
                        if (typeof confetti === 'function') {
                            confetti({
                                particleCount: 100,
                                spread: 70,
                                origin: { y: 0.6 }
                            });
                        }
                    } else {
                        proofForm.style.display = 'none';
                    }
                }
            }
        } else {
            alert('Server error: toggle unsuccessful');
        }
    } catch (error) {
        console.error('Error toggling task:', error);
        alert('Error toggling task: ' + error.message);
    }
}
</script>
<script src="{{ asset('js/motivation.js') }}"></script>
{% endblock %}
