{% extends 'auth_base.html.twig' %}

{% block title %}Reset Password - EduLink{% endblock %}

{% block content %}
<!-- 3D Background -->
<div class="auth-scene">
    <div class="cube-container">
        <div class="cube"></div>
        <div class="cube"></div>
        <div class="cube"></div>
        <div class="cube"></div>
        <div class="cube"></div>
    </div>
</div>

<div class="login-container" data-aos="zoom-in" data-aos-duration="1000">
  
  <div class="login-card">
    <img src="{{ asset('assets/images/logo.png') }}" class="login-logo">
    <h2>Reset Password</h2>
    <p class="subtitle" id="step-desc">Enter your email to receive recovery instructions</p>

    <!-- STEP 1: Email -->
    <form id="step1-form" novalidate>
      <div class="input-group">
        <input type="email" id="reset-email" placeholder="Email Address">
        <i class="ri-mail-send-line input-icon"></i>
      </div>
      <button type="submit" class="btn login-btn" id="btn-otp">
        <span>Send Reset Code</span> <i class="ri-send-plane-fill" style="margin-left: 5px;"></i>
      </button>
    </form>

    <!-- STEP 2: OTP -->
    <form id="step2-form" style="display: none;" novalidate>
      <div class="input-group">
        <input type="text" id="reset-otp" placeholder="Enter 6-digit Code" maxlength="6" style="letter-spacing: 5px; text-align: center; font-weight: bold;">
        <i class="ri-lock-password-line input-icon"></i>
      </div>
      <button type="submit" class="btn login-btn" style="background: var(--brand-accent);">
        Verify Code
      </button>
    </form>

    <!-- STEP 3: New Password -->
    <form id="step3-form" style="display: none;" novalidate>
        <div class="input-group">
        <input type="password" id="new-pass" placeholder="New Password">
        <i class="ri-lock-2-line input-icon"></i>
      </div>
      <div class="input-group">
        <input type="password" id="confirm-pass" placeholder="Confirm Password">
        <i class="ri-check-double-line input-icon"></i>
      </div>
      <button type="submit" class="btn login-btn" style="background: var(--success);">
        Update Password
      </button>
    </form>
    
    <div id="msg-box" style="margin-top: 15px; font-size: 0.9rem; text-align: center;"></div>

    <p class="register-link">
      <a href="{{ path('login') }}" style="color: var(--text-muted); font-weight: 500;"><i class="ri-arrow-left-line"></i> Back to Login</a>
    </p>
  </div>

<script>
    let userEmail = '';
    let confirmedOtp = '';

    const msgBox = document.getElementById('msg-box');
    function showMsg(msg, type = 'error') {
        msgBox.innerText = msg;
        msgBox.style.color = type === 'success' ? 'var(--success)' : 'var(--error)';
    }

    // Step 1: Send OTP
    document.getElementById('step1-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('btn-otp');
        btn.innerHTML = '<i class="ri-loader-4-line ri-spin"></i> Sending...';
        btn.disabled = true;

        userEmail = document.getElementById('reset-email').value;

        try {
            const res = await fetch('/api/auth/reset/otp', {
                method: 'POST',
                body: JSON.stringify({ email: userEmail })
            });

            if(res.ok) { 
                const data = await res.json();
                
                document.getElementById('step1-form').style.display = 'none';
                document.getElementById('step2-form').style.display = 'block';
                document.getElementById('step-desc').innerText = 'Enter the code sent to ' + userEmail;
                
                if (data.debug_otp) {
                     if(data.debug_otp === 'USER_NOT_FOUND') {
                         showMsg('Debug: This email does not exist in the database.', 'error');
                     } else {
                         showMsg('DEV MODE: Email failed but here is your code: ' + data.debug_otp, 'success');
                         alert('DEV OTP: ' + data.debug_otp); 
                     }
                } else {
                     showMsg('Code sent! Check your inbox (and spam).', 'success');
                }
            } else {
                 console.error('Reset Error:', res.status, res.statusText);
                 try {
                    const errData = await res.json();
                    showMsg('Error: ' + (errData.error || res.statusText) + ' (' + res.status + ')');
                 } catch(e) {
                    showMsg('Error: Server returned ' + res.status + ' ' + res.statusText);
                 }
                 
                 btn.innerHTML = 'Send Reset Code';
                 btn.disabled = false;
            }
        } catch(err) {
            showMsg('Network error.');
             btn.innerHTML = 'Send Reset Code';
             btn.disabled = false;
        }
    });

    // Step 2: Verify OTP
    document.getElementById('step2-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const otpCodes = document.getElementById('reset-otp').value;

        const res = await fetch('/api/auth/reset/verify', {
            method: 'POST',
             body: JSON.stringify({ email: userEmail, otp: otpCodes })
        });

        if(res.ok) {
            confirmedOtp = otpCodes;
            document.getElementById('step2-form').style.display = 'none';
            document.getElementById('step3-form').style.display = 'block';
            document.getElementById('step-desc').innerText = 'Create a new secure password';
            showMsg('Code verified!', 'success');
        } else {
            showMsg('Invalid or expired code.');
        }
    });

    // Step 3: Reset
    document.getElementById('step3-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const p1 = document.getElementById('new-pass').value;
        const p2 = document.getElementById('confirm-pass').value;

        if(p1 !== p2) {
            showMsg('Passwords do not match');
            return;
        }

        const res = await fetch('/api/auth/reset/password', {
            method: 'POST',
             body: JSON.stringify({ email: userEmail, otp: confirmedOtp, password: p1 })
        });

        if(res.ok) {
             document.querySelector('.login-card').innerHTML = `
                <div style="text-align: center; padding: 2rem;">
                    <i class="ri-checkbox-circle-fill" style="font-size: 4rem; color: var(--success);"></i>
                    <h3>Success!</h3>
                    <p>Your password has been updated.</p>
                    <a href="/login" class="btn login-btn" style="margin-top: 1rem;">Back to Login</a>
                </div>
             `;
        } else {
            showMsg('Failed to update password.');
        }
    });
</script>

</div>
{% endblock %}
